<div class="container mt-5 mb-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <!-- Success notice -->
      <% if flash[:notice] %>
        <div class="alert alert-success"><%= flash[:notice] %></div>
      <% end %>

      <h2 class="fw-bold mb-4">Edit profile</h2>

      <!-- Main form (targets ProfilesController#update) -->
      <%= form_with(model: @user, url: profile_path, method: :patch) do |f| %>

        <% if @user.errors.any? %>
          <div class="alert alert-danger">
            <% @user.errors.full_messages.each do |msg| %>
              <div><%= msg %></div>
            <% end %>
          </div>
        <% end %>

        <!-- Section 1: User information -->
        <div class="card shadow-sm mb-4">
          <div class="card-header"><h5 class="mb-0">Account information</h5></div>
          <div class="card-body">

            <div class="mb-3">
              <%= f.label :name, "Full name", class: "form-label" %>
              <%= f.text_field :name, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :email, "Email", class: "form-label" %>
              <%= f.email_field :email, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :avatar_url, "Avatar URL", class: "form-label" %>
              <%= f.text_field :avatar_url, class: "form-control", placeholder: "https://..." %>
              <small class="text-muted">Paste an image link (e.g., Gravatar, Imgur...)</small>
            </div>
          </div>
        </div>

        <!-- Section 2: Profile information (nested) -->
        <%= f.fields_for :profile do |profile_form| %>
          <div class="card shadow-sm mb-4">
            <div class="card-header"><h5 class="mb-0">Personal information</h5></div>
            <div class="card-body">

              <div class="mb-3">
                <%= profile_form.label :bio, "Bio", class: "form-label" %>
                <%= profile_form.text_area :bio, rows: 3, class: "form-control", placeholder: "Short intro about you..." %>
              </div>

              <div class="row">
                <div class="col-md-6 mb-3">
                  <%= profile_form.label :phone, "Phone number", class: "form-label" %>
                  <%= profile_form.text_field :phone, class: "form-control" %>
                </div>
                <div class="col-md-6 mb-3">
                  <%= profile_form.label :gender, "Gender", class: "form-label" %>
                  <%= profile_form.select :gender, Profile.genders.keys.map { |k| [k.humanize, k] }, { prompt: "Select gender" }, class: "form-select" %>
                </div>
              </div>

              <div class="mb-3">
                <%= profile_form.label :dob, "Date of birth", class: "form-label" %>
                <%= profile_form.date_field :dob, class: "form-control" %>
              </div>

            </div>
          </div>
        <% end %> <!-- End fields_for -->

        <div class="d-flex justify-content-between align-items-center">
          <%= f.submit "Save changes", class: "btn btn-primary btn-lg" %>

          <%= link_to "Change password", password_edit_path, class: "btn btn-outline-secondary" %>
        </div>

      <% end %> <!-- End form_with -->

    </div>
  </div>
</div>
