<%# ============================================================ %>
<%# MY COURSES PAGE — Standardized UI (No Bootstrap)           %>
<%# ============================================================ %>

<div class="my-courses">

  <%# ── Header ─────────────────────────────────────────────── %>
  <div class="my-courses__header">
    <div class="my-courses__inner">
      <div class="my-courses__badge">Explore knowledge</div>
      <h1 class="my-courses__title">My learning</h1>
      <p class="my-courses__subtitle">
        Welcome back! You are enrolled in <strong><%= @enrollments.count %></strong> courses.
      </p>
    </div>
  </div>

  <div class="my-courses__inner">
    <% if @enrollments.empty? %>
      <div class="my-courses__empty">
        <i class="bi bi-journal-x empty-icon"></i>
        <h3>No courses yet</h3>
        <p>Start your learning journey by exploring the latest courses.</p>
        <%= link_to "Explore now", courses_path, class: "btn-primary" %>
      </div>
    <% else %>

      <div class="my-courses__grid">
        <% @enrollments.each do |enrollment| %>
          <% course = enrollment.course %>
          <% progress = current_user.course_progress_percentage(course) %>
          <% first_lesson = course.course_modules.first&.lessons&.first %>

          <article class="my-course-card <%= 'my-course-card--new' if progress == 0 %>">

            <%# Thumbnail with Play Hover %>
            <div class="my-course-card__thumb">
              <img src="<%= course.thumbnail_url.presence || 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=600&h=400&fit=crop' %>"
                   alt="<%= course.title %>" loading="lazy">

              <% if first_lesson %>
                <div class="play-overlay">
                  <%= link_to lesson_path(first_lesson), class: "btn-play", title: "Start learning" do %>
                    <i class="bi bi-play-fill"></i>
                  <% end %>
                </div>
              <% end %>
            </div>

            <div class="my-course-card__body">
              <%= link_to course.title, course_path(course), class: "my-course-card__title" %>
              <div class="my-course-card__instructor">
                 <%= course.creator&.name || "E-Learning Team" %>
              </div>

              <div class="my-course-card__progress">
                <div class="my-course-card__progress-info">
                  <span class="my-course-card__progress-label">
                    <%= progress == 100 ? "Completed" : "Progress" %>
                  </span>
                  <span class="my-course-card__progress-value"><%= progress %>%</span>
                </div>
                <div class="my-course-card__progress-bar">
                  <div class="fill" style="width: <%= progress %>%"></div>
                </div>
              </div>
            </div>

            <div class="my-course-card__footer">
              <% if first_lesson %>
                <%= link_to lesson_path(first_lesson), class: "btn-resume" do %>
                  <% if progress == 0 %>
                    Start learning
                  <% elsif progress == 100 %>
                    Review lesson
                  <% else %>
                    Continue learning <i class="bi bi-arrow-right-short"></i>
                  <% end %>
                <% end %>
              <% else %>
                <button class="btn-resume" disabled style="opacity: 0.5; cursor: not-allowed;">
                  No lessons yet
                </button>
              <% end %>
            </div>

          </article>
        <% end %>
      </div>

    <% end %>
  </div>
</div>
