<%
  all_lessons   = @lesson.course.course_modules.order(:order_index).flat_map { |mod| mod.lessons.order(:order_index) }
  current_index = all_lessons.index(@lesson)
  prev_lesson   = current_index > 0 ? all_lessons[current_index - 1] : nil
  next_lesson   = all_lessons[current_index + 1]

  course_progress = user_signed_in? ? current_user.course_progress_percentage(@lesson.course) : 0
  @big_quizzes    = @lesson.course.quizzes.where(lesson_id: nil).order(:created_at)

  embed_link = @lesson.video_url.present? ? youtube_embed_url(@lesson.video_url) : nil
%>

<div class="lesson-page">

  <%# ── TOP BAR ──────────────────────────────────────────────── %>
  <header class="lesson-topbar" role="banner">
    <div class="lesson-topbar__left">
      <%= link_to course_path(@lesson.course), class: "lesson-topbar__back" do %>
        <i class="bi bi-arrow-left"></i> Thoát
      <% end %>
      <span class="lesson-topbar__course-title"><%= @lesson.course.title %></span>
    </div>
    <span class="lesson-topbar__lesson-title"><%= @lesson.title %></span>
  </header>

  <%# ── MAIN CONTENT COLUMN ──────────────────────────────────── %>
  <main class="lesson-main" id="lesson-main">

    <%# Video player %>
    <% if embed_link.present? %>
      <div class="lesson-video">
        <iframe src="<%= embed_link %>" allowfullscreen loading="lazy"
                title="<%= @lesson.title %>"></iframe>
      </div>
    <% end %>

    <%# Lesson title + description %>
    <div class="lesson-content">
      <h1 class="lesson-content__title"><%= @lesson.title %></h1>
      <% if @lesson.description.present? %>
        <div class="lesson-content__description">
          <%= simple_format(@lesson.description) %>
        </div>
      <% end %>
    </div>

    <%# Attachment %>
    <% if @lesson.attachment_url.present? %>
      <%= link_to @lesson.attachment_url, target: "_blank", class: "lesson-attach" do %>
        <div class="lesson-attach__icon">
          <i class="bi bi-paperclip"></i>
        </div>
        <div class="lesson-attach__text">
          <span class="lesson-attach__label">
            Tài liệu tham khảo
            <i class="bi bi-box-arrow-up-right" style="font-size:0.7em; opacity:0.6;"></i>
          </span>
          <div class="lesson-attach__hint">Nhấn để xem hoặc tải xuống tài liệu</div>
        </div>
      <% end %>
    <% end %>

    <%# Completion status + toggle button (only for signed-in users) %>
    <% if user_signed_in? %>
    <div class="lesson-status">
      <div class="lesson-status__label">
        <strong>Trạng thái: </strong>
        <% if current_user.lesson_completed?(@lesson) %>
          <span class="lesson-status__badge lesson-status__badge--done">
            <i class="bi bi-check-circle-fill"></i> Đã hoàn thành
          </span>
        <% else %>
          <span class="lesson-status__badge lesson-status__badge--pending">
            Chưa hoàn thành
          </span>
        <% end %>
      </div>
      <div class="lesson-status__actions">
        <%= button_to lesson_complete_path(@lesson), method: :post,
              class: "btn-complete #{current_user.lesson_completed?(@lesson) ? 'btn-complete--done' : 'btn-complete--pending'}" do %>
          <% if current_user.lesson_completed?(@lesson) %>
            <i class="bi bi-x-circle"></i> Bỏ đánh dấu
          <% else %>
            <i class="bi bi-check2-circle"></i> Đánh dấu hoàn thành
          <% end %>
        <% end %>
      </div>
    </div>
    <% end %>

    <%# Lesson quiz CTA (only shown to signed-in users) %>
    <% if user_signed_in? && @lesson.quizzes.any? %>
      <% quiz = @lesson.quizzes.first %>
      <div class="lesson-quiz">
        <div class="lesson-quiz__info">
          <h3 class="lesson-quiz__title">
            <i class="bi bi-lightning-fill"></i> Bài tập thực hành
          </h3>
          <p class="lesson-quiz__meta"><%= quiz.title %> (<%= quiz.questions.count %> câu hỏi)</p>
        </div>
        <% if current_user.quiz_completed?(quiz) %>
          <span class="lesson-quiz__btn-done">
            <i class="bi bi-check-all"></i> Đã đậu
          </span>
        <% else %>
          <div class="lesson-quiz__btn-start">
            <%= button_to "Làm bài ngay →", quiz_quiz_attempts_path(quiz), method: :post %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Divider %>
    <hr class="lesson-divider">

    <%# Prev / Next navigation %>
    <nav class="lesson-nav" aria-label="Lesson navigation">
      <% if prev_lesson %>
        <%= link_to lesson_path(prev_lesson), class: "lesson-nav__btn" do %>
          <i class="bi bi-chevron-left"></i> Bài trước
        <% end %>
      <% else %>
        <span class="lesson-nav__btn lesson-nav__btn--disabled">
          <i class="bi bi-chevron-left"></i> Bài trước
        </span>
      <% end %>

      <% if next_lesson %>
        <%= link_to lesson_path(next_lesson), class: "lesson-nav__btn lesson-nav__btn--next" do %>
          Bài tiếp theo <i class="bi bi-chevron-right"></i>
        <% end %>
      <% else %>
        <span class="lesson-nav__btn lesson-nav__btn--next lesson-nav__btn--disabled">
          Hết bài <i class="bi bi-check2-all"></i>
        </span>
      <% end %>
    </nav>

    <%# Tabs: Overview / Q&A / Notes %>
    <%= render "tabs_container" %>

  </main>

  <%# ── SIDEBAR ───────────────────────────────────────────────── %>
  <aside class="lesson-sidebar" aria-label="Course content">

    <div class="sb-header">
      <div class="sb-header__top">
        <span class="sb-header__label">Nội dung khóa học</span>
        <span class="sb-header__progress-badge"><%= course_progress %>%</span>
      </div>
      <div class="sb-header__bar-track">
        <div class="sb-header__bar-fill" style="width:<%= course_progress %>%;"></div>
      </div>
    </div>

    <div class="sb-body" id="sidebarAccordion">

      <% @lesson.course.course_modules.order(:order_index).each do |mod| %>
        <%
          mod_is_open = mod.lessons.include?(@lesson)
          collapse_id = "sbmod_#{mod.id}"
        %>
        <div class="sb-module accordion-item">
          <h2 class="accordion-header" id="sbhdr_<%= mod.id %>">
            <button class="sb-module__toggle accordion-button <%= 'collapsed' unless mod_is_open %>"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#<%= collapse_id %>"
                    aria-expanded="<%= mod_is_open ? 'true' : 'false' %>"
                    aria-controls="<%= collapse_id %>">
              <span class="sb-module__title"><%= mod.title %></span>
              <i class="bi bi-chevron-down sb-module__chevron"></i>
            </button>
          </h2>

          <div id="<%= collapse_id %>"
               class="sb-module__collapse accordion-collapse collapse <%= 'show' if mod_is_open %>">
            <ul class="sb-module__lessons">
              <% mod.lessons.order(:order_index).each do |l| %>
                <% is_active    = (l == @lesson) %>
                <% is_completed = user_signed_in? && current_user.lesson_completed?(l) %>
                <li>
                  <%= link_to lesson_path(l),
                        class: "sb-lesson #{is_active ? 'sb-lesson--active' : ''}" do %>
                    <div class="sb-lesson__inner">
                      <div class="sb-lesson__left">
                        <i class="bi <%= l.video_url.present? ? 'bi-play-circle' : 'bi-file-text' %> sb-lesson__icon"></i>
                        <span class="sb-lesson__title"><%= l.title %></span>
                      </div>
                      <% if is_completed %>
                        <i class="bi bi-check-circle-fill sb-lesson__check"></i>
                      <% end %>
                    </div>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>

      <%# Big / course-level quizzes (only if signed in) %>
      <% if user_signed_in? && @big_quizzes.any? %>
        <% @big_quizzes.each do |quiz| %>
          <div class="sb-quiz-item accordion-item">
            <h2 class="accordion-header">
              <button class="sb-quiz-item__toggle accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#sb_quiz_<%= quiz.id %>"
                      aria-expanded="false">
                <i class="bi bi-trophy-fill sb-quiz-item__icon"></i>
                <%= quiz.title %>
              </button>
            </h2>
            <div id="sb_quiz_<%= quiz.id %>" class="accordion-collapse collapse">
              <div class="sb-quiz-item__body">
                <p class="sb-quiz-item__meta">
                  <%= quiz.total_questions %> câu hỏi • Đạt: <%= quiz.pass_score %>%
                </p>
                <% if current_user.quiz_completed?(quiz) %>
                  <div class="sb-quiz-item__btn sb-quiz-item__btn--done">
                    <i class="bi bi-check-circle-fill"></i> Đã hoàn thành
                  </div>
                <% else %>
                  <div class="sb-quiz-item__btn sb-quiz-item__btn--start">
                    <%= button_to "Làm bài ngay", quiz_quiz_attempts_path(quiz), method: :post %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>

    </div><%# /sb-body %>
  </aside>

</div><%# /lesson-page %>
