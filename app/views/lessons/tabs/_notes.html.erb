<article class="lesson-tabs__notes">
  <% if user_signed_in? %>
    <%
      lesson_notes = current_user.notes.where(lesson: @lesson).recent
      notes_count = lesson_notes.count
    %>

    <%# Note creation form %>
    <%= render "notes/form", lesson: @lesson, note: Note.new %>

    <%# Saved notes list %>
    <section class="lesson-tabs__saved-notes" aria-label="Saved notes">
      <div class="lesson-tabs__resources-header">
        <h3 class="lesson-tabs__subheading">
          Your notes
          <%= render "notes/count_badge", count: notes_count %>
        </h3>
      </div>

      <div id="notes-list">
        <% if lesson_notes.any? %>
          <% lesson_notes.each do |note| %>
            <%= render "notes/note", note: note %>
          <% end %>
        <% else %>
          <%= render "notes/empty_state" %>
        <% end %>
      </div>
    </section>

  <% else %>
    <section class="lesson-tabs__coming" aria-label="Notes require sign in">
      <span class="lesson-tabs__coming-icon" aria-hidden="true">
        <i class="bi bi-journal-text" style="font-size: 1.4rem;"></i>
      </span>
      <div class="lesson-tabs__coming-content">
        <h3 class="lesson-tabs__coming-title">Sign in to use Notes</h3>
        <p class="lesson-tabs__coming-subtitle">
          Personal notes are available to signed-in learners only.
        </p>
      </div>
    </section>
  <% end %>
</article>
