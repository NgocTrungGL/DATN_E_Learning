<div class="mt-5 pt-5 border-top" id="discussion-section">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center">
      <h4 class="fw-bold mb-0 text-dark">
        <i class="bi bi-chat-dots-fill text-primary me-2"></i>Q&A & Discussion
      </h4>
      <span class="badge bg-secondary ms-2 rounded-pill"><%= @lesson.comments.count %></span>
    </div>

    <button type="button" class="btn btn-primary fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#questionModal">
      <i class="bi bi-plus-lg me-1"></i> Ask a new question
    </button>
  </div>

  <%= render "comment_modal" %>

  <div class="comments-list mt-4">
    <% @lesson.comments.where(parent_id: nil).order(created_at: :desc).each do |comment| %>

      <div class="d-flex mb-4 p-3 rounded-3 bg-white border shadow-sm hover-shadow transition-base" id="comment-<%= comment.id %>">
        <div class="flex-shrink-0 me-3">
            <img src="https://ui-avatars.com/api/?name=<%= comment.user.name %>&background=random" class="rounded-circle shadow-sm avatar" width="48" height="48" alt="<%= comment.user.name %>">
          </div>

        <div class="flex-grow-1">
          <div class="d-flex align-items-center justify-content-between mb-1">
            <div>
              <span class="fw-bold text-dark me-2"><%= comment.user.name %></span>
              <% if comment.user == @lesson.course.creator %>
                <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill me-2" style="font-size: 0.7em">Instructor</span>
              <% end %>
              <small class="text-muted" style="font-size: 0.85rem"><%= time_ago_in_words(comment.created_at) %> ago</small>
            </div>

<% if can?(:destroy, comment) %>
              <div class="dropdown">
                <button class="btn btn-link text-muted p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="bi bi-three-dots-vertical"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                  <li>
                    <%= link_to lesson_comment_path(@lesson, comment),
                        data: { turbo_method: :delete, turbo_confirm: "Delete this comment?" },
                        class: "dropdown-item text-danger small" do %>
                      <i class="bi bi-trash me-2"></i> Delete comment
                    <% end %>
                  </li>
                </ul>
              </div>
            <% end %>
          </div>

          <p class="mb-2 text-secondary text-break"><%= simple_format(comment.body, {}, wrapper_tag: "span") %></p>

          <button class="btn btn-sm btn-light text-primary fw-bold rounded-pill px-3" type="button" data-bs-toggle="collapse" data-bs-target="#replyForm<%= comment.id %>">
            <i class="bi bi-reply-fill me-1"></i> Reply
          </button>

          <% if comment.replies.any? %>
            <div class="mt-3 ps-3 border-start border-2">
              <% comment.replies.order(:created_at).each do |reply| %>
                <div class="d-flex mt-3" id="comment-<%= reply.id %>">
                  <div class="flex-shrink-0 me-2">
                    <img src="https://ui-avatars.com/api/?name=<%= reply.user.name %>&background=random" class="rounded-circle avatar-sm" width="32" height="32" alt="<%= reply.user.name %>">
                  </div>
                  <div class="flex-grow-1 bg-light p-3 rounded-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                      <div>
                        <span class="fw-bold small text-dark"><%= reply.user.name %></span>
                        <% if reply.user == @lesson.course.creator %>
                          <span class="badge bg-info text-dark ms-1" style="font-size: 0.6em">Author</span>
                        <% end %>
                      </div>
                      <div class="d-flex align-items-center">
                        <small class="text-muted me-2" style="font-size: 0.75rem"><%= time_ago_in_words(reply.created_at) %></small>
                        <% if can?(:destroy, reply) %>
                          <%= link_to lesson_comment_path(@lesson, reply),
                              data: { turbo_method: :delete, turbo_confirm: "Delete this reply?" },
                              class: "text-secondary small text-decoration-none hover-text-danger" do %>
                            <i class="bi bi-x-lg"></i>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                    <p class="mb-0 small text-secondary text-break"><%= reply.body %></p>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>

          <div class="collapse mt-3" id="replyForm<%= comment.id %>">
            <div class="card card-body bg-light border-0 p-3">
              <%= form_with(model: [@lesson, Comment.new], local: true) do |f| %>
                <%= f.hidden_field :parent_id, value: comment.id %>
                <div class="d-flex align-items-start">
                   <img src="https://ui-avatars.com/api/?name=<%= current_user&.name %>&background=random" class="rounded-circle me-2 avatar-sm" width="32" height="32" alt="<%= current_user&.name %>">
                   <div class="flex-grow-1">
                     <%= f.text_area :body, class: "form-control form-control-sm mb-2 border-0 shadow-sm", placeholder: "Write your reply...", rows: 2, style: "resize: none;" %>
                     <div class="text-end">
                        <%= f.submit "Submit reply", class: "btn btn-sm btn-primary fw-bold" %>
                     </div>
                   </div>
                </div>
              <% end %>
            </div>
          </div>

        </div>
      </div>
    <% end %>

    <% if @lesson.comments.empty? %>
      <div class="text-center py-5 bg-light rounded-3 mt-4 border border-dashed">
        <div class="mb-3">
          <i class="bi bi-chat-square-quote text-muted opacity-25" style="font-size: 3rem;"></i>
        </div>
        <h5 class="text-muted fw-normal">No discussions yet</h5>
        <p class="text-muted small mb-3">Be the first to ask a question for this lesson!</p>
        <button type="button" class="btn btn-outline-primary btn-sm fw-bold" data-bs-toggle="modal" data-bs-target="#questionModal">
          Ask a question
        </button>
      </div>
    <% end %>
  </div>
</div>
