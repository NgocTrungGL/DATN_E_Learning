<div class="container-fluid py-4">
  <h2 class="h3 fw-bold text-gray-800 mb-4 border-start border-4 border-success ps-3">Doanh thu & Tài chính</h2>

  <div class="row mb-4">
    <div class="col-xl-4 col-md-6">
      <div class="card bg-success text-white shadow h-100 py-2">
        <div class="card-body">
          <div class="row no-gutters align-items-center">
            <div class="col mr-2">
              <div class="text-xs fw-bold text-uppercase mb-1 opacity-75">Số dư khả dụng</div>
              <div class="h1 mb-0 fw-bold">
                <%= number_to_currency(@wallet.balance, unit: "₫", precision: 0, format: "%n %u") %>
              </div>
            </div>
            <div class="col-auto">
              <i class="bi bi-wallet2 fs-1 opacity-50"></i>
            </div>
          </div>
          <div class="mt-3">
             <button class="btn btn-light text-success fw-bold btn-sm shadow-sm">
               <i class="bi bi-bank me-1"></i> Yêu cầu rút tiền
             </button>
             <small class="d-block mt-2 opacity-75 fst-italic">* Chức năng rút tiền đang phát triển</small>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-4 col-md-6">
      <div class="card border-0 shadow-sm h-100 py-2 border-start border-4 border-primary">
        <div class="card-body">
          <div class="text-xs fw-bold text-primary text-uppercase mb-1">Tổng thu nhập (Trọn đời)</div>
          <div class="h3 mb-0 fw-bold text-gray-800">
            <% total_earned = @wallet.wallet_transactions.where(transaction_type: 'sale_commission').sum(:amount) %>
            <%= number_to_currency(total_earned, unit: "₫", precision: 0, format: "%n %u") %>
          </div>
          <p class="text-muted small mt-2 mb-0">Tổng số tiền hoa hồng bán khóa học bạn đã nhận được từ trước đến nay.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow border-0">
    <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
      <h6 class="m-0 fw-bold text-primary">Lịch sử biến động số dư</h6>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="bg-light">
            <tr>
              <th class="ps-4">Mã GD</th>
              <th>Loại giao dịch</th>
              <th>Số tiền</th>
              <th>Nội dung chi tiết</th>
              <th>Thời gian</th>
            </tr>
          </thead>
          <tbody>
            <% @transactions.each do |txn| %>
              <tr>
                <td class="ps-4 font-monospace text-muted small">#<%= txn.id %></td>

                <td>
                  <% case txn.transaction_type %>
                  <% when 'sale_commission' %>
                    <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">
                      <i class="bi bi-graph-up-arrow me-1"></i> Hoa hồng
                    </span>
                  <% when 'withdrawal' %>
                    <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill">
                      <i class="bi bi-arrow-down me-1"></i> Rút tiền
                    </span>
                  <% else %>
                    <span class="badge bg-secondary"><%= txn.transaction_type %></span>
                  <% end %>
                </td>

                <td class="fw-bold fs-5 <%= txn.amount >= 0 ? 'text-success' : 'text-danger' %>">
                  <%= txn.amount >= 0 ? "+" : "" %><%= number_to_currency(txn.amount, unit: "₫", precision: 0, format: "%n %u") %>
                </td>

                <td>
                  <% if txn.source.is_a?(Enrollment) %>
                    <div>Bán khóa học: <strong><%= txn.source.course.title %></strong></div>
                    <small class="text-muted">Học viên: <%= txn.source.user.name %></small>
                  <% elsif txn.transaction_type == 'withdrawal' %>
                    <div>Rút về ngân hàng</div>
                  <% end %>
                </td>

                <td class="text-muted small">
                  <%= txn.created_at.strftime("%d/%m/%Y %H:%M") %>
                </td>
              </tr>
            <% end %>

            <% if @transactions.empty? %>
              <tr>
                <td colspan="5" class="text-center py-5 text-muted">
                  <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                  Chưa có giao dịch nào.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-4 d-flex justify-content-center">
      <%== pagy_bootstrap_nav(@pagy) %>
    </div>
  <% end %>
</div>
