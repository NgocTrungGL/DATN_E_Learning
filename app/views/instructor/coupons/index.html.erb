<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-1 text-dark">Mã giảm giá của tôi</h2>
      <p class="text-muted small mb-0">Tạo mã ưu đãi dành riêng cho học viên của bạn.</p>
    </div>
    <%= link_to new_instructor_coupon_path, class: "btn btn-primary fw-bold px-4 py-2" do %>
      <i class="bi bi-plus-lg me-2"></i> Tạo mã mới
    <% end %>
  </div>

  <div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="px-4 py-3 border-0">Mã Code</th>
            <th class="py-3 border-0">Giá trị</th>
            <th class="py-3 border-0">Khóa học áp dụng</th>
            <th class="py-3 border-0">Thời gian</th>
            <th class="py-3 border-0">Trạng thái</th>
            <th class="px-4 py-3 border-0 text-end">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% if @coupons.any? %>
            <% @coupons.each do |coupon| %>
              <tr>
                <td class="px-4 py-3">
                  <div class="d-flex align-items-center">
                    <div class="coupon-code-badge bg-primary-subtle text-primary fw-bold px-2 py-1 rounded">
                      <%= coupon.code %>
                    </div>
                  </div>
                </td>
                <td class="py-3">
                  <span class="fw-bold text-dark">
                    <%= coupon.percentage? ? "#{coupon.discount_value}%" : number_to_currency(coupon.discount_value, unit: "₫", precision: 0, format: "%n %u") %>
                  </span>
                </td>
                <td class="py-3">
                  <div class="text-truncate" style="max-width: 250px;">
                    <%= coupon.course&.title %>
                  </div>
                </td>
                <td class="py-3">
                  <div class="small text-muted"><%= coupon.start_at.strftime("%d/%m/%Y") %> - <%= coupon.end_at.strftime("%d/%m/%Y") %></div>
                </td>
                <td class="py-3">
                  <% if coupon.active? && coupon.active_and_current? %>
                    <span class="badge rounded-pill bg-success px-3">Đang chạy</span>
                  <% elsif coupon.inactive? %>
                    <span class="badge rounded-pill bg-secondary px-3">Đã tắt</span>
                  <% elsif coupon.expired? %>
                    <span class="badge rounded-pill bg-danger px-3">Hết hạn</span>
                  <% else %>
                    <span class="badge rounded-pill bg-info px-3">Lên lịch</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-end">
                  <div class="btn-group">
                    <%= link_to edit_instructor_coupon_path(coupon), class: "btn btn-sm btn-outline-primary" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <%= link_to instructor_coupon_path(coupon), data: { turbo_method: :delete, turbo_confirm: "Xóa mã này?" }, class: "btn btn-sm btn-outline-danger" do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="text-center py-5">
                <div class="text-muted opacity-50 mb-3">
                  <i class="bi bi-ticket-perforated display-1"></i>
                </div>
                <h5 class="text-muted">Bạn chưa tạo mã giảm giá nào.</h5>
                <p class="text-muted small">Hãy tạo mã đầu tiên để tăng doanh số bán hàng!</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
