<div class="d-flex justify-content-between align-items-center mb-4">
  <h3>Học viên khóa: <%= @course.title %></h3>
  <%= link_to "Quay lại", instructor_course_path(@course), class: "btn btn-outline-secondary" %>
</div>

<div class="card shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Học viên</th>
          <th>Email</th>
          <th>Ngày tham gia</th>
          <th>Tiến độ</th>
        </tr>
      </thead>
      <tbody>
        <% @enrollments.each do |enrollment| %>
          <tr>
            <td>
              <div class="d-flex align-items-center">
                <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px;">
                  <%= enrollment.user.name[0].upcase %>
                </div>
                <span class="fw-bold"><%= enrollment.user.name %></span>
              </div>
            </td>
            <td><%= enrollment.user.email %></td>
            <td><%= enrollment.created_at.strftime("%d/%m/%Y") %></td>
            <td>
              <% progress = enrollment.user.course_progress_percentage(@course) %>
              <div class="d-flex align-items-center">
                <div class="progress flex-grow-1 me-2" style="height: 6px;">
                  <div class="progress-bar bg-success" style="width: <%= progress %>%"></div>
                </div>
                <span class="small text-muted"><%= progress %>%</span>
              </div>
            </td>
          </tr>
        <% end %>

        <% if @enrollments.empty? %>
          <tr><td colspan="4" class="text-center text-muted py-4">Chưa có học viên nào.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
