<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold"><i class="bi bi-collection-play me-2"></i> Khóa học của tôi</h2>
  <%= link_to new_instructor_course_path, class: "btn btn-primary" do %>
    <i class="bi bi-plus-circle"></i> Tạo khóa học mới
  <% end %>
</div>
<% if @courses.any? %>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% @courses.each do |course| %>
      <div class="col">
        <div class="card h-100 shadow-sm border-0">
          <div class="position-relative">
            <img src="<%= course.thumbnail_url.presence || 'https://via.placeholder.com/400x225' %>"
                 class="card-img-top" style="height: 200px; object-fit: cover;">
            <span class="badge bg-primary position-absolute top-0 start-0 m-2">
              <%= course.category&.name || "Chưa phân loại" %>
            </span>
          </div>
          <div class="card-body d-flex flex-column">
            <h5 class="card-title fw-bold text-truncate"><%= course.title %></h5>
            <p class="card-text text-muted small text-truncate-2-lines">
              <%= truncate(course.description, length: 100) %>
            </p>
            <div class="mt-auto">
              <hr>
              <div class="d-flex justify-content-between align-items-center">
                <%= link_to instructor_course_path(course), class: "btn btn-sm btn-outline-primary fw-bold" do %>
                  <i class="bi bi-gear"></i> Quản lý nội dung
                <% end %>
                <div class="dropdown">
                  <button class="btn btn-sm btn-light" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-three-dots-vertical"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                      <%= link_to edit_instructor_course_path(course), class: "dropdown-item" do %>
                        <i class="bi bi-pencil me-2"></i> Chỉnh sửa thông tin
                      <% end %>
                    </li>
                    <li>
                      <%= link_to students_instructor_course_path(course), class: "dropdown-item" do %>
                        <i class="bi bi-people me-2"></i> Xem học viên
                      <% end %>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                      <%= button_to instructor_course_path(course), method: :delete, class: "dropdown-item text-danger", data: { confirm: "Bạn chắc chắn muốn xóa khóa học này?" } do %>
                        <i class="bi bi-trash me-2"></i> Xóa khóa học
                      <% end %>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
          <div class="card-footer bg-light d-flex justify-content-between small text-muted">
            <span><i class="bi bi-book"></i> <%= course.course_modules.count %> Chương</span>
            <span><i class="bi bi-cash"></i> <%= number_to_currency(course.price, unit: '₫', precision: 0, format: "%n %u") %></span>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-5 bg-light rounded border border-dashed">
    <i class="bi bi-journal-plus display-1 text-muted mb-3"></i>
    <h4 class="text-muted">Bạn chưa có khóa học nào.</h4>
    <p class="mb-4">Hãy bắt đầu chia sẻ kiến thức của bạn ngay hôm nay!</p>
    <%= link_to "Tạo khóa học đầu tiên", new_instructor_course_path, class: "btn btn-lg btn-primary" %>
  </div>
<% end %>
<% if @pagy.pages > 1 %>
  <div class="d-flex justify-content-center mt-4">
    <%== pagy_bootstrap_nav(@pagy) %>
  </div>

  <div class="text-center text-muted small mt-2">
    Hiển thị <b><%= @pagy.items %></b> khóa học / trang
    (Tổng <b><%= @pagy.count %></b> khóa học)
  </div>
<% end %>
