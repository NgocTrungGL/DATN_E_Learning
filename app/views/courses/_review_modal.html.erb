<div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="reviewModalLabel">
          <i class="bi bi-pencil-square me-2 text-primary"></i>Course review
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body">
        <%= form_with(model: [course, Review.new], local: true) do |f| %>

          <div class="mb-3 text-center">
            <label class="form-label fw-bold mb-2">How many stars?</label>

            <div class="rating-box d-flex justify-content-center">
              <% 5.downto(1) do |i| %>
                <%= f.radio_button :rating, i, id: "rating#{i}", class: "d-none rating-input" %>
                <label for="rating<%= i %>" class="bi bi-star-fill fs-1 mx-1 rating-label" title="<%= i %> stars"></label>
              <% end %>
            </div>

            <style>
              .rating-box { flex-direction: row-reverse; }
              .rating-label { color: #ddd; cursor: pointer; transition: color 0.2s; }
              .rating-label:hover, .rating-label:hover ~ .rating-label { color: #ffc107 !important; }
              .rating-input:checked ~ .rating-label { color: #ffc107; }
            </style>
          </div>

          <div class="mb-4">
            <%= f.label :content, "Your feedback", class: "form-label fw-bold" %>
            <%= f.text_area :content, class: "form-control bg-light", rows: 4, placeholder: "Share your honest thoughts...", required: true %>
          </div>

          <div class="d-grid gap-2">
            <%= f.button type: "submit", class: "btn btn-primary fw-bold" do %>
              <i class="bi bi-send-fill me-2"></i> Submit review
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
