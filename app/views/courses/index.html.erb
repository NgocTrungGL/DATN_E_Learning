<%# ============================================================ %>
<%# COURSES INDEX PAGE                                          %>
<%# Full-width layout (no container from application.html.erb)  %>
<%# ============================================================ %>
<% content_for :full_width, true %>

<%# ============================================================ %>
<%# SECTION 1: PAGE HEADER                                      %>
<%# ============================================================ %>
<div class="courses-page-header">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-7">
        <div class="page-header-badge">📚 Course Catalog</div>
        <h1>Explore Our Courses</h1>
        <p>Browse <%= @courses.size %> expert-crafted courses and start building in-demand skills today.</p>
        <div class="header-stats">
          <div class="header-stat">
            <i class="bi bi-play-btn-fill"></i>
            <strong><%= @courses.size %>+</strong> Courses Available
          </div>
          <div class="header-stat">
            <i class="bi bi-people-fill"></i>
            <strong>10,000+</strong> Active Students
          </div>
          <div class="header-stat">
            <i class="bi bi-award-fill"></i>
            <strong>Certificate</strong> on Completion
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# ============================================================ %>
<%# SECTION 2: FILTER & SEARCH BAR (Frontend UI — connect to    %>
<%# backend later by adding params to the courses controller)   %>
<%# ============================================================ %>
<div class="courses-filter-bar">
  <div class="container">
    <%# Wrap in a form so filters can be wired to the backend later %>
    <%# FUTURE: Add params[:query], params[:category_id], params[:price_filter], params[:min_rating] to controller %>
    <%= form_with url: courses_path, method: :get, local: true, class: "d-flex align-items-center gap-3 flex-wrap" do |f| %>

      <%# Search input — FUTURE: wire to Course.where("title ILIKE ?", "%#{params[:query]}%") %>
      <div class="filter-search">
        <i class="bi bi-search"></i>
        <%= f.search_field :query,
              value: params[:query],
              placeholder: "Search courses...",
              class: "" %>
      </div>

      <%# Category filter — FUTURE: replace hardcoded options with Category.all %>
      <%= f.select :category_id,
            options_for_select(
              [["All Categories", ""]] +
              # FUTURE: replace below with Category.all.map { |c| [c.name, c.id] }
              [
                ["Web Development", "web"],
                ["Data Science", "data"],
                ["Design & UI/UX", "design"],
                ["DevOps & Cloud", "devops"],
                ["Mobile Development", "mobile"]
              ],
              params[:category_id]
            ),
            {},
            class: "filter-select" %>

      <%# Price filter — FUTURE: add to controller: @courses = @courses.free if params[:price] == "free" %>
      <%= f.select :price_filter,
            options_for_select(
              [["Any Price", ""], ["Free", "free"], ["Paid", "paid"]],
              params[:price_filter]
            ),
            {},
            class: "filter-select" %>

      <%# Rating filter — FUTURE: add to controller: @courses = @courses.where("avg_rating >= ?", ...) %>
      <%= f.select :min_rating,
            options_for_select(
              [["Any Rating", ""], ["4.5+", "4.5"], ["4.0+", "4.0"], ["3.5+", "3.5"]],
              params[:min_rating]
            ),
            {},
            class: "filter-select d-none d-md-block" %>

      <button type="submit" class="filter-btn-active">
        <i class="bi bi-funnel-fill"></i> Apply
      </button>

      <% if params[:query].present? || params[:category_id].present? || params[:price_filter].present? %>
        <%= link_to courses_path, class: "btn btn-link text-muted text-decoration-none small fw-semibold p-0" do %>
          <i class="bi bi-x-circle"></i> Clear
        <% end %>
      <% end %>

      <span class="results-count ms-auto d-none d-md-block">
        Showing <strong><%= @courses.size %></strong> courses
      </span>
    <% end %>
  </div>
</div>

<%# ============================================================ %>
<%# SECTION 3: COURSES GRID                                     %>
<%# ============================================================ %>
<section class="courses-grid-section">
  <div class="container">

    <% if @courses.any? %>
      <%# Responsive grid: 1 col mobile, 2 col tablet, 3 col lg, 4 col xl %>
      <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
        <% @courses.each do |course| %>
          <div class="col">
            <%= render 'courses/course_card', course: course %>
          </div>
        <% end %>
      </div>

    <% else %>
      <%# --- Empty State --- %>
      <div class="courses-empty-state">
        <div class="empty-icon"><i class="bi bi-search"></i></div>
        <h3>No courses found</h3>
        <p>Try adjusting your search or filters to find what you're looking for.</p>
        <%= link_to "Clear Filters", courses_path, class: "btn btn-primary px-5" %>
      </div>
    <% end %>

    <%# ============================================================ %>
    <%# PAGINATION                                                  %>
    <%# FUTURE: Install kaminari or pagy gem and replace @courses   %>
    <%# with @courses.page(params[:page]).per(12) in the controller %>
    <%# Then render pagination here                                 %>
    <%# ============================================================ %>
    <%# Example with kaminari: %>
    <%# <div class="courses-pagination"> %>
    <%#   <%= paginate @courses %> %>
    <%# </div> %>

  </div>
</section>
