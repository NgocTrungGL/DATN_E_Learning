<% unless current_user %>
  <div class="bg-light py-5 mb-5">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-6">
          <h1 class="display-5 fw-bold mb-3">Học không giới hạn</h1>
          <p class="lead mb-4">Nâng cao kỹ năng với các khóa học online chất lượng cao.</p>
        </div>
        <div class="col-md-6 text-end d-none d-md-block">
          <img src="https://img.freepik.com/free-vector/online-learning-isometric-concept_1284-17947.jpg" class="img-fluid" style="max-height: 300px;">
        </div>
      </div>
    </div>
  </div>
<% else %>
  <div class="mt-4"></div>
<% end %>

<div class="container mb-5">
  <h3 class="fw-bold mb-4">Hãy bắt đầu học nào</h3>

  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
    <% @courses.each do |course| %>
      <div class="col">
        <div class="card h-100 border-0 shadow-hover course-card position-relative">

          <%# 1. LINK HÌNH ẢNH %>
          <%= link_to course_path(course), class: "text-decoration-none" do %>
            <img src="<%= course.thumbnail_url.presence || 'https://via.placeholder.com/400x225' %>"
                 class="card-img-top border-bottom" style="height: 160px; object-fit: cover;">
          <% end %>

          <div class="card-body p-2 d-flex flex-column">

            <%# 2. LINK TIÊU ĐỀ %>
            <%= link_to course_path(course), class: "text-decoration-none text-dark" do %>
              <h6 class="card-title fw-bold mb-1 text-truncate-2-lines" style="height: 2.5em; overflow: hidden;">
                <%= course.title %>
              </h6>
            <% end %>

            <small class="text-muted d-block mb-2"><%= course.creator&.name || "Admin" %></small>

            <%# --- RATING & STUDENTS --- %>
            <div class="mb-2 d-flex align-items-center flex-wrap small">
              <% if course.reviews.present? && course.reviews.any? %>
                <% avg_rating = course.reviews.average(:rating).to_f; review_count = course.reviews.count %>
                <span class="text-warning fw-bold me-1"><%= avg_rating.round(1) %></span>
                <span class="d-flex me-1">
                  <% 5.times do |i| %>
                    <% if i < avg_rating.floor %>
                      <i class="bi bi-star-fill text-warning" style="font-size: 0.7rem;"></i>
                    <% elsif (i == avg_rating.floor) && (avg_rating % 1 >= 0.5) %>
                      <i class="bi bi-star-half text-warning" style="font-size: 0.7rem;"></i>
                    <% else %>
                      <i class="bi bi-star text-warning" style="font-size: 0.7rem;"></i>
                    <% end %>
                  <% end %>
                </span>
                <span class="text-muted me-2">(<%= review_count %>)</span>
              <% else %>
                <span class="text-muted fst-italic me-2" style="font-size: 0.8rem;">Chưa có đánh giá</span>
              <% end %>

              <% if course.total_students > 0 %>
                <span class="text-muted me-2">•</span>
                <span class="text-muted" title="<%= course.total_students %> học viên">
                  <i class="bi bi-people-fill text-secondary" style="font-size: 0.8rem;"></i>
                  <%= number_to_human(course.total_students, format: "%n%u", units: { thousand: "k", million: "M" }) %>
                </span>
              <% end %>
            </div>

            <%# --- PHẦN GIÁ & NÚT CART (Đẩy xuống đáy bằng mt-auto) --- %>
            <div class="mt-auto d-flex justify-content-between align-items-center pt-2 border-top">

              <%# GIÁ TIỀN %>
              <div class="fw-bold fs-5">
                <% if course.free? %>
                  <span class="text-success">Miễn phí</span>
                <% else %>
                  <%= number_to_currency(course.price, unit: "₫", format: "%n %u", precision: 0) %>
                <% end %>
              </div>

              <%# NÚT ADD TO CART %>
              <%# Chỉ hiện nút Cart nếu User đã đăng nhập VÀ khóa học không miễn phí %>
              <% if current_user && !course.free? %>

                <%# Kiểm tra xem đã có trong giỏ chưa %>
                <% if current_user.cart&.courses&.include?(course) %>

                  <%= link_to cart_path, class: "btn btn-outline-success btn-sm rounded-circle shadow-sm", title: "Đã trong giỏ hàng" do %>
                    <i class="bi bi-check-lg"></i>
                  <% end %>

                <% else %>

                  <%# Nút thêm vào giỏ (Dùng link_to turbo để tránh lỗi style form trắng) %>
                  <%= link_to cart_items_path(course_id: course.id),
                        data: { turbo_method: :post },
                        class: "btn btn-outline-primary btn-sm rounded-circle shadow-sm",
                        title: "Thêm vào giỏ" do %>
                    <i class="bi bi-cart-plus"></i>
                  <% end %>

                <% end %>

              <% end %>
            </div>

          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .shadow-hover { transition: box-shadow 0.2s, transform 0.2s; }
  .shadow-hover:hover {
    box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    transform: translateY(-2px);
  }
  .text-truncate-2-lines {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .bi-star-fill, .bi-star-half, .bi-star { line-height: 1; }

  /* Style cho nút tròn */
  .btn-outline-primary.rounded-circle,
  .btn-outline-success.rounded-circle {
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
</style>
