<% unless current_user %>
  <div class="bg-light py-5 mb-5">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-6">
          <h1 class="display-5 fw-bold mb-3">Học không giới hạn</h1>
          <p class="lead mb-4">Nâng cao kỹ năng với các khóa học online chất lượng cao.</p>
        </div>
        <div class="col-md-6 text-end d-none d-md-block">
          <img src="https://img.freepik.com/free-vector/online-learning-isometric-concept_1284-17947.jpg" class="img-fluid" style="max-height: 300px;">
        </div>
      </div>
    </div>
  </div>
<% else %>
  <div class="mt-4"></div>
<% end %>

<div class="container mb-5">
  <h3 class="fw-bold mb-4">Hãy bắt đầu học nào</h3>

  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
    <% @courses.each do |course| %>
      <div class="col">
        <div class="card h-100 border-0 shadow-hover course-card">
          <%= link_to course_path(course), class: "text-decoration-none text-dark" do %>
            <img src="<%= course.thumbnail_url.presence || 'https://via.placeholder.com/400x225' %>"
                 class="card-img-top border-bottom" style="height: 160px; object-fit: cover;">

            <div class="card-body p-2">
              <h6 class="card-title fw-bold mb-1 text-truncate-2-lines" style="height: 2.5em; overflow: hidden;">
                <%= course.title %>
              </h6>

              <small class="text-muted d-block mb-1"><%= course.creator&.name %></small>

              <div class="mb-1">
                <span class="text-warning fw-bold small">4.5</span>
                <i class="bi bi-star-fill text-warning small"></i>
                <i class="bi bi-star-fill text-warning small"></i>
                <i class="bi bi-star-fill text-warning small"></i>
                <i class="bi bi-star-fill text-warning small"></i>
                <i class="bi bi-star-half text-warning small"></i>
                <span class="text-muted small">(123)</span>
              </div>

              <div class="fw-bold">
                <% if course.free? %>
                  Miễn phí
                <% else %>
                  <%= number_to_currency(course.price, unit: "₫", format: "%n %u", precision: 0) %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .shadow-hover { transition: box-shadow 0.2s; }
  .shadow-hover:hover { box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important; }
  .text-truncate-2-lines {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
