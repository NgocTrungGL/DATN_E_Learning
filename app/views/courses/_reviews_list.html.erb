<% colors = ["#FF6B6B", "#4ECDC4", "#5D9CEC", "#A55EEA", "#FFA502", "#2ED573", "#1E90FF", "#FF4757", "#3742FA", "#00B894"] %>

<div class="reviews-container">

  <% if reviews.any? %>
    <% reviews.each do |review| %>

      <div class="review-item pb-4 mb-4 border-bottom">

        <!-- AVATAR + NAME + RATING -->
        <div class="d-flex align-items-start justify-content-between">

          <div class="d-flex">
            <!-- Avatar với màu Random -->
            <div class="rounded-circle text-white d-flex align-items-center justify-content-center me-3 fw-bold"
                 style="width:48px;height:48px;font-size:18px;background:<%= colors.sample %>;">
              <%= review.user.name.first.upcase %>
            </div>

            <div>
              <div class="fw-bold text-dark mb-1" style="font-size:17px;">
                <%= review.user.name %>
              </div>

              <div class="d-flex align-items-center text-muted" style="font-size:14px;">
                <div class="me-2 text-warning">
                  <% review.rating.times { %><i class="bi bi-star-fill"></i><% } %>
                  <% (5-review.rating).times { %><i class="bi bi-star text-muted"></i><% } %>
                </div>
                <span><%= time_ago_in_words(review.created_at) %> trước</span>
              </div>
            </div>
          </div>

          <i class="bi bi-three-dots-vertical text-muted" style="cursor:pointer;"></i>
        </div>

        <!-- Content -->
        <div class="mt-3 text-dark" style="font-size:15px; line-height:1.7;">
          <%= review.content %>
        </div>

      </div>

    <% end %>

  <% else %>
    <div class="text-center text-muted py-5">
      <i class="bi bi-chat-square-text fs-1 mb-3 d-block"></i>
      <p class="mb-0">Chưa có đánh giá nào — Hãy là người đầu tiên!</p>
    </div>
  <% end %>

</div>
