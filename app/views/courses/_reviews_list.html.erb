<div class="list-group list-group-flush">
  <% reviews.each do |review| %>
    <div class="list-group-item px-0 py-3">
      <div class="d-flex w-100 justify-content-between">
        <div class="d-flex align-items-center mb-2">
          <div class="avatar-wrapper avatar-sm me-2">
            <% if review.user.avatar_url.present? %>
               <img src="<%= review.user.avatar_url %>" class="avatar-img rounded-circle">
            <% else %>
               <div class="avatar-text avatar-sm-text rounded-circle bg-secondary text-white">
                 <%= review.user.name.first.upcase %>
               </div>
            <% end %>
          </div>

          <div>
             <h6 class="mb-0 fw-bold fs-6"><%= review.user.name %></h6>
             <small class="text-muted"><%= time_ago_in_words(review.created_at) %> ago</small>
          </div>
        </div>

        <% if current_user && (current_user.admin? || current_user == review.user) %>
          <%= button_to course_review_path(review.course, review),
              method: :delete,
              class: "btn btn-link text-danger p-0 btn-sm text-decoration-none",
              data: { turbo_confirm: "Are you sure you want to delete this review?" } do %>
            <i class="bi bi-trash"></i> Delete
          <% end %>
        <% end %>

      </div>

      <div class="mb-2 text-warning small">
        <% review.rating.times do %>
          <i class="bi bi-star-fill"></i>
        <% end %>
        <% (5 - review.rating).times do %>
          <i class="bi bi-star"></i>
        <% end %>
      </div>

      <p class="mb-1 text-break"><%= review.content %></p>
    </div>
  <% end %>

  <% if reviews.empty? %>
    <div class="text-center py-4 text-muted">
      <i class="bi bi-chat-square-text fs-1 mb-2"></i>
      <p>No reviews yet.</p>
    </div>
  <% end %>
</div>
