<% colors = ["#FF6B6B", "#4ECDC4", "#5D9CEC", "#A55EEA", "#FFA502", "#2ED573", "#1E90FF", "#FF4757", "#3742FA", "#00B894"] %>

<div class="list-group list-group-flush">
  <% if reviews.any? %>
    <% reviews.each do |review| %>
      <div class="list-group-item px-0 py-3 border-bottom">
        <div class="d-flex w-100 justify-content-between align-items-start">

          <div class="d-flex align-items-center">
             <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 45px; height: 45px; font-weight: bold; font-size: 1.2rem;">
               <%= review.user.name[0].upcase %>
             </div>
             <div>
               <h6 class="mb-0 fw-bold"><%= review.user.name %></h6>
               <div class="text-warning small mb-1">
                 <% review.rating.times do %> <i class="bi bi-star-fill"></i> <% end %>
                 <% (5 - review.rating).times do %> <i class="bi bi-star text-muted opacity-25"></i> <% end %>
               </div>
               <small class="text-muted" style="font-size: 0.8rem;"><%= time_ago_in_words(review.created_at) %> trước</small>
             </div>
          </div>

          <% if can?(:destroy, review) %>
            <div class="dropdown">
              <button class="btn btn-link text-secondary p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                <li>
                  <%# Nút Xóa %>
                  <%= link_to course_review_path(review.course, review),
                      data: { turbo_method: :delete, turbo_confirm: "Bạn chắc chắn muốn xóa đánh giá này?" },
                      class: "dropdown-item text-danger small" do %>
                    <i class="bi bi-trash me-2"></i> Xóa đánh giá
                  <% end %>
                </li>
              </ul>
            </div>
          <% end %>

        </div>

        <div class="mt-3 ps-5 ms-2">
          <p class="mb-0 text-secondary" style="font-style: italic;">
            "<%= review.content %>"
          </p>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-5 text-muted">
      <div class="mb-3">
        <i class="bi bi-chat-square-heart display-4 opacity-25"></i>
      </div>
      <p>Chưa có đánh giá nào. Hãy là người đầu tiên!</p>
    </div>
  <% end %>
</div>
