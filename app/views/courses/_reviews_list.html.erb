<div class="list-group list-group-flush">
  <% if reviews.any? %>
    <% reviews.each do |review| %>
      <div class="list-group-item px-0 py-3">
        <div class="d-flex w-100 justify-content-between align-items-center">
          <div class="d-flex align-items-center">
             <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px; font-weight: bold;">
               <%= review.user.name[0].upcase %>
             </div>
             <div>
               <h6 class="mb-0 fw-bold"><%= review.user.name %></h6>
               <small class="text-muted"><%= time_ago_in_words(review.created_at) %> trước</small>
             </div>
          </div>

          <div class="text-warning">
            <% review.rating.times do %> <i class="bi bi-star-fill"></i> <% end %>
            <% (5 - review.rating).times do %> <i class="bi bi-star text-muted opacity-25"></i> <% end %>
          </div>
        </div>

        <p class="mt-2 mb-1 bg-light p-3 rounded fst-italic text-secondary">
          "<%= review.content %>"
        </p>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-chat-square-text fs-1 d-block mb-2"></i>
      <p>Chưa có đánh giá nào. Hãy là người đầu tiên!</p>
    </div>
  <% end %>
</div>
