<%# --- PHẦN 1: HEADER KHÓA HỌC (HERO SECTION) --- %>
<div class="bg-dark text-white py-5 mb-5">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-md-8">
        <span class="badge bg-warning text-dark mb-2">
          <%= @course.category&.name || "General" %>
        </span>

        <h1 class="display-4 fw-bold"><%= @course.title %></h1>
        <p class="lead"><%= @course.description %></p>

        <div class="mb-3 text-warning">
          <span class="fw-bold fs-5"><%= @course.reviews.average(:rating).to_f.round(1) %>/5</span>
          <i class="bi bi-star-fill"></i>
          <a href="#course-reviews" class="text-white-50 text-decoration-none ms-2 small">
            (<%= @course.reviews.count %> đánh giá)
          </a>
          <span class="text-white-50 mx-2">|</span>
          <span class="text-white fw-bold">
            <i class="bi bi-people-fill ms-1"></i>
            <%= @course.total_students %> học viên
          </span>
        </div>

        <div class="mt-4">
          <%# --- HIỂN THỊ GIÁ TIỀN --- %>
          <% unless @course.free? %>
             <div class="mb-3 d-flex align-items-center">
               <h2 class="text-warning fw-bold mb-0 me-3">
                 <%= number_to_currency(@course.price, unit: "₫", format: "%n %u", precision: 0) %>
               </h2>

               <% if current_user && (current_user.admin? || current_user == @course.creator) %>
                  <span class="badge bg-light text-secondary border opacity-75">Giá niêm yết</span>
               <% end %>
             </div>
          <% end %>

          <%# --- CÁC NÚT HÀNH ĐỘNG (ACTION BUTTONS) --- %>
          <% if current_user %>

            <%# A: ĐƯỢC PHÉP VÀO HỌC (Check Enrollment/License/Creator) %>
            <% if can? :access_content, @course %>

               <% first_lesson = @course.course_modules.first&.lessons&.first %>
               <% if first_lesson %>
                 <%= link_to lesson_path(first_lesson), class: "btn btn-success btn-lg px-4 me-2 shadow" do %>
                   <i class="bi bi-play-circle-fill"></i> Vào học ngay

                   <% if current_user.admin? %>
                     <span class="fs-6 fw-normal ms-1">(Admin)</span>
                   <% elsif current_user == @course.creator %>
                     <span class="fs-6 fw-normal ms-1">(Giảng viên)</span>
                   <% end %>
                 <% end %>
               <% else %>
                 <button class="btn btn-secondary btn-lg px-4 me-2" disabled>Nội dung đang cập nhật</button>
               <% end %>

            <% else %>

              <%# B: CHƯA ĐƯỢC HỌC -> MUA HOẶC ĐĂNG KÝ %>
              <% pending_enrollment = current_user.enrollments.find_by(course: @course, status: :pending) %>

              <% if pending_enrollment %>
                 <div class="d-flex align-items-center">
                   <button class="btn btn-warning btn-lg px-4 me-3 disabled text-dark fw-bold">
                     <i class="bi bi-clock-history"></i> Đang chờ thanh toán
                   </button>

                   <%= button_to create_checkout_session_path(course_id: @course.id), method: :post, class: "btn btn-outline-light btn-sm", data: { turbo: false } do %>
                      <i class="bi bi-credit-card"></i> Tiếp tục thanh toán
                   <% end %>
                 </div>
                 <p class="text-white-50 mt-2 small">
                   <i class="bi bi-info-circle"></i> Vui lòng hoàn tất thanh toán để vào học.
                 </p>

              <% else %>
                 <% if @course.free? %>
                    <%= button_to course_enrollments_path(@course), method: :post, class: "btn btn-primary btn-lg px-4 shadow" do %>
                      <i class="bi bi-person-plus-fill"></i> Đăng ký học miễn phí
                    <% end %>
                 <% else %>
                    <div class="d-flex gap-3 align-items-center">

                      <%# 1. NÚT MUA NGAY %>
                      <%= button_to create_checkout_session_path(course_id: @course.id),
                            method: :post,
                            class: "btn btn-primary btn-lg px-4 shadow border-0 bg-gradient",
                            style: "background-color: #635bff;",
                            data: { turbo: false } do %>
                        <i class="bi bi-credit-card-2-front-fill me-2"></i> Mua ngay
                      <% end %>

                      <%# 2. NÚT THÊM VÀO GIỎ HÀNG %>
                      <% if current_user.cart&.courses&.include?(@course) %>

                        <%= link_to cart_path, class: "btn btn-outline-light btn-lg px-4" do %>
                          <i class="bi bi-cart-check-fill me-2"></i> Đã trong giỏ
                        <% end %>

                      <% else %>

                        <%# Dùng link_to với turbo_method: :post để gửi request POST mà không cần thẻ form bao quanh %>
                        <%= link_to cart_items_path(course_id: @course.id),
                              data: { turbo_method: :post },
                              class: "btn btn-outline-light btn-lg px-4" do %>
                          <i class="bi bi-cart-plus me-2"></i> Thêm vào giỏ
                        <% end %>

                      <% end %>

                    </div>
                 <% end %>
              <% end %>

            <% end %>

          <% else %>
            <%# C: CHƯA ĐĂNG NHẬP %>
            <div class="d-flex align-items-center">
              <%= link_to new_user_session_path, class: "btn btn-outline-light btn-lg px-4" do %>
                Đăng nhập để học
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="col-md-4 d-none d-md-block">
        <img src="<%= @course.thumbnail_url.presence || 'https://via.placeholder.com/400x300' %>"
             class="img-fluid rounded shadow-lg border border-secondary"
             style="object-fit: cover; width: 100%; height: auto;">
      </div>
    </div>
  </div>
</div>

<%# --- PHẦN 2: NỘI DUNG CHÍNH --- %>
<div class="container">
  <div class="row">

    <%# CỘT TRÁI: DANH SÁCH BÀI HỌC %>
    <div class="col-lg-8">

      <h3 class="mb-4 border-bottom pb-2">Nội dung khóa học</h3>

      <div class="accordion mb-5" id="accordionCourse">
        <% @course.course_modules.order(:order_index).each_with_index do |mod, index| %>
          <div class="accordion-item">
            <h2 class="accordion-header" id="heading<%= mod.id %>">
              <button class="accordion-button <%= 'collapsed' if index > 0 %> fw-bold bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= mod.id %>">
                <%= mod.title %>
              </button>
            </h2>
            <div id="collapse<%= mod.id %>" class="accordion-collapse collapse <%= 'show' if index == 0 %>" data-bs-parent="#accordionCourse">
              <div class="accordion-body p-0">
                <div class="list-group list-group-flush">

                  <%# --- VÒNG LẶP BÀI HỌC (LESSONS) --- %>
                  <% mod.lessons.order(:order_index).each do |lesson| %>

                    <%# --- LOGIC QUYỀN TRUY CẬP --- %>
                    <% is_free = lesson.free_preview? %>
                    <% has_access = current_user && can?(:access_content, @course) %>

                    <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                      <div class="d-flex align-items-center text-truncate">
                        <i class="bi <%= lesson.video_url.present? ? 'bi-play-circle' : 'bi-file-text' %> me-3 text-muted fs-5"></i>

                        <%# TRƯỜNG HỢP 1: ĐƯỢC HỌC (Mua rồi hoặc Admin/Owner) %>
                        <% if has_access %>
                           <%= link_to lesson.title, lesson_path(lesson), class: "text-decoration-none text-dark fw-medium stretched-link" %>

                        <%# TRƯỜNG HỢP 2: HỌC THỬ (Chưa mua nhưng bài là Free) -> KÍCH HOẠT MODAL %>
                        <% elsif is_free %>
                           <a href="#" class="text-decoration-none text-dark fw-medium stretched-link"
                              data-bs-toggle="modal"
                              data-bs-target="#previewCourseModal"
                              data-video-url="<%= lesson.video_url %>"
                              data-lesson-title="<%= lesson.title %>">
                              <%= lesson.title %>
                           </a>

                        <%# TRƯỜNG HỢP 3: BỊ KHÓA %>
                        <% else %>
                           <span class="text-muted"><%= lesson.title %></span>
                        <% end %>
                      </div>

                      <%# BADGE TRẠNG THÁI BÊN PHẢI %>
                      <div>
                        <% if has_access %>
                           <i class="bi bi-chevron-right text-muted small"></i>
                        <% elsif is_free %>
                           <span class="badge bg-primary-subtle text-primary border border-primary fw-bold rounded-pill">
                             <i class="bi bi-eye-fill me-1"></i> Xem trước
                           </span>
                        <% else %>
                           <i class="bi bi-lock-fill text-secondary"></i>
                        <% end %>
                      </div>
                    </div>

                  <% end %>
                  <%# ------------------------------------ %>

                  <% if mod.lessons.empty? %>
                     <div class="p-3 text-muted fst-italic small">Nội dung đang được cập nhật.</div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <%# --- PHẦN BÀI KIỂM TRA (BIG QUIZ) --- %>
        <% if @big_quizzes.any? %>
          <% @big_quizzes.each do |quiz| %>
            <% accordion_id = "big_quiz_#{quiz.id}" %>
            <div class="accordion-item border-warning mt-2">
               <h2 class="accordion-header" id="heading_<%= accordion_id %>">
                <button class="accordion-button collapsed bg-warning-subtle text-dark fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapse_<%= accordion_id %>">
                  <i class="bi bi-trophy-fill me-2 text-warning"></i>
                  Bài kiểm tra: <%= quiz.title %>
                </button>
              </h2>
              <div id="collapse_<%= accordion_id %>" class="accordion-collapse collapse" data-bs-parent="#accordionCourse">
                <div class="accordion-body bg-light">
                  <div class="row align-items-center">
                    <div class="col-md-8">
                      <p class="mb-2 small text-muted"><%= quiz.description.presence || "Bài kiểm tra tổng hợp kiến thức." %></p>
                      <div class="d-flex gap-3 text-muted small">
                        <span><i class="bi bi-question-circle"></i> <%= quiz.total_questions %> câu</span>
                        <span><i class="bi bi-clock"></i> <%= quiz.time_limit ? "#{quiz.time_limit} phút" : "Không giới hạn" %></span>
                        <span><i class="bi bi-bullseye"></i> Đạt: <%= quiz.pass_score %>%</span>
                      </div>
                    </div>
                    <div class="col-md-4 text-end mt-3 mt-md-0">
                      <% if can? :access_content, @course %>
                        <% if current_user.quiz_completed?(quiz) %>
                          <button class="btn btn-success fw-bold disabled w-100 btn-sm">
                            <i class="bi bi-check-circle-fill"></i> Đã hoàn thành
                          </button>
                        <% else %>
                          <%= button_to quiz_quiz_attempts_path(quiz), method: :post, class: "btn btn-primary fw-bold w-100 btn-sm shadow-sm" do %>
                            <i class="bi bi-play-circle-fill"></i> Làm bài ngay
                          <% end %>
                        <% end %>
                      <% else %>
                        <button class="btn btn-secondary w-100 disabled btn-sm" title="Vui lòng đăng ký khóa học">
                          <i class="bi bi-lock-fill"></i> Bị khóa
                        </button>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <%# --- PHẦN ĐÁNH GIÁ (REVIEWS) --- %>
      <div id="course-reviews" class="mt-5">
        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
          <h3 class="mb-0">Đánh giá từ học viên</h3>

          <% if user_signed_in? %>
            <% enrollment = current_user.enrollments.find_by(course: @course) %>
            <% has_reviewed = @course.reviews.exists?(user: current_user) %>
            <% is_creator = (current_user == @course.creator) %>

            <% if enrollment&.active? && !has_reviewed && !is_creator %>
              <% if enrollment.can_review? %>
                <%# A. ĐỦ ĐIỀU KIỆN %>
                <button type="button" class="btn btn-outline-primary fw-bold" data-bs-toggle="modal" data-bs-target="#reviewModal">
                  <i class="bi bi-pencil-square me-1"></i> Viết đánh giá
                </button>
                <%= render "review_modal", course: @course %>
              <% else %>
                <%# B. CHƯA ĐỦ ĐIỀU KIỆN %>
                <button type="button" class="btn btn-outline-primary fw-bold" data-bs-toggle="modal" data-bs-target="#eligibilityModal">
                  <i class="bi bi-pencil-square me-1"></i> Viết đánh giá
                </button>

                <%# Modal cảnh báo chưa đủ tiến độ %>
                <div class="modal fade" id="eligibilityModal" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                      <div class="modal-header border-0 pb-0">
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>
                      <div class="modal-body text-center pb-4">
                        <div class="mb-3 text-warning"><i class="bi bi-exclamation-circle-fill" style="font-size: 3rem;"></i></div>
                        <h4 class="fw-bold">Chưa đủ điều kiện đánh giá</h4>
                        <p class="text-muted mt-3">Để đảm bảo tính khách quan, bạn cần hoàn thành ít nhất <strong>70%</strong> nội dung khóa học.</p>
                        <div class="bg-light p-3 rounded mt-3 d-inline-block">
                          Tiến độ hiện tại: <strong class="text-danger fs-5"><%= enrollment.current_progress_percentage %>%</strong> <span class="text-muted">/ 70%</span>
                        </div>
                        <div class="mt-4">
                          <button type="button" class="btn btn-primary px-4" data-bs-dismiss="modal">Tiếp tục học ngay</button>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            <% elsif is_creator %>
               <span class="text-muted small fst-italic border px-2 py-1 rounded bg-light">Giảng viên</span>
            <% elsif has_reviewed %>
              <span class="text-success fw-bold small"><i class="bi bi-check-circle-fill"></i> Đã đánh giá</span>
            <% else %>
              <span class="text-muted small fst-italic">Đăng ký học để đánh giá</span>
            <% end %>
          <% else %>
            <%= link_to new_user_session_path, class: "btn btn-outline-secondary btn-sm" do %>
              Đăng nhập để đánh giá
            <% end %>
          <% end %>
        </div>
        <%= render "reviews_list", reviews: @course.reviews.recent %>
      </div>
    </div>

    <%# CỘT PHẢI: SIDEBAR THÔNG TIN %>
    <div class="col-lg-4">
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-body">
          <h5 class="card-title fw-bold text-uppercase text-muted small">Giảng viên</h5>
          <div class="d-flex align-items-center mt-3">
             <div class="avatar-wrapper avatar-lg me-3">
                <% if @course.creator&.avatar_url.present? %>
                  <img src="<%= @course.creator.avatar_url %>" alt="<%= @course.creator.name %>" class="avatar-img">
                <% else %>
                  <div class="avatar-text avatar-lg-text"><%= @course.creator&.name&.first&.upcase || "?" %></div>
                <% end %>
              </div>
             <div>
               <h6 class="mb-0 fw-bold"><%= @course.creator&.name || "Admin" %></h6>
               <small class="text-muted">Senior Instructor</small>
             </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0 bg-light">
        <div class="card-body">
          <ul class="list-unstyled mb-0">
            <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Truy cập trọn đời</li>
            <li class="mb-2"><i class="bi bi-phone-fill text-primary me-2"></i> Học trên thiết bị di động</li>
            <li><i class="bi bi-award-fill text-warning me-2"></i> Cấp chứng chỉ khi hoàn thành</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<%# --- MODAL XEM TRƯỚC (DARK THEME) --- %>
<div class="modal fade" id="previewCourseModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content bg-dark text-white border-secondary">
      <%# Header Modal %>
      <div class="modal-header border-secondary">
        <h5 class="modal-title">
          <span class="text-warning me-2">Xem trước:</span>
          <span id="previewModalTitle" class="fw-bold"></span>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <%# Body Modal %>
      <div class="modal-body p-0">
        <div class="row g-0">
          <%# Cột Trái: Video Player %>
          <div class="col-lg-8 bg-black d-flex align-items-center justify-content-center" style="min-height: 400px;">
            <div class="ratio ratio-16x9">
              <iframe id="previewVideoFrame" src="" title="YouTube video" allowfullscreen></iframe>
            </div>
          </div>

          <%# Cột Phải: Playlist Free %>
          <div class="col-lg-4 border-start border-secondary d-none d-lg-block">
            <div class="p-3 border-bottom border-secondary bg-dark">
              <h6 class="mb-0 fw-bold">Các bài học miễn phí khác:</h6>
            </div>
            <div class="list-group list-group-flush overflow-auto custom-scrollbar" style="max-height: 400px;">
              <% @course.course_modules.flat_map(&:lessons).select(&:free_preview?).each do |free_lesson| %>
                 <button type="button"
                         class="list-group-item list-group-item-action bg-dark text-white border-secondary d-flex align-items-center py-3 preview-playlist-item"
                         onclick="changePreviewVideo('<%= free_lesson.video_url %>', '<%= free_lesson.title %>')">
                    <i class="bi bi-play-circle text-warning fs-5 me-3"></i>
                    <div class="small text-truncate"><%= free_lesson.title %></div>
                 </button>
              <% end %>
            </div>

            <%# Footer Playlist %>
            <div class="p-3 bg-dark border-top border-secondary text-center mt-auto">
              <% unless current_user && can?(:access_content, @course) %>
                <p class="small text-muted mb-2">Bạn thích nội dung này?</p>
                <% if @course.free? %>
                   <%= button_to "Đăng ký học ngay", course_enrollments_path(@course), class: "btn btn-primary w-100 btn-sm fw-bold" %>
                <% else %>
                   <%= button_to "Mua khóa học ngay", create_checkout_session_path(course_id: @course.id), data: { turbo: false }, class: "btn btn-warning w-100 btn-sm fw-bold text-dark" %>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# --- JAVASCRIPT XỬ LÝ VIDEO --- %>
<script>
  document.addEventListener("turbo:load", function() {
    var previewModal = document.getElementById('previewCourseModal');
    if (!previewModal) return;

    // Khi Modal hiện lên -> Lấy link video và phát
    previewModal.addEventListener('show.bs.modal', function (event) {
      var button = event.relatedTarget;
      var videoUrl = button.getAttribute('data-video-url');
      var lessonTitle = button.getAttribute('data-lesson-title');
      changePreviewVideo(videoUrl, lessonTitle);
    });

    // Khi đóng Modal -> Dừng video (xóa src)
    previewModal.addEventListener('hidden.bs.modal', function () {
      document.getElementById('previewVideoFrame').src = "";
    });
  });

  function changePreviewVideo(url, title) {
    var embedUrl = getYoutubeEmbedUrl(url);
    document.getElementById('previewModalTitle').textContent = title || "Bài học mẫu";

    if (embedUrl) {
      document.getElementById('previewVideoFrame').src = embedUrl + "?autoplay=1&rel=0";
    } else {
      document.getElementById('previewVideoFrame').src = "";
    }
  }

  function getYoutubeEmbedUrl(url) {
    if (!url) return null;
    var regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
    var match = url.match(regExp);
    return (match && match[2].length == 11) ? "https://www.youtube.com/embed/" + match[2] : null;
  }
</script>

<style>
  .custom-scrollbar::-webkit-scrollbar { width: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: #212529; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #495057; border-radius: 3px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #6c757d; }
  .preview-playlist-item:hover { background-color: #343a40 !important; cursor: pointer; }
</style>
