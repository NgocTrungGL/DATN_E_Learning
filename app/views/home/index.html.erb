<%# ============================================================ %>
<%# SECTION 3: FEATURED COURSES                                %>
<%# ============================================================ %>
<section class="courses-section" id="courses">
  <div class="container">
    <div class="text-center mb-5" data-reveal>
      <span class="lp-section-badge">📚 Featured Courses</span>
      <h2 class="lp-section-title">Start Learning Today</h2>
      <p class="lp-section-subtitle">
        Browse our most popular courses, hand-picked by our expert team to help you build skills that matter.
      </p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4">
      <% @featured_courses.each_with_index do |course, i| %>
        <div class="col" data-reveal data-reveal-delay="<%= [i * 100, 400].min %>">
          <div class="lp-course-card">
            <div class="course-thumbnail-wrapper">
              <%= link_to course_path(course) do %>
                <img src="<%= course.thumbnail_url.presence || 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=400&h=220&fit=crop' %>"
                     alt="<%= course.title %>">
              <% end %>
              <% if course.category %>
                <span class="course-category-badge"><%= course.category.name %></span>
              <% end %>
              <span class="course-price-badge <%= 'free' if course.free? %>">
                <% if course.free? %>
                  Free
                <% else %>
                  <%= number_to_currency(course.price, unit: "₫", format: "%n %u", precision: 0) %>
                <% end %>
              </span>
            </div>
            <div class="course-body">
              <%= link_to course.title, course_path(course), class: "course-title" %>
              <p class="course-instructor">
                <i class="bi bi-person-fill"></i>
                <%= course.creator&.name || "E-Learning Team" %>
              </p>
              <div class="course-meta">
                <div class="course-rating">
                  <% if course.reviews.any? %>
                    <% avg = course.reviews.average(:rating).to_f.round(1) %>
                    <span class="rating-value"><%= avg %></span>
                    <span class="star"><i class="bi bi-star-fill"></i></span>
                    <span class="rating-count">(<%= course.reviews.count %>)</span>
                  <% else %>
                    <span style="color: var(--lp-text-muted); font-size: 0.75rem;">No reviews yet</span>
                  <% end %>
                </div>
                <div class="course-students">
                  <% if course.total_students > 0 %>
                    <i class="bi bi-people-fill"></i>
                    <%= number_to_human(course.total_students, format: "%n%u", units: { thousand: "k" }) %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <%# If no courses, show placeholder cards %>
      <% if @featured_courses.empty? %>
        <% 4.times do |i| %>
          <div class="col" data-reveal data-reveal-delay="<%= i * 100 %>">
            <div class="lp-course-card">
              <div class="course-thumbnail-wrapper" style="background: linear-gradient(135deg, #2563eb20, #0d948820);"></div>
              <div class="course-body">
                <div style="height: 40px; background: #f1f5f9; border-radius: 8px; margin-bottom: 0.5rem;"></div>
                <div style="height: 20px; background: #f8fafc; border-radius: 6px; width: 70%; margin-bottom: 0.75rem;"></div>
                <div class="course-meta" style="border-top: 1px solid #e2e8f0; padding-top: 0.75rem;">
                  <span style="font-size: 0.8rem; color: #94a3b8;">Courses loading...</span>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="text-center mt-5" data-reveal>
      <%= link_to "View All Courses →", courses_path, class: "btn btn-outline-primary btn-lg px-5 fw-bold" %>
    </div>
  </div>
</section>

<%# ============================================================ %>
<%# SECTION 4: LEARNING PATHS                                  %>
<%# ============================================================ %>
<section class="paths-section" id="learning-paths">
  <div class="container">
    <div class="text-center mb-5" data-reveal>
      <span class="lp-section-badge">🗺️ Learning Paths</span>
      <h2 class="lp-section-title">Structured Roadmaps to Success</h2>
      <p class="lp-section-subtitle">
        Don't get lost. Follow our expert-crafted learning paths that take you from beginner to job-ready.
      </p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4">
      <% learning_paths.each_with_index do |path, i| %>
        <div class="col" data-reveal data-reveal-delay="<%= [i * 100, 300].min %>">
          <div class="path-card <%= path[:css_class] %>">
            <div class="path-icon <%= path[:icon_bg] %>">
              <%= path[:icon] %>
            </div>
            <h3 class="path-title"><%= path[:title] %></h3>
            <p class="path-description"><%= path[:description] %></p>
            <div class="path-tags">
              <% path[:tags].each do |tag| %>
                <span class="path-tag"><%= tag %></span>
              <% end %>
            </div>
            <div class="path-meta">
              <span><i class="bi bi-book"></i> <%= path[:courses_count] %> courses</span>
              <span><i class="bi bi-clock"></i> <%= path[:hours] %>+ hrs</span>
            </div>
            <div class="path-cta">
              <span class="path-level"><i class="bi bi-bar-chart-fill"></i> <%= path[:level] %></span>
              <%= link_to courses_path do %>
                Explore Path <i class="bi bi-arrow-right"></i>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
