<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-lg-5">
      <h2 class="fw-bold mb-4">Change Password</h2>

      <div class="card shadow-sm">
        <div class="card-body">

          <%= form_with(url: password_path, method: :patch) do |f| %>

            <% if flash[:alert] %>
              <div class="alert alert-danger"><%= flash[:alert] %></div>
            <% end %>

            <!-- Show validation errors (e.g., short password) -->
            <% if controller.instance_variable_get(:@user)&.errors&.any? %>
              <div class="alert alert-danger">
                <% controller.instance_variable_get(:@user).errors.full_messages.each do |msg| %>
                  <div><%= msg %></div>
                <% end %>
              </div>
            <% end %>

            <div class="mb-3">
              <%= f.label :current_password, "Current password", class: "form-label" %>
              <%= f.password_field :current_password, class: "form-control", required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :password, "New password", class: "form-label" %>
              <%= f.password_field :password, class: "form-control", required: true, placeholder: "Minimum 6 characters" %>
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
              <%= f.password_field :password_confirmation, class: "form-control", required: true %>
            </div>

            <div class="d-grid gap-2">
              <%= f.submit "Update Password", class: "btn btn-primary" %>
              <%= link_to "Cancel (Back to profile)", edit_profile_path, class: "btn btn-light text-center" %>
            </div>

          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
