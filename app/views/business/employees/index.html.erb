<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold text-primary"><i class="bi bi-people me-2"></i>Employee list</h2>
  <%= link_to new_business_employee_path, class: "btn btn-primary shadow-sm" do %>
    <i class="bi bi-person-plus-fill me-2"></i> Add new employee
  <% end %>
</div>

<div class="card shadow border-0">
  <div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="bg-light text-uppercase small fw-bold">
        <tr>
          <th class="px-4 py-3">Full name</th>
          <th class="py-3">Login email</th>
          <th class="py-3">Joined on</th>
          <th class="py-3 text-end px-4">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if @employees.any? %>
          <% @employees.each do |emp| %>
            <tr>
              <td class="px-4">
                <div class="d-flex align-items-center">
                  <img src="<%= emp.avatar_url.presence || "https://ui-avatars.com/api/?name=#{emp.name}&background=random" %>"
                 class="rounded-circle" width="40" height="40">
                  <span class="fw-bold"><%= emp.name %></span>
                </div>
              </td>
              <td><%= emp.email %></td>
              <td><%= emp.created_at.strftime("%d/%m/%Y") %></td>
              <td class="text-end px-4">
                <%= link_to "Edit", edit_business_employee_path(emp), class: "btn btn-sm btn-outline-secondary me-1" %>
                <%= link_to "Delete", business_employee_path(emp), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this employee?" }, class: "btn btn-sm btn-outline-danger" %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="text-center py-5 text-muted">
              <i class="bi bi-inbox fs-1 d-block mb-3"></i>
              No employees yet. Add your first employee!
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
