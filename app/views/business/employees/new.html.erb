<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold">Add new employee</h5>
      </div>
      <div class="card-body p-4">
        <%= form_with model: @employee, url: business_employees_path, local: true do |f| %>

          <%= render "shared/error_messages", object: f.object rescue nil %>

          <div class="mb-3">
            <%= f.label :name, "Employee full name", class: "form-label" %>
            <%= f.text_field :name, class: "form-control", required: true, placeholder: "Jane Doe" %>
          </div>

          <div class="mb-3">
            <%= f.label :email, "Work email", class: "form-label" %>
            <%= f.email_field :email, class: "form-control", required: true, placeholder: "employee@company.com" %>
          </div>

          <div class="alert alert-info small">
            <i class="bi bi-info-circle me-1"></i>
            Since the system does not send invitation emails yet, set a default password and share login details with the employee.
          </div>

          <div class="row g-2 mb-4">
            <div class="col-md-6">
              <%= f.label :password, "Initial password", class: "form-label" %>
              <%= f.password_field :password, class: "form-control", required: true %>
            </div>
            <div class="col-md-6">
              <%= f.label :password_confirmation, "Confirm password", class: "form-label" %>
              <%= f.password_field :password_confirmation, class: "form-control", required: true %>
            </div>
          </div>

          <div class="d-flex justify-content-end gap-2">
            <%= link_to "Cancel", business_employees_path, class: "btn btn-light" %>
            <%= f.submit "Create account", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
