<h2 class="fw-bold text-primary mb-4">
  <i class="bi bi-shop me-2"></i>
  Buy more licenses
</h2>

<div class="row">
  <% @courses.each do |course| %>
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm border-0">

        <% if course.image.attached? %>
          <%= image_tag course.image,
                class: "card-img-top",
                style: "height: 200px; object-fit: cover;" %>

        <% elsif course.thumbnail_url.present? %>
          <%= image_tag course.thumbnail_url,
                class: "card-img-top",
                style: "height: 200px; object-fit: cover;" %>

        <% else %>
          <div class="bg-secondary text-white d-flex align-items-center justify-content-center fw-bold"
               style="height: 200px;">
            NO IMAGE
          </div>
        <% end %>

        <div class="card-body d-flex flex-column">

          <!-- Title -->
          <h5 class="card-title fw-bold mb-1">
            <%= course.title %>
          </h5>

          <!-- Description -->
          <p class="card-text text-muted small flex-grow-1">
            <%= course.description.to_s.truncate(80) %>
          </p>

          <!-- Price -->
          <div class="mb-3">
            <h4 class="fw-bold text-success mb-0">
              <%= number_to_currency(course.price) %>
              <small class="fs-6 text-muted fw-normal">/seat</small>
            </h4>

            <!-- Promotion -->
            <div class="alert alert-warning border-warning p-2 mt-2 mb-0 small bg-warning bg-opacity-10 text-dark">
              <div class="fw-bold">
                <i class="bi bi-tag-fill me-1"></i>
                Business offer:
              </div>
              Buy <strong>10 seats</strong> and get <strong>10%</strong> off.
              <br>
              (Now only
              <strong><%= number_to_currency(course.price * 0.9) %></strong>/seat)
            </div>
          </div>

          <!-- Checkout form -->
          <%= form_with url: create_checkout_session_path,
                        method: :post,
                        data: { turbo: false } do |f| %>

            <%= f.hidden_field :course_id, value: course.id %>
            <%= f.hidden_field :purchase_type, value: "license" %>

            <!-- Quantity (FIXED UI) -->
            <div class="mb-3">
              <label class="form-label fw-semibold small mb-1">
                Quantity
              </label>

              <%= f.number_field :quantity,
                    value: 10,
                    min: 1,
                    max: 100,
                    class: "form-control text-center fw-bold py-2" %>
            </div>

            <!-- Submit -->
            <%= f.button type: "submit",
                          class: "btn btn-primary w-100 fw-bold" do %>
              <i class="bi bi-cart-plus me-2"></i>
              Buy now
            <% end %>

          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
<% if @courses.empty? %>
  <div class="alert alert-info">
    No courses are available in the catalog right now.
  </div>
<% end %>
