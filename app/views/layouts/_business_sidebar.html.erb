<div class="bg-white border-end" id="sidebar-wrapper" style="width: 280px; min-height: 100vh;">
  <div class="sidebar-heading border-bottom bg-light fw-bold text-uppercase text-primary">
    <i class="bi bi-briefcase-fill me-2"></i> Business Portal
  </div>

  <div class="list-group list-group-flush p-3">
    <%= link_to business_root_path, class: "list-group-item list-group-item-action mb-2 #{'active' if controller_name == 'dashboard'}" do %>
      <i class="bi bi-speedometer2 me-2"></i> Tổng quan
    <% end %>

    <small class="text-uppercase text-muted fw-bold mt-3 mb-2 px-3" style="font-size: 0.75rem;">QUẢN LÝ NHÂN SỰ</small>

    <%= link_to business_employees_path, class: "list-group-item list-group-item-action mb-2 #{'active' if controller_name == 'employees'}" do %>
      <i class="bi bi-people-fill me-2"></i> Danh sách nhân viên
    <% end %>

    <small class="text-uppercase text-muted fw-bold mt-3 mb-2 px-3" style="font-size: 0.75rem;">ĐÀO TẠO</small>

    <a href="#" class="list-group-item list-group-item-action mb-2 text-muted">
      <i class="bi bi-ticket-perforated me-2"></i> Kho License khóa học
      <i class="bi bi-lock-fill ms-auto small"></i>
    </a>
  </div>
</div>
