.<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top py-3">
  <div class="container">

    <%= link_to root_path, class: "navbar-brand fw-bold text-dark fs-4 me-4" do %>
      E-Learning
    <% end %>

    <div class="dropdown me-4 d-none d-lg-block">
      <a class="text-decoration-none text-dark fw-medium" href="#" role="button" id="categoryDropdown" data-bs-toggle="dropdown" aria-expanded="false">
        Danh mục
      </a>
      <ul class="dropdown-menu shadow border-0" aria-labelledby="categoryDropdown">
        <% Category.where(parent_id: nil).each do |parent_cat| %>
          <li>
            <a class="dropdown-item d-flex justify-content-between align-items-center" href="<%= category_path(parent_cat) %>">
              <%= parent_cat.name %>
              <% if parent_cat.children.any? %>
                <i class="bi bi-chevron-right small text-muted"></i>
              <% end %>
            </a>

            <% if parent_cat.children.any? %>
              <ul class="dropdown-menu submenu shadow border-0">
                <% parent_cat.children.each do |child_cat| %>
                  <li>
                    <%= link_to child_cat.name, category_path(child_cat), class: "dropdown-item" %>
                  </li>
                <% end %>
              </ul>
            <% end %>
          </li>
        <% end %>
        <li><hr class="dropdown-divider"></li>
        <li><%= link_to "Tất cả danh mục", categories_path, class: "dropdown-item fw-bold" %></li>
      </ul>
    </div>
    <div class="flex-grow-1 d-flex justify-content-center mx-3">
      <form action="<%= courses_path %>" method="get"
            class="search-box d-flex align-items-center w-100">

        <i class="bi bi-search search-icon"></i>

        <input type="search"
              name="query"
              class="search-input"
              placeholder="Tìm khóa học..."
              aria-label="Search">
      </form>
    </div>


    <button class="navbar-toggler ms-3" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse flex-grow-0" id="navbarNav">
      <ul class="navbar-nav align-items-center ms-auto">

        <li class="nav-item d-none d-lg-block">
          <a href="#" class="nav-link text-dark small">E-Learning Business</a>
        </li>
        <li class="nav-item d-none d-lg-block">
          <a href="#" class="nav-link text-dark small">Giảng dạy</a>
        </li>

        <% if current_user %>

          <li class="nav-item mx-2">
            <%= link_to "Học tập", my_courses_path, class: "nav-link text-dark fw-medium" %>
          </li>

          <li class="nav-item me-3">
            <a href="#" class="nav-link text-dark position-relative">
              <i class="bi bi-cart"></i>
            </a>
          </li>

          <li class="nav-item dropdown">
            <a class="nav-link p-0" href="#" role="button" data-bs-toggle="dropdown">
              <% if current_user.avatar_url.present? %>
                <img src="<%= current_user.avatar_url %>" class="rounded-circle border" width="35" height="35" style="object-fit: cover;">
              <% else %>
                <div class="bg-dark text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 35px; height: 35px;">
                  <%= current_user.name[0..1].upcase %>
                </div>
              <% end %>
            </a>

            <ul class="dropdown-menu dropdown-menu-end shadow pt-0" style="min-width: 250px;">
              <li class="d-flex align-items-center p-3 border-bottom mb-2">
                <div class="me-3">
                   <% if current_user.avatar_url.present? %>
                    <img src="<%= current_user.avatar_url %>" class="rounded-circle border" width="50" height="50" style="object-fit: cover;">
                  <% else %>
                    <div class="bg-dark text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 50px; height: 50px; font-size: 1.2rem;">
                      <%= current_user.name[0..1].upcase %>
                    </div>
                  <% end %>
                </div>
                <div>
                  <div class="fw-bold text-truncate" style="max-width: 160px;"><%= current_user.name %></div>
                  <div class="small text-muted text-truncate" style="max-width: 160px;"><%= current_user.email %></div>
                </div>
              </li>

              <li><%= link_to "Học tập của tôi", my_courses_path, class: "dropdown-item" %></li>
              <li><%= link_to "Hồ sơ cá nhân", edit_profile_path, class: "dropdown-item" %></li>

              <% if current_user.admin? %>
                <li><hr class="dropdown-divider"></li>
                <li><%= link_to "Trang quản trị", admin_courses_path, class: "dropdown-item text-danger fw-bold" %></li>
              <% end %>

              <li><hr class="dropdown-divider"></li>
              <li>
                <%= button_to logout_path, method: :delete, class: "dropdown-item w-100 text-start" do %>
                  Đăng xuất
                <% end %>
              </li>
            </ul>
          </li>
        <% else %>
          <li class="nav-item ms-3">
            <%= link_to "Đăng nhập", login_path, class: "btn btn-outline-dark fw-bold px-3" %>
          </li>
          <li class="nav-item ms-2">
            <%= link_to "Đăng ký", signup_path, class: "btn btn-dark fw-bold px-3" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
