<%# ============================================================ %>
<%# REDESIGNED NAVBAR                                            %>
<%# ============================================================ %>

<nav class="navbar navbar-expand-lg lp-navbar sticky-top">
  <div class="container">
    <%# --- LOGO --- %>
    <%= link_to root_path, class: "navbar-brand" do %>
      <i class="bi bi-mortarboard-fill"></i>
      <span>E-Learning</span>
    <% end %>

    <%# --- MOBILE TOGGLER --- %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <%# --- NAV LINKS --- %>
    <div class="collapse navbar-collapse" id="navbarMain">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
        
        <%# --- COURSES DROPDOWN --- %>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" id="coursesDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Courses
          </a>
          <ul class="dropdown-menu border-0 shadow" aria-labelledby="coursesDropdown">
            <%# FUTURE: Replace hardcoded categories with Category.where(parent_id: nil) loop %>
            <li>
              <%= link_to categories_path, class: "dropdown-item" do %>
                <i class="bi bi-code-slash"></i> Web Development
              <% end %>
            </li>
            <li>
              <%= link_to categories_path, class: "dropdown-item" do %>
                <i class="bi bi-graph-up"></i> Data Science
              <% end %>
            </li>
            <li>
              <%= link_to categories_path, class: "dropdown-item" do %>
                <i class="bi bi-palette"></i> Design & UI/UX
              <% end %>
            </li>
            <li>
              <%= link_to categories_path, class: "dropdown-item" do %>
                <i class="bi bi-hdd-network"></i> DevOps & Cloud
              <% end %>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
              <%= link_to courses_path, class: "dropdown-item fw-bold text-primary" do %>
                <i class="bi bi-arrow-right-circle"></i> Browse All Courses
              <% end %>
            </li>
          </ul>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="#learning-paths">Learning Paths</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#pricing">Pricing</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#instructors">About</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#cta">Contact</a>
        </li>
      </ul>

      <%# --- AUTH BUTTONS / USER SECTION --- %>
      <div class="d-flex align-items-center gap-3 btn-group-mobile">
        <% if current_user %>
          <%# --- Logged In State --- %>
          <div class="nav-item dropdown">
            <a class="nav-link p-0 d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <% if current_user.avatar_url.present? %>
                <img src="<%= current_user.avatar_url %>" class="rounded-circle border" width="38" height="38" style="object-fit: cover;">
              <% else %>
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 38px; height: 38px;">
                  <%= current_user.name.to_s[0].upcase %>
                </div>
              <% end %>
              <span class="d-lg-none fw-bold text-dark"><%= current_user.name %></span>
            </a>

            <ul class="dropdown-menu dropdown-menu-end shadow border-0 pt-0" style="min-width: 260px;">
              <li class="p-4 border-bottom bg-light rounded-top-4">
                <div class="fw-bold text-dark text-truncate"><%= current_user.name %></div>
                <div class="small text-muted text-truncate"><%= current_user.email %></div>
              </li>
              
              <li><%= link_to "My Courses", my_courses_path, class: "dropdown-item mt-2" %></li>
              <li><%= link_to "Edit Profile", edit_user_registration_path, class: "dropdown-item" %></li>

              <% if current_user.admin? %>
                <li><hr class="dropdown-divider"></li>
                <li><%= link_to "Admin Dashboard", admin_dashboard_path, class: "dropdown-item text-danger fw-bold" %></li>
              <% end %>

              <li><hr class="dropdown-divider"></li>
              <li>
                <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "dropdown-item text-start w-100" %>
              </li>
            </ul>
          </div>
        <% else %>
          <%# --- Logged Out State --- %>
          <%= link_to "Login", new_user_session_path, class: "btn-login" %>
          <%= link_to "Sign Up", new_user_registration_path, class: "btn-signup" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>

<div class="navbar-backdrop"></div>

<%# Mobile Menu Enhancement Script %>
<script>
  document.addEventListener('turbo:load', function() {
    const toggler = document.querySelector('.navbar-toggler');
    const collapse = document.querySelector('.navbar-collapse');
    const backdrop = document.querySelector('.navbar-backdrop');
    const navbar = document.querySelector('.lp-navbar');

    if (toggler) {
      toggler.addEventListener('click', function() {
        backdrop.classList.toggle('show');
      });
    }

    if (backdrop) {
      backdrop.addEventListener('click', function() {
        collapse.classList.remove('show');
        backdrop.classList.remove('show');
      });
    }

    // Scroll effect
    window.addEventListener('scroll', function() {
      if (window.scrollY > 50) {
        navbar.classList.add('navbar-scrolled');
      } else {
        navbar.classList.remove('navbar-scrolled');
      }
    });
  });
</script>
