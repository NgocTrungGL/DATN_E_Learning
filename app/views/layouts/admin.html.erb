<!DOCTYPE html>
<html>
  <head>
    <title>Admin Portal | E-Learning</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      body {
        min-height: 100vh;
        overflow-x: hidden;
        background-color: #f8f9fa;
      }

      .admin-wrapper {
        display: flex;
        width: 100%;
        align-items: stretch;
      }

      /* --- SIDEBAR STYLES (Đã sửa màu chữ) --- */
      #sidebar {
        min-width: 260px;
        max-width: 260px;
        min-height: 100vh;
        background: #212529; /* Nền tối */
        color: #fff;         /* Chữ trắng */
        transition: all 0.3s;
      }

      #sidebar .sidebar-header {
        padding: 20px;
        background: #1a1d20;
        border-bottom: 1px solid #343a40;
      }

      #sidebar ul.components {
        padding: 20px 0;
      }

      /* Style cho các tiêu đề nhóm (VD: NỘI DUNG ĐÀO TẠO) */
      #sidebar ul li.text-uppercase {
        color: #adb5bd !important; /* Màu xám sáng dễ đọc */
        font-weight: bold;
        letter-spacing: 0.5px;
        margin-top: 15px;
        margin-bottom: 5px;
      }

      /* Link menu thông thường */
      #sidebar ul li a {
        padding: 12px 20px;
        font-size: 0.95rem;
        display: block;
        color: #ced4da; /* Màu trắng xám */
        text-decoration: none;
        transition: 0.2s;
        border-left: 4px solid transparent;
      }

      /* Khi di chuột vào link */
      #sidebar ul li a:hover {
        color: #fff; /* Chuyển sang trắng tinh */
        background: #2c3034;
        border-left-color: #ffc107; /* Vạch vàng bên trái */
      }

      /* Link đang Active (Trang hiện tại) */
      #sidebar ul li a.active {
        color: #fff;
        background: #2c3034;
        border-left-color: #0d6efd; /* Vạch xanh bên trái */
        font-weight: 600;
      }

      #sidebar ul li a i {
        margin-right: 10px;
        width: 20px;
        text-align: center;
      }

      /* --- CONTENT STYLES --- */
      #content {
        width: 100%;
        padding: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .admin-topbar {
        background: #fff;
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
        padding: 15px 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
      }
    </style>
  </head>

  <body>
    <div class="admin-wrapper">

      <%= render "layouts/admin_sidebar" %>

      <div id="content">
        <%= render "layouts/admin_topbar" %>

        <div class="p-4 flex-grow-1">
          <% if notice %>
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
              <i class="bi bi-check-circle-fill me-2"></i><%= notice %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% end %>
          <% if alert %>
            <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i><%= alert %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% end %>

          <%= yield %>
        </div>

        <footer class="bg-white text-center py-3 text-muted small border-top mt-auto">
          &copy; <%= Time.current.year %> E-Learning Admin Portal
        </footer>
      </div>

    </div>
  </body>
</html>
