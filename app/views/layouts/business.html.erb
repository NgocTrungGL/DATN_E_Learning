<!DOCTYPE html>
<html>
  <head>
    <title><%= current_user.organization&.name %> | Business Portal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  </head>

  <body class="bg-light">
    <div class="d-flex" id="wrapper">

      <%= render 'layouts/business_sidebar' %>

      <div id="page-content-wrapper" class="w-100">
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom px-4 py-3 shadow-sm">
          <div class="d-flex align-items-center w-100 justify-content-between">
            <h5 class="mb-0 fw-bold text-primary">
              <i class="bi bi-building me-2"></i> <%= current_user.organization&.name %>
            </h5>

            <div class="dropdown">
              <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark" id="dropdownUser" data-bs-toggle="dropdown">
                <img src="https://ui-avatars.com/api/?name=<%= current_user.name %>&background=random" width="32" height="32" class="rounded-circle me-2">
                <span class="fw-bold"><%= current_user.name %></span>
              </a>
              <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                <li><%= link_to "Đăng xuất", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item text-danger" %></li>
              </ul>
            </div>
          </div>
        </nav>

        <div class="container-fluid py-4 px-4">
          <%= render 'layouts/flash_messages' %>
          <%= yield %>
        </div>
      </div>
    </div>

    <style>
      #wrapper { overflow-x: hidden; }
      .sidebar-heading { padding: 1.5rem 1.25rem; font-size: 1.2rem; }
      .list-group-item { border: none; padding: 1rem 1.25rem; }
      .list-group-item.active { background-color: #0d6efd; color: white; font-weight: bold; border-radius: 0.5rem; }
      .list-group-item-action:hover { background-color: #e9ecef; color: #000; border-radius: 0.5rem; }
    </style>
  </body>
</html>
