<%# ============================================================ %>
<%# ADMIN SIDEBAR — Redesigned UI (BEM)                       %>
<%# ============================================================ %>

<nav class="admin-sidebar" id="sidebar">

  <%# ── Header / Brand ────────────────────────────────────── %>
  <div class="admin-sidebar__header">
    <%= link_to admin_dashboard_path, class: "admin-sidebar__brand" do %>
      <i class="bi bi-shield-lock-fill"></i>
      <span>ADMIN PORTAL</span>
    <% end %>
  </div>

  <%# ── Navigation List ───────────────────────────────────── %>
  <div class="admin-sidebar__nav">

    <%# Dashboard %>
    <%= link_to admin_dashboard_path, class: "admin-sidebar__link #{'active' if controller_name == 'dashboard'}" do %>
      <span><i class="bi bi-speedometer2"></i> Dashboard</span>
    <% end %>

    <%# Section: Learning content %>
    <div class="admin-sidebar__group">Learning content</div>

    <%= link_to admin_course_reviews_path, class: "admin-sidebar__link #{'active' if controller_name == 'course_reviews'}" do %>
      <span><i class="bi bi-check-circle-fill" style="color: #f59e0b;"></i> Review Courses</span>
      <% pending_count = Course.pending.count %>
      <% if pending_count > 0 %>
        <span class="admin-sidebar__badge admin-sidebar__badge--pulse"><%= pending_count %></span>
      <% end %>
    <% end %>

    <%= link_to admin_courses_path, class: "admin-sidebar__link #{'active' if controller_name == 'courses' && params[:status].blank?}" do %>
      <span><i class="bi bi-collection-play"></i> All Courses</span>
    <% end %>

    <%= link_to admin_categories_path, class: "admin-sidebar__link #{'active' if controller_name == 'categories'}" do %>
      <span><i class="bi bi-tags"></i> Categories</span>
    <% end %>

    <%# Section: Quizzes & Assessment %>
    <div class="admin-sidebar__group">Quizzes & Assessment</div>

    <%= link_to admin_quizzes_path, class: "admin-sidebar__link #{'active' if controller_name == 'quizzes'}" do %>
      <span><i class="bi bi-card-checklist"></i> Quizzes</span>
    <% end %>

    <%= link_to admin_questions_path, class: "admin-sidebar__link #{'active' if controller_name == 'questions'}" do %>
      <span><i class="bi bi-question-square"></i> Question Bank</span>
    <% end %>

    <%# Section: Engagement & Community %>
    <div class="admin-sidebar__group">Engagement & Community</div>

    <%= link_to admin_reviews_path, class: "admin-sidebar__link #{'active' if controller_name == 'reviews'}" do %>
      <span><i class="bi bi-star"></i> Reviews</span>
    <% end %>

    <%= link_to admin_comments_path, class: "admin-sidebar__link #{'active' if controller_name == 'comments'}" do %>
      <span><i class="bi bi-chat-dots"></i> Q&A (Comments)</span>
    <% end %>

    <%# Section: Users & System %>
    <div class="admin-sidebar__group">Users & System</div>

    <%= link_to admin_users_path, class: "admin-sidebar__link #{'active' if controller_name == 'users'}" do %>
      <span><i class="bi bi-people-fill"></i> Users</span>
    <% end %>

    <%= link_to admin_instructor_profiles_path, class: "admin-sidebar__link #{'active' if controller_name == 'instructors'}" do %>
      <span><i class="bi bi-person-lines-fill"></i> Instructor Approvals</span>
    <% end %>

    <%# Section: Finance %>
    <div class="admin-sidebar__group">Finance Management</div>

    <%= link_to admin_revenues_path, class: "admin-sidebar__link #{'active' if controller_name == 'revenues'}" do %>
      <span><i class="bi bi-cash-coin" style="color: #10b981;"></i> Platform Revenue</span>
    <% end %>

    <%= link_to admin_enrollments_path, class: "admin-sidebar__link #{'active' if controller_name == 'enrollments'}" do %>
      <span><i class="bi bi-receipt-cutoff"></i> Enrollment Approvals</span>
    <% end %>

    <%= link_to admin_payouts_path, class: "admin-sidebar__link #{'active' if controller_name == 'payouts'}" do %>
      <span><i class="bi bi-bank2" style="color: #ef4444;"></i> Payout Requests</span>
    <% end %>

    <%= link_to admin_coupons_path, class: "admin-sidebar__link #{'active' if controller_name == 'coupons'}" do %>
      <span><i class="bi bi-ticket-perforated" style="color: #8b5cf6;"></i> Coupons</span>
    <% end %>

  </div>
</nav>
