<% flash.each do |type, message| %>
  <%
    # Map Rails flash type to Bootstrap color class
    alert_class = case type.to_s
      when 'notice' then 'success'  # Green
      when 'alert'  then 'danger'   # Red
      when 'error'  then 'danger'   # Red
      else 'info'                   # Blue
    end
  %>

  <div class="alert alert-<%= alert_class %> alert-dismissible fade show mb-3 shadow-sm" role="alert">
    <% if type.to_s == 'notice' %>
      <i class="bi bi-check-circle-fill me-2"></i>
    <% elsif type.to_s == 'alert' %>
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
    <% end %>

    <%= message %>

    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>
