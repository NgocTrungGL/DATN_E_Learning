<div class="container py-5">
  <h3 class="mb-4 fw-bold"><i class="bi bi-cart3"></i> Your cart</h3>

  <% if @items.any? %>
    <div class="row">
      <div class="col-lg-8">
        <div class="card shadow-sm border-0">
          <ul class="list-group list-group-flush">
            <% @items.each do |item| %>
              <li class="list-group-item p-4 d-flex align-items-center">

                <div class="me-3 flex-shrink-0" style="width: 120px; height: 70px; background: #eee; border-radius: 8px; overflow: hidden;">
                   <% if item.course.thumbnail_url.present? %>
                     <img src="<%= item.course.thumbnail_url %>" style="width: 100%; height: 100%; object-fit: cover;" alt="<%= item.course.title %>">
                   <% else %>
                     <div class="w-100 h-100 bg-secondary-subtle d-flex align-items-center justify-content-center text-muted">
                       <i class="bi bi-image fs-4"></i>
                     </div>
                   <% end %>
                </div>

                <div class="flex-grow-1">
                  <h5 class="mb-1 fw-bold">
                    <%= link_to item.course.title, course_path(item.course), class: "text-decoration-none text-dark" %>
                  </h5>
                  <p class="mb-0 text-muted small">Instructor: <%= item.course.creator&.name || "Admin" %></p>
                </div>

                <div class="text-end ms-4">
                  <div class="fw-bold fs-5 text-primary mb-2">
                    <%= number_to_currency(item.course.price, unit: "VND", precision: 0, format: "%n %u") %>
                  </div>
                  <%= button_to cart_item_path(item), method: :delete, class: "btn btn-sm btn-outline-danger border-0 p-2", title: "Remove this course" do %>
                    <i class="bi bi-trash"></i> Remove
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card shadow-sm border-0 bg-light">
          <div class="card-body p-4">
            <h5 class="fw-bold mb-3">Order summary</h5>

            <div class="mb-4">
              <label class="form-label small fw-bold">Promo code</label>
              <%= form_with(url: apply_coupon_cart_path, method: :post, class: "input-group input-group-sm") do |f| %>
                <%= f.text_field :promo_code, value: @cart.promo_code, class: "form-control", placeholder: "Enter code..." %>
                <%= f.submit "Apply", class: "btn btn-outline-primary" %>
              <% end %>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="text-muted small">Subtotal:</span>
              <span class="fw-bold">
                <%= number_to_currency(@cart.total_price, unit: "VND", precision: 0, format: "%n %u") %>
              </span>
            </div>

            <% if @cart.discount_amount > 0 %>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-muted small">Discount:</span>
                <span class="text-danger fw-bold">
                  - <%= number_to_currency(@cart.discount_amount, unit: "VND", precision: 0, format: "%n %u") %>
                </span>
              </div>
            <% end %>

            <hr class="my-3 opacity-10">

            <div class="d-flex justify-content-between align-items-center mb-4">
              <span class="fw-bold">Total:</span>
              <span class="fw-bold fs-4 text-primary">
                <%= number_to_currency(@cart.final_total, unit: "VND", precision: 0, format: "%n %u") %>
              </span>
            </div>

            <div class="d-grid">
              <%= button_to checkout_cart_path, method: :post, data: { turbo: false }, class: "btn btn-primary btn-lg fw-bold py-3" do %>
                Checkout now
              <% end %>
            </div>

            <p class="text-center mt-3 small text-muted">
              <i class="bi bi-shield-lock"></i> Secure checkout via Stripe
            </p>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="text-center py-5">
      <div class="mb-3">
        <i class="bi bi-cart-x display-1 text-muted opacity-25"></i>
      </div>
      <h4 class="text-muted">Your cart is empty</h4>
      <p class="mb-4">Find the right course to level up your skills today.</p>
      <%= link_to "Explore courses", courses_path, class: "btn btn-primary px-4 py-2" %>
    </div>
  <% end %>
</div>
