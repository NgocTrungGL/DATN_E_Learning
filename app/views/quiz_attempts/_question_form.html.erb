<%
  all_ids = @all_questions.map(&:id)
  current_index = all_ids.index(question.id)

  prev_id = current_index > 0 ? all_ids[current_index - 1] : nil
  next_id = all_ids[current_index + 1]
%>

<h4 class="mb-4 text-primary fw-bold">Question: <%= question.question_text %></h4>

<%= form_with(model: quiz_answer, url: quiz_attempt_quiz_answers_path(quiz_attempt), id: "question-form") do |f| %>

  <%= f.hidden_field :question_id, value: question.id %>

  <%= hidden_field_tag :next_question_id, next_id %>

  <div class="list-group mb-4">
    <% question.question_options.each do |option| %>
      <% if question.single? %>
        <label class="list-group-item list-group-item-action cursor-pointer p-3 border rounded mb-2 shadow-sm">
          <div class="form-check d-flex align-items-center">
            <%= f.radio_button :question_option_id, option.id,
                  class: "form-check-input me-3 fs-5",
                  style: "cursor: pointer;" %>

            <span class="form-check-label fs-5"><%= option.option_text %></span>
          </div>
        </label>
      <% end %>
    <% end %>
  </div>

  <div class="d-flex justify-content-between mt-4 pt-3 border-top">

    <% if prev_id %>
      <%= link_to quiz_attempt_path(quiz_attempt, question_id: prev_id), class: "btn btn-outline-secondary px-4" do %>
        <i class="bi bi-arrow-left"></i> Previous
      <% end %>
    <% else %>
      <button class="btn btn-outline-secondary px-4" disabled><i class="bi bi-arrow-left"></i> Previous</button>
    <% end %>

    <button type="submit" class="btn btn-primary px-4 fw-bold">
      <% if next_id %>
        Save & Next <i class="bi bi-arrow-right"></i>
      <% else %>
        Save answer <i class="bi bi-check2"></i>
      <% end %>
    </button>

  </div>

<% end %>

<style>
  .cursor-pointer { cursor: pointer; }
  .list-group-item:hover { background-color: #f0f8ff; border-color: #0d6efd; }
  .form-check-input:checked + .form-check-label { font-weight: bold; color: #0d6efd; }
</style>
