<div class="container-fluid py-4 bg-light" style="min-height: 100vh;">

  <div class="d-flex justify-content-between align-items-center mb-4 px-3">
    <h4 class="mb-0 text-primary fw-bold"><i class="bi bi-journals"></i> <%= @quiz.title %></h4>

    <% unless @quiz_is_finished %>
      <button class="btn btn-danger btn-sm fw-bold" data-bs-toggle="modal" data-bs-target="#submitModal">
        <i class="bi bi-check-circle"></i> Submit
      </button>
    <% end %>
  </div>

  <div class="row g-4 px-3">

    <% if @quiz_is_finished %>
      <div class="col-12">
        <div class="card border-0 shadow-sm">
          <div class="card-body p-5">
            <%= render 'results', quiz_attempt: @quiz_attempt %>
          </div>
        </div>
      </div>

    <% else %>
      <div class="col-lg-8">

        <% if @current_question %>

          <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 border-bottom">
              <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                  Question <%= @all_questions.index(@current_question) + 1 %>
                  <span class="text-muted fs-6">/ <%= @all_questions.count %></span>
                </h5>
                <span class="badge bg-info text-dark"><%= @current_question.difficulty.humanize %></span>
              </div>
            </div>

            <div class="card-body p-4">
              <%= render 'question_form',
                    quiz_attempt: @quiz_attempt,
                    question: @current_question,
                    quiz_answer: @quiz_answer %>
            </div>
          </div>

        <% else %>

          <div class="alert alert-warning text-center p-5 shadow-sm border-0">
            <h4><i class="bi bi-exclamation-circle-fill text-warning display-4 d-block mb-3"></i></h4>
            <h5>Question data not found</h5>
            <p class="text-muted">The question may have been deleted or the quiz is not configured correctly.</p>
            <%= link_to "Back", :back, class: "btn btn-outline-dark mt-3" %>
          </div>

        <% end %>

      </div>

      <div class="col-lg-4">

        <div class="card border-0 shadow-sm mb-3">
          <div class="card-body text-center bg-dark text-white rounded">
            <small class="text-uppercase text-white-50 fw-bold">Time remaining</small>
            <div id="quiz-timer" class="display-4 fw-bold my-2">--:--</div>
            <% end_time = @quiz_attempt.started_at + (@quiz.time_limit || 60).minutes %>
            <div id="timer-data" data-end-time="<%= end_time.iso8601 %>"></div>
          </div>
        </div>

        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-bold">Question list</div>
          <div class="card-body">
            <div class="row g-2">
              <% @all_questions.each_with_index do |q, index| %>
                <% is_answered = @answered_ids[q.id] %>
                <% is_current = (q == @current_question) %>

                <div class="col-3 col-sm-2 col-lg-3">
                  <%= link_to quiz_attempt_path(@quiz_attempt, question_id: q.id),
                      class: "btn w-100 py-2 fw-bold position-relative #{is_current ? 'btn-primary border-2 border-dark' : (is_answered ? 'btn-success' : 'btn-outline-secondary')}" do %>

                    <%= index + 1 %>

                    <% if is_current %>
                      <span class="position-absolute top-0 start-100 translate-middle p-1 bg-warning border border-light rounded-circle">
                        <span class="visually-hidden">Current</span>
                      </span>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>

            <div class="mt-3 pt-3 border-top small text-muted d-flex justify-content-between">
              <span><i class="bi bi-square-fill text-success"></i> Answered</span>
              <span><i class="bi bi-square-fill text-primary"></i> In progress</span>
              <span><i class="bi bi-square text-secondary"></i> Unanswered</span>
            </div>
          </div>
        </div>

      </div>
    <% end %>
  </div>
</div>

<% unless @quiz_is_finished %>

  <div class="modal fade" id="submitModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header bg-light">
          <h5 class="modal-title fw-bold text-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> Confirm submission
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body p-4">
          <% count = @unanswered_count || 0 %>

          <% if count > 0 %>
            <div class="text-center">
              <h3 class="text-warning fw-bold display-6 mb-3"><%= count %></h3>
              <p class="fs-5">Some questions are still <strong>unanswered</strong>.</p>
              <p class="text-muted small">If you submit now, these questions will be scored as 0.</p>
            </div>
          <% else %>
            <div class="text-center text-success">
              <i class="bi bi-check-circle-fill display-1 mb-3"></i>
              <p class="fs-5 fw-bold">You have completed all questions!</p>
              <p class="text-muted">Are you sure you want to submit and view the results?</p>
            </div>
          <% end %>
        </div>

        <div class="modal-footer bg-light">
          <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Review</button>
          <%= button_to finish_quiz_attempt_path(@quiz_attempt), method: :patch, class: "btn btn-danger px-4 fw-bold" do %>
            <i class="bi bi-send-check-fill"></i> Submit now
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%= form_with url: finish_quiz_attempt_path(@quiz_attempt), method: :patch, id: "auto-submit-form", class: "d-none" do %>
  <% end %>

  <script>
    document.addEventListener("turbo:load", function() {
      const timerData = document.getElementById("timer-data");
      const timerDisplay = document.getElementById("quiz-timer");

      if (timerData && timerDisplay) {
        const endTime = new Date(timerData.dataset.endTime).getTime();

        const interval = setInterval(function() {
          const now = new Date().getTime();
          const distance = endTime - now;

          if (distance < 0) {
            clearInterval(interval);
            timerDisplay.innerHTML = "00:00";
            timerDisplay.classList.add("text-danger");

            const autoForm = document.getElementById("auto-submit-form");
            if (autoForm) {
               alert("Time is up! The system will submit automatically.");
               autoForm.requestSubmit();
            }
            return;
          }

          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          timerDisplay.innerHTML =
            (minutes < 10 ? "0" + minutes : minutes) + ":" +
            (seconds < 10 ? "0" + seconds : seconds);

          if (distance < 60000) {
              timerDisplay.classList.remove("text-white");
              timerDisplay.classList.add("text-warning");
          }
        }, 1000);
      }
    });
  </script>

<% end %>
