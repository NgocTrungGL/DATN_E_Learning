<%# ============================================================ %>
<%# PROFILE SETTINGS — Standardized UI (No Bootstrap) %>
<%# ============================================================ %>

<div class="profile-settings">

  <%# ── Header ─────────────────────────────────────────────── %>
  <header class="profile-settings__header">
    <div class="profile-settings__inner">
      <h1 class="profile-settings__title">Account settings</h1>
      <p class="profile-settings__subtitle">Manage your personal information and security.</p>
    </div>
  </header>

  <div class="profile-settings__inner">
    <div class="profile-settings__card">

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "profile-settings__form" }) do |f| %>

        <%# ── Errors ─────────────────────────────────────────── %>
        <% if resource.errors.any? %>
          <div class="form-errors mb-4">
            <%= render "devise/shared/error_messages", resource: resource %>
          </div>
        <% end %>

        <%# ── Basic Info ─────────────────────────────────────── %>
        <section class="profile-settings__section">
          <h2 class="profile-settings__section-title">
            <i class="bi bi-person-circle"></i> Basic information
          </h2>

          <div class="profile-settings__field">
            <%= f.label :email, class: "profile-settings__label" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "profile-settings__input", placeholder: "your@email.com" %>

            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <p class="profile-settings__hint">Pending confirmation: <%= resource.unconfirmed_email %></p>
            <% end %>
          </div>
        </section>

        <%# ── Password Settings ───────────────────────────────── %>
        <section class="profile-settings__section">
          <h2 class="profile-settings__section-title">
            <i class="bi bi-shield-lock"></i> Change password
          </h2>

          <div class="profile-settings__field">
            <label class="profile-settings__label">
              New password <i>(leave blank if you do not want to change it)</i>
            </label>
            <%= f.password_field :password, autocomplete: "new-password", class: "profile-settings__input", placeholder: "••••••••" %>
            <% if @minimum_password_length %>
              <span class="profile-settings__hint">Minimum <%= @minimum_password_length %> characters</span>
            <% end %>
          </div>

          <div class="profile-settings__field">
            <%= f.label :password_confirmation, "Confirm new password", class: "profile-settings__label" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "profile-settings__input", placeholder: "••••••••" %>
          </div>
        </section>

        <%# ── Confirmation ────────────────────────────────────── %>
        <section class="profile-settings__section">
          <h2 class="profile-settings__section-title">
            <i class="bi bi-check2-circle"></i> Confirm changes
          </h2>

          <div class="profile-settings__field">
            <label class="profile-settings__label">
              Current password <i>(required to save changes)</i>
            </label>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "profile-settings__input", placeholder: "Enter current password" %>
          </div>
        </section>

        <%# ── Actions ─────────────────────────────────────────── %>
        <div class="profile-settings__actions">
          <%= f.submit "Update account", class: "btn-update" %>
          <%= link_to "Back", :back, class: "btn-back" %>
        </div>

      <% end %>

      <%# ── Dangerous Zone ─────────────────────────────────────── %>
      <div class="profile-settings__danger">
        <h3>Delete account</h3>
        <p>This action cannot be undone. All of your learning progress will be permanently deleted.</p>
        <%= button_to "Delete my account", registration_path(resource_name),
              data: { confirm: "Are you sure you want to delete your account?", turbo_confirm: "Are you absolutely sure?" },
              method: :delete,
              class: "btn-cancel" %>
      </div>

    </div>
  </div>
</div>
