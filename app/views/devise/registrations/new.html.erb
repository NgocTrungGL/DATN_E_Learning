<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card border-0 shadow-lg rounded-3">
        <div class="card-header bg-success text-white text-center py-3">
          <h4 class="fw-bold mb-0"><i class="bi bi-person-plus-fill me-2"></i>Đăng Ký Tài Khoản</h4>
        </div>

        <div class="card-body p-4 bg-light">
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <div class="form-floating mb-3">
              <%= f.text_field :name, autofocus: true, class: "form-control", id: "floatingName", placeholder: "Nguyễn Văn A" %>
              <%= f.label :name, "Họ và tên", for: "floatingName" %>
            </div>

            <div class="form-floating mb-3">
              <%= f.email_field :email, autocomplete: "email", class: "form-control", id: "floatingInput", placeholder: "name@example.com" %>
              <%= f.label :email, "Địa chỉ Email", for: "floatingInput" %>
            </div>

            <div class="form-floating mb-3">
              <%= f.password_field :password, autocomplete: "new-password", class: "form-control", id: "floatingPassword", placeholder: "Password" %>
              <%= f.label :password, "Mật khẩu (#{(@minimum_password_length.to_s + ' ký tự tối thiểu') if @minimum_password_length})", for: "floatingPassword" %>
            </div>

            <div class="form-floating mb-3">
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", id: "floatingConfirmPassword", placeholder: "Password" %>
              <%= f.label :password_confirmation, "Nhập lại mật khẩu", for: "floatingConfirmPassword" %>
            </div>

            <div class="d-grid gap-2 mt-4">
              <%= f.button type: "submit", class: "btn btn-success btn-lg fw-bold" do %>
                Đăng ký ngay
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="card-footer bg-white text-center py-3 small">
          Đã có tài khoản?
          <%= link_to "Đăng nhập", new_session_path(resource_name), class: "text-decoration-none fw-bold" %>
        </div>
      </div>
    </div>
  </div>
</div>
