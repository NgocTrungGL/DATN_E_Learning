<%# Check if this message should be grouped with the previous one %>
<% is_grouped = message.same_group_as?(previous_message) %>

<div class="chat-msg <%= 'chat-msg--grouped' if is_grouped %>" id="<%= dom_id(message) %>">
  <% unless is_grouped %>
    <div class="chat-msg__gutter">
      <div class="chat-msg__avatar">
        <%= message.author_initial %>
      </div>
    </div>
  <% end %>

  <div class="chat-msg__body">
    <% unless is_grouped %>
      <div class="chat-msg__header">
        <span class="chat-msg__author-name">
          <%= message.author_name %>
          <% if message.instructor_message? %>
            <span class="chat-msg__badge chat-msg__badge--instructor">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M23,12L20.56,9.22L20.9,5.54L17.29,4.72L15.4,1.54L12,3L8.6,1.54L6.71,4.72L3.1,5.53L3.44,9.21L1,12L3.44,14.78L3.1,18.47L6.71,19.29L8.6,22.47L12,21L15.4,22.46L17.29,19.28L20.91,18.46L20.56,14.78L23,12M10,17L6,13L7.41,11.59L10,14.17L16.59,7.58L18,9L10,17Z"/></svg>
              Giảng viên
            </span>
          <% end %>
        </span>
        <span class="chat-msg__timestamp"><%= message.created_at.strftime("%H:%M") %></span>
      </div>
    <% else %>
      <%# Show tiny timestamp on hover for grouped messages %>
      <span class="chat-msg__tiny-time"><%= message.created_at.strftime("%H:%M") %></span>
    <% end %>

    <div class="chat-msg__content">
      <%= simple_format(message.content) %>
    </div>
  </div>

  <%# Delete action for owner or instructor %>
  <% if current_user == message.user || current_user.admin? || course.created_by == current_user.id %>
    <div class="chat-msg__actions">
      <%= button_to course_discussion_message_path(course, message),
            method: :delete,
            class: "chat-msg__action-btn chat-msg__action-btn--delete",
            data: { turbo_confirm: "Xóa tin nhắn này?" } do %>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
      <% end %>
    </div>
  <% end %>
</div>
