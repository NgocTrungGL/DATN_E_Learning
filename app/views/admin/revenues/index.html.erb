<%# Admin Revenues Index — Bootstrap-free BEM redesign %>
<%# Chartkick helpers: line_chart, pie_chart — kept as-is %>

<div class="admin-page-header">
  <div class="admin-page-header__inner">
    <div>
      <div class="admin-page-header__badge"><i class="bi bi-cash-coin"></i> Tài chính</div>
      <h1 class="admin-page-header__title">Tài chính Hệ thống</h1>
    </div>
  </div>
</div>

<div class="admin-page-body">

  <%# ── Financial Summary Widgets ─────────────────────────── %>
  <div class="admin-stats">
    <div class="admin-stats__card admin-stats__card--accent">
      <i class="bi bi-safe2-fill admin-stats__icon"></i>
      <div class="admin-stats__value">
        <%= number_to_currency(@wallet.balance, unit: "₫", precision: 0, format: "%n %u") %>
      </div>
      <div class="admin-stats__label">Ví Admin (30% Phí)</div>
      <div style="font-size:0.75rem; color:#94a3b8; margin-top:0.25rem;">Số tiền thực tế bạn có thể rút</div>
    </div>

    <div class="admin-stats__card admin-stats__card--success">
      <i class="bi bi-graph-up-arrow admin-stats__icon"></i>
      <div class="admin-stats__value">
        <%= number_to_currency(@total_platform_revenue, unit: "₫", precision: 0, format: "%n %u") %>
      </div>
      <div class="admin-stats__label">Tổng doanh thu (Lifetime)</div>
      <div style="font-size:0.75rem; color:#94a3b8; margin-top:0.25rem;">Tổng phí 30% đã thu từ trước đến nay</div>
    </div>

    <div class="admin-stats__card admin-stats__card--warning">
      <i class="bi bi-bank admin-stats__icon"></i>
      <div class="admin-stats__value">
        <%= number_to_currency(@total_system_balance, unit: "₫", precision: 0, format: "%n %u") %>
      </div>
      <div class="admin-stats__label">Tổng System Hold</div>
      <div style="font-size:0.75rem; color:#94a3b8; margin-top:0.25rem;">Tổng số dư tất cả ví (Admin + GV)</div>
    </div>
  </div>

  <%# ── Charts ────────────────────────────────────────────── %>
  <div style="display:grid; grid-template-columns:1fr 380px; gap:1.5rem; margin-bottom:2rem;">
    <div class="admin-card">
      <div class="admin-card__header">
        <h5><i class="bi bi-bar-chart-line" style="color:#0d9488;"></i> Biểu đồ doanh thu (30 ngày gần nhất)</h5>
      </div>
      <div class="admin-card__body">
        <%= line_chart @revenue_chart_data, prefix: "₫", thousands: ",", colors: ["#0d9488"], height: "300px", empty: "Chưa có dữ liệu doanh thu" %>
      </div>
    </div>

    <div class="admin-card">
      <div class="admin-card__header">
        <h5><i class="bi bi-pie-chart-fill" style="color:#10b981;"></i> Top khóa học bán chạy</h5>
      </div>
      <div class="admin-card__body">
        <%= pie_chart @top_courses_data, donut: true, height: "300px", empty: "Chưa có dữ liệu" %>
      </div>
    </div>
  </div>

  <%# ── Revenue Transaction Log ───────────────────────────── %>
  <div class="admin-card">
    <div class="admin-card__header">
      <h5><i class="bi bi-journal-text" style="color:#2563eb;"></i> Nhật ký doanh thu (Platform Fee)</h5>
    </div>
    <div style="overflow:hidden;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Mã GD</th>
            <th>Loại giao dịch</th>
            <th>Số tiền (30%)</th>
            <th>Nguồn gốc</th>
            <th>Thời gian</th>
          </tr>
        </thead>
        <tbody>
          <% @transactions.each do |txn| %>
            <tr>
              <td style="font-family:monospace; color:#94a3b8; font-size:0.8rem;">#<%= txn.id %></td>
              <td>
                <% if txn.platform_fee? %>
                  <span class="admin-badge admin-badge--info"><i class="bi bi-pie-chart-fill"></i> Phí nền tảng</span>
                <% else %>
                  <span class="admin-badge admin-badge--neutral"><%= txn.transaction_type %></span>
                <% end %>
              </td>
              <td style="font-weight:800; font-size:1.05rem; color:#10b981;">
                +<%= number_to_currency(txn.amount, unit: "₫", precision: 0, format: "%n %u") %>
              </td>
              <td>
                <% if txn.source.is_a?(Enrollment) %>
                  <div class="admin-table__title"><%= txn.source.course.title %></div>
                  <div class="admin-table__sub">
                    Giá gốc: <%= number_to_currency(txn.source.price, unit: "₫", precision: 0) %>
                    | HV: <%= txn.source.user.name %>
                  </div>
                <% end %>
              </td>
              <td class="admin-table__sub"><%= txn.created_at.strftime("%d/%m/%Y %H:%M") %></td>
            </tr>
          <% end %>

          <% if @transactions.empty? %>
            <tr>
              <td colspan="5">
                <div class="admin-table__empty">
                  <i class="bi bi-cash-coin"></i>
                  <p>Chưa có doanh thu nào.</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="admin-pagination">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>

</div>
