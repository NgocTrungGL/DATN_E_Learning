<%# Admin Instructor Profiles Index — Bootstrap-free BEM redesign %>

<div class="admin-page-header">
  <div class="admin-page-header__inner">
    <div>
      <div class="admin-page-header__badge"><i class="bi bi-person-lines-fill"></i> System</div>
      <h1 class="admin-page-header__title">Instructor Approvals</h1>
    </div>
  </div>
</div>

<div class="admin-page-body">
  <div class="admin-table-wrapper">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Applicant</th>
          <th>Contact</th>
          <th>CV</th>
          <th>Status</th>
          <th style="text-align: right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @instructor_profiles.each do |profile| %>
          <tr>
            <td>
              <div class="admin-table__title"><%= profile.user.name %></div>
              <div class="admin-table__sub"><%= profile.user.email %></div>
            </td>
            <td>
              <div class="admin-table__sub">Phone: <%= profile.phone %></div>
              <% if profile.linkedin_url.present? %>
                <div class="admin-table__sub">
                  <%= link_to "LinkedIn →", profile.linkedin_url, target: "_blank", style: "color: #2563eb; text-decoration: none; font-size: 0.78rem;" %>
                </div>
              <% end %>
            </td>
            <td>
              <%= link_to profile.cv_url, target: "_blank", class: "btn-action btn-action--info" do %>
                <i class="bi bi-file-earmark-person"></i> View CV
              <% end %>
            </td>
            <td>
              <% if profile.pending? %>
                <span class="admin-badge admin-badge--warning"><i class="bi bi-hourglass"></i> Pending</span>
              <% elsif profile.approved? %>
                <span class="admin-badge admin-badge--success"><i class="bi bi-check-circle"></i> Approved</span>
              <% else %>
                <span class="admin-badge admin-badge--danger"><i class="bi bi-x-circle"></i> Rejected</span>
              <% end %>
            </td>
            <td>
              <div class="admin-table__actions">
                <% if profile.pending? %>
                  <%= button_to "Approve", approve_admin_instructor_path(profile), method: :patch,
                        class: "btn-action btn-action--success" do %>
                    <i class="bi bi-check-lg"></i> Approve
                  <% end %>
                  <%= button_to "Reject", reject_admin_instructor_path(profile), method: :patch,
                        class: "btn-action btn-action--danger" do %>
                    <i class="bi bi-x-lg"></i> Reject
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>

        <% if @instructor_profiles.empty? %>
          <tr>
            <td colspan="5">
              <div class="admin-table__empty">
                <i class="bi bi-person-badge"></i>
                <p>No instructor applications awaiting review.</p>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
