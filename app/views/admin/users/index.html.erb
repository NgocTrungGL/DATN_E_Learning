<h2 class="mb-4">Quản lý Người dùng</h2>

<div class="table-responsive">
  <table class="table table-hover border align-middle">
    <thead class="table-light">
      <tr>
        <th>Avatar</th>
        <th>Thông tin</th>
        <th>Vai trò</th>
        <th>Ngày tham gia</th>
        <th>Hành động</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td>
            <img src="<%= user.avatar_url.presence || "https://ui-avatars.com/api/?name=#{user.name}&background=random" %>"
                 class="rounded-circle" width="40" height="40">
          </td>
          <td>
            <div class="fw-bold"><%= user.name %></div>
            <div class="text-muted small"><%= user.email %></div>
          </td>
          <td>
            <% if user.admin? %>
              <span class="badge bg-danger">Admin</span>
            <% else %>
              <span class="badge bg-primary">Học viên</span>
            <% end %>
          </td>
          <td><%= user.created_at.strftime("%d/%m/%Y") %></td>
          <td>
            <% if user != current_user %>
              <%= button_to admin_user_path(user), method: :delete,
                    class: "btn btn-sm btn-outline-danger",
                    data: { confirm: "Bạn có chắc muốn xóa user này?" } do %>
                <i class="bi bi-trash"></i> Xóa
              <% end %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% if @pagy.pages > 1 %>
  <div class="d-flex justify-content-center mt-4">
    <%== pagy_bootstrap_nav(@pagy) %>
  </div>

  <div class="text-center text-muted small mt-2">
    Hiển thị <b><%= @pagy.items %></b> tài khoản / trang
    (Tổng <b><%= @pagy.count %></b> người dùng)
  </div>
<% end %>
