<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 fw-bold mb-0">Hàng chờ kiểm duyệt</h1>
      <p class="text-muted small">Danh sách các khóa học đang chờ Admin phê duyệt.</p>
    </div>

    <div class="bg-white p-2 rounded shadow-sm border">
      <span class="text-muted small text-uppercase fw-bold me-2">Tổng chờ xử lý:</span>
      <span class="badge bg-danger rounded-pill fs-6"><%= Course.pending.count %></span>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="bg-light text-secondary small text-uppercase">
            <tr>
              <th scope="col" class="ps-4" style="width: 40%;">Thông tin khóa học</th>
              <th scope="col" style="width: 20%;">Giảng viên</th>
              <th scope="col" style="width: 15%;">Thời gian gửi</th>
              <th scope="col" class="text-end pe-4" style="width: 25%;">Hành động</th>
            </tr>
          </thead>
          <tbody>
            <% if @pending_courses.any? %>
              <% @pending_courses.each do |course| %>
                <tr>
                  <td class="ps-4 py-3">
                    <div class="d-flex align-items-start">
                      <div class="position-relative me-3">
                        <img src="<%= course.thumbnail_url.presence || 'https://via.placeholder.com/80x50' %>"
                             class="rounded border shadow-sm"
                             style="width: 100px; height: 60px; object-fit: cover;">
                        <span class="position-absolute top-0 start-0 translate-middle badge rounded-pill bg-warning text-dark border border-light shadow-sm">
                          Pending
                        </span>
                      </div>

                      <div>
                        <h6 class="fw-bold mb-1 text-dark">
                          <%= link_to truncate(course.title, length: 60), admin_course_path(course), class: "text-decoration-none text-dark", target: "_blank" %>
                        </h6>
                        <div class="text-muted small mb-1">
                          <i class="bi bi-tag-fill me-1"></i> <%= course.category&.name || "Chưa phân loại" %>
                          <span class="mx-1">•</span>
                          <span class="text-primary fw-bold">
                            <%= course.free? ? "Miễn phí" : number_to_currency(course.price, unit: '₫', precision: 0) %>
                          </span>
                        </div>
                      </div>
                    </div>
                  </td>

                  <td>
                    <div class="d-flex align-items-center">
                      <div class="avatar-wrapper avatar-xs me-2">
                        <% if course.creator.avatar_url.present? %>
                          <img src="<%= course.creator.avatar_url %>" class="avatar-img rounded-circle border">
                        <% else %>
                          <div class="avatar-text rounded-circle bg-light text-secondary border small">
                            <%= course.creator.name.first.upcase %>
                          </div>
                        <% end %>
                      </div>
                      <div>
                        <div class="small fw-bold"><%= course.creator.name %></div>
                        <div class="small text-muted" style="font-size: 0.75rem;"><%= course.creator.email %></div>
                      </div>
                    </div>
                  </td>

                  <td>
                    <div class="small text-dark fw-bold">
                      <%= time_ago_in_words(course.updated_at) %> trước
                    </div>
                    <div class="small text-muted" style="font-size: 0.75rem;">
                      <%= course.updated_at.strftime("%H:%M - %d/%m/%Y") %>
                    </div>
                  </td>

                  <td class="text-end pe-4">
                    <div class="d-flex justify-content-end gap-2">
                      <%= link_to admin_course_path(course), class: "btn btn-outline-secondary btn-sm", target: "_blank", title: "Xem nội dung chi tiết" do %>
                        <i class="bi bi-eye"></i> Xem
                      <% end %>

                      <%= button_to approve_admin_course_review_path(course),
                          method: :patch,
                          class: "btn btn-success btn-sm fw-bold",
                          data: { confirm: "Xác nhận duyệt khóa học này và công khai lên hệ thống?" } do %>
                        <i class="bi bi-check-lg"></i> Duyệt
                      <% end %>

                      <%= button_to reject_admin_course_review_path(course),
                          method: :patch,
                          class: "btn btn-danger btn-sm",
                          title: "Từ chối khóa học này",
                          data: { confirm: "Bạn có chắc muốn từ chối khóa học này không?" } do %>
                        <i class="bi bi-x-lg"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="4" class="text-center py-5">
                  <div class="d-flex flex-column align-items-center justify-content-center text-muted">
                    <div class="bg-light rounded-circle p-4 mb-3">
                      <i class="bi bi-check2-all fs-1 text-success"></i>
                    </div>
                    <h5 class="fw-bold">Tuyệt vời!</h5>
                    <p class="mb-0">Không có khóa học nào đang chờ duyệt.</p>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="card-footer bg-white py-3 border-top-0 d-flex justify-content-end">
        <%== pagy_bootstrap_nav(@pagy) %>
      </div>
    <% end %>
  </div>
</div>
