<%# Admin Course Reviews — Premium BEM Redesign %>
<%# Pattern consistent with crs-page / cat-page design system %>

<div class="rev-page">

  <%# ── Page Header ─────────────────────────────────────────── %>
  <header class="rev-page__header">
    <div class="rev-page__header-left">
      <div class="rev-page__breadcrumb">
        <i class="bi bi-shield-check"></i>
        <span>Content Moderation</span>
      </div>
      <h1 class="rev-page__title">Review Queue</h1>
      <p class="rev-page__subtitle">Courses awaiting admin approval before going public on the platform.</p>
    </div>

    <div class="rev-page__header-right">
      <div class="rev-page__stat-pill">
        <i class="bi bi-hourglass-split"></i>
        <strong><%= Course.pending.count %></strong>
        <span>Pending</span>
      </div>
    </div>
  </header>

  <%# ── Table Card ───────────────────────────────────────────── %>
  <% if @pending_courses.any? %>
    <div class="rev-table-card">
      <table class="rev-table">
        <thead>
          <tr>
            <th class="rev-table__th">
              <i class="bi bi-play-circle"></i> Course
            </th>
            <th class="rev-table__th rev-table__th--instructor">
              <i class="bi bi-person-fill"></i> Instructor
            </th>
            <th class="rev-table__th rev-table__th--time">
              <i class="bi bi-clock"></i> Submitted
            </th>
            <th class="rev-table__th rev-table__th--actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @pending_courses.each do |course| %>
            <tr class="rev-table__row">

              <%# Course cell %>
              <td class="rev-table__td">
                <div class="rev-table__course-cell">
                  <div class="rev-table__thumb">
                    <% if course.thumbnail_url.present? %>
                      <img src="<%= course.thumbnail_url %>" class="rev-table__thumb-img" alt="<%= course.title %>">
                    <% else %>
                      <div class="rev-table__thumb-placeholder">
                        <i class="bi bi-play-circle-fill"></i>
                      </div>
                    <% end %>
                    <span class="rev-table__status-badge">Pending</span>
                  </div>
                  <div class="rev-table__course-info">
                    <span class="rev-table__course-title">
                      <%= link_to truncate(course.title, length: 72), admin_course_path(course),
                          target: '_blank', class: 'rev-table__course-link' %>
                    </span>
                    <span class="rev-table__course-meta">
                      <i class="bi bi-tag-fill"></i>
                      <%= course.category&.name || 'Uncategorized' %>
                      <span class="rev-table__dot">·</span>
                      <span class="rev-table__price">
                        <%= course.free? ? 'Free' : number_to_currency(course.price, unit: '₫', precision: 0) %>
                      </span>
                    </span>
                  </div>
                </div>
              </td>

              <%# Instructor cell %>
              <td class="rev-table__td rev-table__td--instructor">
                <div class="rev-table__instructor">
                  <div class="rev-table__avatar">
                    <% if course.creator.avatar_url.present? %>
                      <img src="<%= course.creator.avatar_url %>" class="rev-table__avatar-img" alt="<%= course.creator.name %>">
                    <% else %>
                      <span class="rev-table__avatar-text"><%= course.creator.name.first.upcase %></span>
                    <% end %>
                  </div>
                  <div>
                    <p class="rev-table__instructor-name"><%= course.creator.name %></p>
                    <p class="rev-table__instructor-email"><%= course.creator.email %></p>
                  </div>
                </div>
              </td>

              <%# Time cell %>
              <td class="rev-table__td rev-table__td--time">
                <p class="rev-table__time-ago"><%= time_ago_in_words(course.updated_at) %> ago</p>
                <p class="rev-table__time-abs"><%= course.updated_at.strftime('%H:%M · %d/%m/%Y') %></p>
              </td>

              <%# Actions cell %>
              <td class="rev-table__td rev-table__td--actions">
                <div class="rev-table__action-group">
                  <%= link_to admin_course_path(course),
                      class: 'rev-btn rev-btn--view',
                      target: '_blank',
                      title: 'View course detail' do %>
                    <i class="bi bi-eye"></i>
                    <span>View</span>
                  <% end %>

                  <%= button_to approve_admin_course_review_path(course),
                      method: :patch,
                      class: 'rev-btn rev-btn--approve',
                      data: { confirm: 'Approve this course and make it public?' } do %>
                    <i class="bi bi-check-lg"></i>
                    <span>Approve</span>
                  <% end %>

                  <%= button_to reject_admin_course_review_path(course),
                      method: :patch,
                      class: 'rev-btn rev-btn--reject',
                      data: { confirm: 'Are you sure you want to reject this course?' } do %>
                    <i class="bi bi-x-lg"></i>
                    <span>Reject</span>
                  <% end %>
                </div>
              </td>

            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rev-empty">
      <div class="rev-empty__icon">
        <i class="bi bi-check2-all"></i>
      </div>
      <h2>All Clear!</h2>
      <p>No courses are currently pending review.</p>
    </div>
  <% end %>

  <%# ── Pagination ───────────────────────────────────────────── %>
  <% if @pagy.pages > 1 %>
    <div class="rev-pagination">
      <div class="rev-pagination__nav"><%== pagy_nav(@pagy) %></div>
    </div>
  <% end %>

</div>
