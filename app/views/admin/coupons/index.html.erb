<div class="cat-page">
  <header class="cat-page__header">
    <div class="cat-page__header-left">
      <div class="cat-page__breadcrumb">
        <i class="bi bi-ticket-perforated-fill"></i>
        <span>Promotions</span>
      </div>
      <h1 class="cat-page__title">Coupon management</h1>
      <p class="cat-page__subtitle">Create and manage promotions sitewide or for specific courses.</p>
    </div>

    <div class="cat-page__header-right">
      <%= link_to new_admin_coupon_path, class: 'cat-page__cta' do %>
        <i class="bi bi-plus-lg"></i>
        <span>Add new code</span>
      <% end %>
    </div>
  </header>

  <div class="cat-table-card">
    <table class="cat-table">
      <thead>
        <tr>
          <th class="cat-table__th">Code</th>
          <th class="cat-table__th">Type</th>
          <th class="cat-table__th">Value</th>
          <th class="cat-table__th">Scope</th>
          <th class="cat-table__th">Validity</th>
          <th class="cat-table__th">Status</th>
          <th class="cat-table__th">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if @coupons.any? %>
          <% @coupons.each do |coupon| %>
            <tr class="cat-table__row">
              <td class="cat-table__td">
                <span class="fw-bold text-primary"><%= coupon.code %></span>
              </td>
              <td class="cat-table__td">
                <%= coupon.percentage? ? "Percentage (%)" : "Fixed amount (VND)" %>
              </td>
              <td class="cat-table__td">
                <%= coupon.percentage? ? "#{coupon.discount_value}%" : number_to_currency(coupon.discount_value, unit: "VND", precision: 0, format: "%n %u") %>
              </td>
              <td class="cat-table__td">
                <% if coupon.global? %>
                  <span class="badge bg-info-subtle text-info border border-info-subtle">Sitewide</span>
                <% else %>
                  <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Course-specific</span>
                  <div class="small text-muted mt-1"><%= coupon.course&.title&.truncate(30) %></div>
                <% end %>
              </td>
              <td class="cat-table__td">
                <div class="small">From: <%= coupon.start_at.strftime("%d/%m/%Y") %></div>
                <div class="small">To: <%= coupon.end_at.strftime("%d/%m/%Y") %></div>
              </td>
              <td class="cat-table__td">
                <% if coupon.active? && coupon.active_and_current? %>
                  <span class="badge bg-success">Active</span>
                <% elsif coupon.inactive? %>
                  <span class="badge bg-secondary">Inactive</span>
                <% elsif coupon.expired? %>
                  <span class="badge bg-danger">Expired</span>
                <% else %>
                  <span class="badge bg-primary">Pending start</span>
                <% end %>
              </td>
              <td class="cat-table__td">
                <div class="cat-table__action-group">
                  <%= link_to edit_admin_coupon_path(coupon), class: 'cat-btn cat-btn--edit' do %>
                    <i class="bi bi-pencil-fill"></i>
                  <% end %>
                  <%= link_to admin_coupon_path(coupon), data: { turbo_method: :delete, turbo_confirm: "Confirm delete this code?" }, class: 'cat-btn cat-btn--delete' do %>
                    <i class="bi bi-trash-fill"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="7">
              <div class="cat-table__empty">
                <i class="bi bi-ticket-perforated display-4 opacity-25"></i>
                <h3>No coupons yet</h3>
                <p>Create the first code to attract learners.</p>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
