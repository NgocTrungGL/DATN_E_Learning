<%# Admin Courses Index — Premium Table-based Redesign %>

<div class="crs-page">

  <%# ── Page Header ──────────────────────────────────────────── %>
  <header class="crs-page__header">
    <div class="crs-page__header-left">
      <div class="crs-page__breadcrumb">
        <i class="bi bi-collection-play-fill"></i>
        <span><%= t('admin.courses.index.eyebrow') %></span>
      </div>
      <h1 class="crs-page__title"><%= t('admin.courses.index.title') %></h1>
      <p class="crs-page__subtitle"><%= t('admin.courses.index.subtitle') %></p>
    </div>

    <div class="crs-page__header-right">
      <div class="crs-page__stat-pill">
        <i class="bi bi-journal-bookmark-fill"></i>
        <strong><%= @pagy&.count || @courses.size %></strong>
        <span><%= t('admin.courses.index.counter_suffix') %></span>
      </div>

      <%= link_to new_admin_course_path, class: 'crs-page__cta' do %>
        <i class="bi bi-plus-lg"></i>
        <span><%= t('admin.courses.index.new_course') %></span>
      <% end %>
    </div>
  </header>

  <%# ── Table Card ───────────────────────────────────────────── %>
  <% if @courses.any? %>
    <div class="crs-table-card">
      <table class="crs-table">
        <thead>
          <tr>
            <th class="crs-table__th crs-table__th--course">
              <i class="bi bi-play-circle"></i> Course
            </th>
            <th class="crs-table__th crs-table__th--category">
              <i class="bi bi-tag"></i> Category
            </th>
            <th class="crs-table__th crs-table__th--price">
              <i class="bi bi-currency-dollar"></i> Price
            </th>
            <th class="crs-table__th crs-table__th--actions">
              <%= t('admin.courses.index.actions') %>
            </th>
          </tr>
        </thead>
        <tbody>
          <% @courses.each do |course| %>
            <tr class="crs-table__row">

              <%# Course info cell %>
              <td class="crs-table__td crs-table__td--course">
                <div class="crs-table__course-cell">
                  <div class="crs-table__thumb">
                    <% if course.thumbnail_url.present? %>
                      <img src="<%= course.thumbnail_url %>" alt="<%= course.title %>" class="crs-table__thumb-img">
                    <% else %>
                      <div class="crs-table__thumb-placeholder">
                        <i class="bi bi-play-circle-fill"></i>
                      </div>
                    <% end %>
                  </div>
                  <div class="crs-table__course-info">
                    <span class="crs-table__course-title">
                      <%= link_to course.title, admin_course_path(course), class: 'crs-table__course-link' %>
                    </span>
                    <span class="crs-table__course-desc">
                      <%= course.description.present? ? truncate(course.description, length: 70) : "No description yet" %>
                    </span>
                  </div>
                </div>
              </td>

              <%# Category %>
              <td class="crs-table__td crs-table__td--category">
                <span class="crs-table__cat-badge">
                  <%= course.category&.name || t('admin.courses.index.uncategorized') %>
                </span>
              </td>

              <%# Price %>
              <td class="crs-table__td crs-table__td--price">
                <% if course.price.present? && course.price > 0 %>
                  <span class="crs-table__price"><%= number_with_delimiter(course.price.to_i) %>&nbsp;VND</span>
                <% else %>
                  <span class="crs-table__price-free">Free</span>
                <% end %>
              </td>

              <%# Actions — icon-only buttons with title tooltip %>
              <td class="crs-table__td crs-table__td--actions">
                <div class="crs-table__action-group">
                  <%= link_to admin_course_path(course), class: 'crs-btn crs-btn--view', title: 'View details' do %>
                    <%= image_tag 'view.png', class: 'crs-btn__img', alt: 'View' %>
                  <% end %>
                  <%= link_to new_admin_course_course_module_path(course), class: 'crs-btn crs-btn--module', title: 'Add module' do %>
                    <%= image_tag 'add.png', class: 'crs-btn__img', alt: 'Add module' %>
                  <% end %>
                  <%= link_to edit_admin_course_path(course), class: 'crs-btn crs-btn--edit', title: 'Edit' do %>
                    <%= image_tag 'edit.png', class: 'crs-btn__img', alt: 'Edit' %>
                  <% end %>
                  <%= link_to admin_course_path(course),
                      data: { turbo_method: :delete, turbo_confirm: t('admin.courses.index.confirm_delete') },
                      class: 'crs-btn crs-btn--delete', title: 'Delete' do %>
                    <%= image_tag 'delete.png', class: 'crs-btn__img', alt: 'Delete' %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="crs-empty">
      <div class="crs-empty__icon">
        <i class="bi bi-journal-bookmark"></i>
      </div>
      <h3><%= t('admin.courses.index.empty_title') %></h3>
      <p><%= t('admin.courses.index.empty_text') %></p>
      <%= link_to new_admin_course_path, class: 'crs-page__cta' do %>
        <i class="bi bi-plus-lg"></i>
        <span><%= t('admin.courses.index.new_course') %></span>
      <% end %>
    </div>
  <% end %>

  <%# ── Pagination ───────────────────────────────────────────── %>
  <% if @pagy.pages > 1 %>
    <div class="crs-pagination">
      <div class="crs-pagination__nav"><%== pagy_nav(@pagy) %></div>
      <p class="crs-pagination__note">
        <%= t('admin.courses.index.pagination_note', items: @pagy.items, count: @pagy.count) %>
      </p>
    </div>
  <% end %>

</div>
