<%# Admin Courses Form Partial — Premium BEM Redesign %>
<%# Preserves: form_with model, local:true, collection_select Category, input-group price %>

<%= form_with(model: [:admin, @course], local: true) do |form| %>

  <%# ── Validation errors ──────────────────────────────────────── %>
  <% if @course.errors.any? %>
    <div class="crs-form__errors">
      <i class="bi bi-exclamation-triangle-fill crs-form__errors-icon"></i>
      <div>
        <strong class="crs-form__errors-title">
          <%= t('admin.courses.form.errors_title', count: @course.errors.count) %>
        </strong>
        <ul class="crs-form__errors-list">
          <% @course.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <%# ── Form card ─────────────────────────────────────────────── %>
  <div class="crs-form__card">
    <div class="crs-form__card-header">
      <div class="crs-form__card-icon">
        <i class="bi bi-journal-plus"></i>
      </div>
      <div>
        <h2 class="crs-form__card-title">Course information</h2>
        <p class="crs-form__card-subtitle">Provide the details to create or update the course.</p>
      </div>
    </div>

    <div class="crs-form__card-body">

      <%# 2-column grid for main fields %>
      <div class="crs-form__grid">

        <%# Title %>
        <div class="crs-form__field crs-form__field--full">
          <label class="crs-form__label crs-form__label--required">
            <i class="bi bi-pencil-fill"></i>
            <%= t('admin.courses.form.title') %>
          </label>
          <%= form.text_field :title,
              class: 'crs-form__input',
              required: true,
              placeholder: "e.g., Ruby on Rails from scratch..." %>
            <span class="crs-form__hint">The course title will be shown publicly.</span>
        </div>

        <%# Category %>
        <div class="crs-form__field">
          <label class="crs-form__label">
            <i class="bi bi-tag-fill"></i>
            <%= t('admin.courses.form.category') %>
          </label>
          <%= form.collection_select :category_id, Category.order(:name), :id, :name,
                { include_blank: t('admin.courses.form.none') },
                class: 'crs-form__select' %>
        </div>

        <%# Price %>
        <div class="crs-form__field">
          <label class="crs-form__label">
            <i class="bi bi-cash-coin"></i>
            <%= t('admin.courses.form.price_label') %>
          </label>
          <div class="crs-form__price-group">
            <%= form.number_field :price,
                class: 'crs-form__input',
                step: 1000,
                min: 0,
                placeholder: t('admin.courses.form.price_placeholder') %>
            <span class="crs-form__price-suffix">VND</span>
          </div>
          <span class="crs-form__hint"><%= t('admin.courses.form.price_hint') %></span>
        </div>

        <%# Thumbnail URL %>
        <div class="crs-form__field crs-form__field--full">
          <label class="crs-form__label">
            <i class="bi bi-image-fill"></i>
            <%= t('admin.courses.form.thumbnail_url') %>
          </label>
          <%= form.text_field :thumbnail_url,
              class: 'crs-form__input',
              placeholder: t('admin.courses.form.thumbnail_placeholder') %>
          <span class="crs-form__hint">Enter a cover image URL for the course (16:9 recommended).</span>
        </div>

        <%# Description %>
        <div class="crs-form__field crs-form__field--full">
          <label class="crs-form__label">
            <i class="bi bi-text-paragraph"></i>
            <%= t('admin.courses.form.description') %>
          </label>
          <%= form.text_area :description,
              class: 'crs-form__textarea',
              rows: 5,
              placeholder: "Briefly describe the course content and benefits..." %>
        </div>

      </div>
    </div>

    <%# ── Form actions ─────────────────────────────────────────  %>
    <div class="crs-form__actions">
      <%= link_to admin_courses_path, class: 'crs-form__btn crs-form__btn--cancel' do %>
        <i class="bi bi-x-lg"></i>
        <%= t('admin.courses.form.back') %>
      <% end %>
      <%= form.submit t('admin.courses.form.submit'), class: 'crs-form__btn crs-form__btn--save' %>
    </div>
  </div>

<% end %>
