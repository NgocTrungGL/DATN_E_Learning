<div class="admin-container">

  <div class="card mb-4 p-4 shadow-sm">
    <div class="course-hero">

      <img src="<%= @course.thumbnail_url.presence || 'https://via.placeholder.com/800x400' %>"
           class="course-thumb"
           alt="<%= @course.title %>">

      <div>
        <h2 class="fw-bold mb-1"><%= @course.title %></h2>
        <p class="text-muted mb-2">
          <%= @course.category&.name || t('admin.courses.show.uncategorized') %>
        </p>
        <p><%= @course.description %></p>

        <div class="course-actions mt-3">
          <%= link_to t('admin.courses.show.add_module'),
                new_admin_course_course_module_path(@course),
                class: "btn btn-primary" %>

          <%= link_to t('admin.courses.show.edit_course'),
                edit_admin_course_path(@course),
                class: "btn btn-warning" %>

          <%= link_to t('admin.courses.show.delete_course'),
                admin_course_path(@course),
                data: { turbo_method: :delete, turbo_confirm: t('admin.courses.show.confirm_delete_course') },
                class: "btn btn-danger" %>

          <%= link_to t('admin.courses.show.back_to_list'),
                admin_courses_path,
                class: "btn btn-outline-secondary mt-2" %>
        </div>
      </div>

    </div>
  </div>
<div class="card shadow-sm">
  <div class="card-header fw-bold">
    <%= t('admin.courses.show.content_admin') %>
  </div>

  <div class="card-body p-3">
    <div class="accordion" id="courseContentAccordion">

      <% @course.course_modules.each_with_index do |module_item, index| %>
        <div class="accordion-item mb-2">
          <h2 class="accordion-header">
            <button class="accordion-button <%= 'collapsed' if index > 0 %>"
                    data-bs-toggle="collapse"
                    data-bs-target="#module-<%= module_item.id %>">
              <div class="module-header w-100">
                <span><%= module_item.title %></span>
                <small class="text-muted">
                  <%= module_item.lessons.count %> lessons
                </small>
              </div>
            </button>
          </h2>

          <div id="module-<%= module_item.id %>"
               class="accordion-collapse collapse <%= 'show' if index == 0 %>">
            <div class="accordion-body">

              <div class="admin-box mb-3">
                <%= link_to t('admin.courses.show.edit_module'),
                      edit_admin_course_module_path(module_item),
                      class: "btn btn-sm btn-outline-secondary" %>

                <%= link_to t('admin.courses.show.delete_module'),
                      admin_course_module_path(module_item),
                      data: { turbo_method: :delete, turbo_confirm: t('admin.courses.show.confirm_delete_module', title: module_item.title) },
                      class: "btn btn-sm btn-outline-danger" %>

                <%= link_to t('admin.courses.show.add_lesson'),
                      new_admin_course_module_lesson_path(module_item),
                      class: "btn btn-sm btn-success float-end" %>
              </div>

              <% if module_item.lessons.empty? %>
                <p class="text-muted"><em>No lessons yet</em></p>
              <% else %>
                <ul class="list-group">
                  <% module_item.lessons.each do |lesson| %>
                    <li class="list-group-item lesson-item">
                      <span><%= lesson.title %></span>
                      <div class="lesson-actions">
                        <%= link_to "👁", lesson_path(lesson),
                              class: "btn btn-sm btn-outline-info", target: "_blank" %>

                        <%= link_to "✏️", edit_admin_lesson_path(lesson),
                              class: "btn btn-sm btn-outline-warning" %>

                        <%= link_to "🗑", admin_lesson_path(lesson),
                              data: { turbo_method: :delete, turbo_confirm: t('admin.courses.show.confirm_delete_lesson', title: lesson.title) },
                              class: "btn btn-sm btn-outline-danger" %>
                      </div>
                    </li>
                  <% end %>
                </ul>
              <% end %>

            </div>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>

</div> <!-- admin-container -->
