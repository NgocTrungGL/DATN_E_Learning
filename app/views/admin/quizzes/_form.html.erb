<%# Admin Quiz Form Partial — Premium BEM Redesign %>
<%# Preserves: Stimulus data-controller, data-action, data-*-target %>

<div data-controller="form-refresh quiz-form">
  <%= form_with(model: [:admin, @quiz]) do |f| %>

    <%# ── Validation Errors ──────────────────────────────────── %>
    <% if @quiz.errors.any? %>
      <div class="qz-form__errors">
        <i class="bi bi-exclamation-triangle-fill qz-form__errors-icon"></i>
        <div>
          <strong class="qz-form__errors-title"><%= @quiz.errors.count %> errors to fix:</strong>
          <ul class="qz-form__errors-list">
            <% @quiz.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <%# ── Card 1: Quiz information ───────────────────────────── %>
    <div class="qz-form__card">
      <div class="qz-form__card-header">
        <div>
          <h2 class="qz-form__card-title">Quiz Information</h2>
          <p class="qz-form__card-subtitle">Enter title, select course and lesson</p>
        </div>
      </div>
      <div class="qz-form__card-body">

        <div class="qz-form__field qz-form__field--full">
          <label class="qz-form__label qz-form__label--required">
            <i class="bi bi-pencil-fill"></i> Title
          </label>
          <%= f.text_field :title, class: "qz-form__input", required: true, placeholder: "e.g., Final quiz for module 1..." %>
        </div>

        <div class="qz-form__grid">
          <div class="qz-form__field">
            <label class="qz-form__label qz-form__label--required">
              <i class="bi bi-book"></i> Course
            </label>
            <%= f.collection_select :course_id, @courses, :id, :title,
              { prompt: "--- Select course ---" },
              {
                class: "qz-form__select",
                required: true,
                data: {
                  form_refresh_target: "courseSelect",
                  action: "change->form-refresh#updateLessons"
                }
              } %>
          </div>

          <div class="qz-form__field">
            <label class="qz-form__label">
              <i class="bi bi-layers"></i> Lesson
              <span class="qz-form__optional">(Optional)</span>
            </label>
            <%= f.select :lesson_id,
              @lessons&.map { |l| [l.title, l.id] } || [],
              { include_blank: "--- None (Final course quiz) ---" },
              {
                class: "qz-form__select",
                data: {
                  form_refresh_target: "lessonSelect",
                  quiz_form_target: "lessonSelect",
                  action: "change->quiz-form#toggleMode"
                }
              } %>
          </div>
        </div>

        <div class="qz-form__field qz-form__field--full" style="margin-top:1rem;">
          <label class="qz-form__label">
            <i class="bi bi-text-paragraph"></i> Description
          </label>
          <%= f.text_area :description, rows: 2, class: "qz-form__textarea", placeholder: "Short description of the quiz (optional)..." %>
        </div>

      </div>
    </div>

    <%# ── Card 2: General settings ───────────────────────────── %>
    <div class="qz-form__card">
      <div class="qz-form__card-header">
        <div>
          <h2 class="qz-form__card-title">General Settings</h2>
          <p class="qz-form__card-subtitle">Time limit, pass score and question count</p>
        </div>
      </div>
      <div class="qz-form__card-body">

        <div class="qz-form__grid">
          <div class="qz-form__field">
            <label class="qz-form__label">
              <i class="bi bi-clock"></i> Time limit (minutes)
            </label>
            <%= f.number_field :time_limit, class: "qz-form__input", placeholder: "Leave blank for no limit" %>
          </div>
          <div class="qz-form__field">
            <label class="qz-form__label">
              <i class="bi bi-check-circle"></i> Pass score (%)
            </label>
            <%= f.number_field :pass_score, value: @quiz.pass_score || 70, class: "qz-form__input" %>
          </div>
        </div>

        <div class="qz-form__field qz-form__field--full" style="margin-top:1rem;">
          <label class="qz-form__label qz-form__label--required">
            <i class="bi bi-123"></i> Total questions
          </label>
          <%= f.number_field :total_questions,
                class: "qz-form__input",
                required: true,
                data: { quiz_form_target: "totalInput" } %>
          <span class="qz-form__hint" data-quiz-form-target="totalHint">
            Enter the total number of questions required for the quiz.
          </span>
        </div>

        <div class="qz-form__field qz-form__field--full" style="margin-top:1rem;">
          <label class="qz-form__label">
            <i class="bi bi-calculator"></i> Scoring method
          </label>
          <%= f.select :scoring_type,
            Quiz.scoring_types.keys.map { |k| [k == "equal" ? "Equal (all questions weigh the same)" : "Weighted (Easy:Medium:Hard = 1:2:3)", k] },
            {}, class: "qz-form__select" %>
        </div>

      </div>
    </div>

    <%# ── Manual Mode Banner ─────────────────────────────────────── %>
    <div class="qz-form__mode-banner qz-form__mode-banner--manual d-none"
         data-quiz-form-target="manualSection">
      <i class="bi bi-hand-index-thumb"></i>
      <div>
        <strong>Mode: Mini Quiz</strong>
        <p>This is a Mini Quiz. Enter <strong>Total questions</strong> above, then add questions manually on the details page.</p>
      </div>
    </div>

    <%# ── Random Mode Card ───────────────────────────────────────── %>
    <div class="qz-form__card qz-form__card--random"
         data-quiz-form-target="randomSection">
      <div class="qz-form__card-header qz-form__card-header--random">
        <div>
          <h2 class="qz-form__card-title">Random Mode Configuration</h2>
          <p class="qz-form__card-subtitle">System auto-selects questions by difficulty. Enter count per level:</p>
        </div>
      </div>
      <div class="qz-form__card-body">
        <div class="qz-form__random-grid">
          <div class="qz-form__count-field qz-form__count-field--easy">
            <label class="qz-form__label">Number of easy questions</label>
            <%= f.number_field :easy_count, class: "qz-form__input",
                  min: 0,
                  data: { quiz_form_target: "countInput", action: "input->quiz-form#updateTotal" } %>
          </div>
          <div class="qz-form__count-field qz-form__count-field--medium">
            <label class="qz-form__label">Number of medium questions</label>
            <%= f.number_field :medium_count, class: "qz-form__input",
                  min: 0,
                  data: { quiz_form_target: "countInput", action: "input->quiz-form#updateTotal" } %>
          </div>
          <div class="qz-form__count-field qz-form__count-field--hard">
            <label class="qz-form__label">Number of hard questions</label>
            <%= f.number_field :hard_count, class: "qz-form__input",
                  min: 0,
                  data: { quiz_form_target: "countInput", action: "input->quiz-form#updateTotal" } %>
          </div>
        </div>
      </div>
    </div>

    <%# ── Actions ─────────────────────────────────────────────── %>
    <div class="qz-form__actions">
      <%= link_to "Cancel", admin_quizzes_path, class: "qz-form__btn qz-form__btn--cancel" %>
      <%= button_tag type: "submit", class: "qz-form__btn qz-form__btn--save" do %>
        <i class="bi bi-check-lg"></i> Save &amp; Continue
      <% end %>
    </div>

  <% end %>
</div>
