<%# Admin Quizzes Show — Premium BEM Redesign %>
<%# Preserves: button_to (CSRF), form_with, turbo_confirm, Stimulus data-* %>

<div class="qz-page">

  <%# Backlink %>
  <div class="qz-backlink">
    <%= link_to admin_quizzes_path do %>
      <i class="bi bi-arrow-left"></i>
      <span>Quay lại danh sách</span>
    <% end %>
  </div>

  <%# ── Quiz Hero ────────────────────────────────────────────── %>
  <header class="qz-page__header qz-page__header--compact">
    <div class="qz-page__header-left">
      <div class="qz-page__breadcrumb">
        <i class="bi bi-card-checklist"></i>
        <span>Quiz Management</span>
      </div>
      <h1 class="qz-page__title"><%= @quiz.title %></h1>
      <div class="qz-page__meta">
        <span class="qz-page__meta-item">
          <i class="bi bi-book"></i> <%= @quiz.course.title %>
        </span>
        <span class="qz-page__meta-item">
          <% if @quiz.lesson %>
            <i class="bi bi-layers"></i> <%= @quiz.lesson.title %> &mdash; Mini Quiz
          <% else %>
            <i class="bi bi-mortarboard"></i> Bài kiểm tra cuối khóa
          <% end %>
        </span>
      </div>
    </div>
    <div class="qz-page__header-right">
      <%= link_to edit_admin_quiz_path(@quiz), class: 'qz-hero-btn qz-hero-btn--secondary' do %>
        <i class="bi bi-gear"></i>
        <span>Cấu hình</span>
      <% end %>
    </div>
  </header>

  <%# ── Content ─────────────────────────────────────────────── %>
  <% if @quiz.random_selection? %>

    <%# === RANDOM MODE === %>
    <div class="qz-random-banner">
      <div>
        <h3>Random Mode</h3>
        <p>This is a comprehensive exam. The system will <strong>automatically select questions</strong> from the course question bank each time a student starts the quiz. You <strong>do not need</strong> to add questions manually here.</p>
      </div>
    </div>

    <div class="qz-config-card">
      <div class="qz-config-card__header">
        <i class="bi bi-sliders"></i> Cấu hình đề thi hiện tại
      </div>
      <div class="qz-config-card__body">
        <div class="qz-stats-grid">
          <div class="qz-stat">
            <span class="qz-stat__label">Tổng số câu</span>
            <span class="qz-stat__value"><%= @quiz.total_questions %></span>
          </div>
          <div class="qz-stat">
            <span class="qz-stat__label">Câu Dễ</span>
            <span class="qz-stat__value qz-stat__value--easy"><%= @quiz.easy_count %></span>
          </div>
          <div class="qz-stat">
            <span class="qz-stat__label">Câu Trung bình</span>
            <span class="qz-stat__value qz-stat__value--medium"><%= @quiz.medium_count %></span>
          </div>
          <div class="qz-stat">
            <span class="qz-stat__label">Câu Khó</span>
            <span class="qz-stat__value qz-stat__value--hard"><%= @quiz.hard_count %></span>
          </div>
        </div>
        <div class="qz-config-card__scoring">
          <i class="bi bi-calculator"></i>
          Kiểu chấm điểm: <strong><%= @quiz.weighted? ? "Phân cấp (Khó x3, TB x2)" : "Đồng cấp (Mọi câu bằng điểm)" %></strong>
        </div>
      </div>
      <div class="qz-config-card__footer">
        <i class="bi bi-info-circle"></i>
        Để thay đổi số lượng câu hỏi, vui lòng bấm nút "Cấu hình" ở trên.
      </div>
    </div>

  <% else %>

    <%# === MANUAL MODE === %>
    <div class="qz-manual-grid">

      <%# Left: Question List %>
      <div class="qz-questions-panel">
        <div class="qz-questions-panel__header">
          <span>Câu hỏi đã chọn</span>
          <span class="qz-count-badge"><%= @quiz_questions.count %></span>
        </div>

        <% if @quiz_questions.empty? %>
          <div class="qz-questions-panel__empty">
            <i class="bi bi-inbox"></i>
            <p>Chưa có câu hỏi nào được thêm.<br>Hãy chọn câu hỏi từ cột bên phải.</p>
          </div>
        <% else %>
          <div class="qz-questions-panel__list">
            <% @quiz_questions.each do |quiz_question| %>
              <% q = quiz_question.question %>
              <div class="qz-question-item">
                <div class="qz-question-item__content">
                  <p class="qz-question-item__text"><%= truncate(q.question_text, length: 90) %></p>
                  <div class="qz-question-item__tags">
                    <span class="qz-tag qz-tag--<%= q.question_type == 'single' ? 'single' : 'multiple' %>">
                      <%= q.question_type == 'single' ? '1 Đáp án' : 'Nhiều đáp án' %>
                    </span>
                    <span class="qz-tag qz-tag--<%= q.difficulty %>">
                      <%= q.difficulty.capitalize %>
                    </span>
                  </div>
                </div>
                <%= button_to admin_quiz_question_path(quiz_question),
                      method: :delete,
                      data: { turbo_confirm: "Remove this question from the quiz?" },
                      class: "qz-remove-btn",
                      title: "Remove" do %>
                  <%= image_tag 'delete.png', class: 'crs-btn__img', alt: 'Remove' %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Right: Add from Bank %>
      <div class="qz-sidebar">
        <div class="qz-sidebar__header">
          <i class="bi bi-plus-circle"></i> Thêm từ Ngân hàng
        </div>
        <div class="qz-sidebar__body">
          <p class="qz-sidebar__hint">
            Chọn câu hỏi từ khóa học <strong><%= @quiz.course.title %></strong>:
          </p>

          <%= form_with(url: admin_quiz_quiz_questions_path(@quiz), method: :post) do |f| %>
            <% if @available_questions.any? %>
              <label class="qz-sidebar__label">Danh sách câu hỏi có sẵn</label>
              <%= f.collection_select :question_id, @available_questions, :id,
                    ->(q){ "#{truncate(q.question_text, length: 50)} (#{q.difficulty})" },
                    { prompt: "--- Chọn câu hỏi ---" },
                    { class: "qz-sidebar__select", required: true } %>
              <%= f.submit "Thêm vào Quiz", class: "qz-sidebar__submit" %>
            <% else %>
              <div class="qz-sidebar__exhausted">
                <i class="bi bi-check-all"></i> Đã thêm hết tất cả câu hỏi của khóa học này vào Quiz.
              </div>
            <% end %>
          <% end %>

          <hr class="qz-sidebar__divider">
          <%= link_to new_admin_question_path(course_id: @quiz.course_id),
              class: "qz-sidebar__create-btn", target: "_blank" do %>
            <i class="bi bi-pencil-square"></i> Tạo câu hỏi mới cho khóa này
          <% end %>
        </div>
      </div>

    </div>

  <% end %>

</div>
