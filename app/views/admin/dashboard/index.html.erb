<div class="container-fluid py-4">
  <h2 class="h3 fw-bold text-gray-800 mb-4 border-start border-4 border-primary ps-3">Tổng quan hệ thống</h2>

  <div class="row g-4 mb-4">

    <div class="col-xl-3 col-md-6">
      <div class="card border-0 shadow-sm h-100 py-2 border-start border-4 border-primary">
        <div class="card-body">
          <div class="row no-gutters align-items-center">
            <div class="col mr-2">
              <div class="text-xs fw-bold text-primary text-uppercase mb-1">Học viên</div>
              <div class="h3 mb-0 fw-bold text-gray-800"><%= @total_students %></div>
            </div>
            <div class="col-auto">
              <i class="bi bi-people-fill fs-1 text-gray-300 opacity-25"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6">
      <div class="card border-0 shadow-sm h-100 py-2 border-start border-4 border-success">
        <div class="card-body">
          <div class="row no-gutters align-items-center">
            <div class="col mr-2">
              <div class="text-xs fw-bold text-success text-uppercase mb-1">Giảng viên</div>
              <div class="h3 mb-0 fw-bold text-gray-800"><%= @total_instructors %></div>
            </div>
            <div class="col-auto">
              <i class="bi bi-person-video3 fs-1 text-gray-300 opacity-25"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6">
      <div class="card border-0 shadow-sm h-100 py-2 border-start border-4 border-info">
        <div class="card-body">
          <div class="row no-gutters align-items-center">
            <div class="col mr-2">
              <div class="text-xs fw-bold text-info text-uppercase mb-1">Tổng Khóa học</div>
              <div class="h3 mb-0 fw-bold text-gray-800"><%= @total_courses %></div>
            </div>
            <div class="col-auto">
              <i class="bi bi-collection-play-fill fs-1 text-gray-300 opacity-25"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6">
      <div class="card border-0 shadow-sm h-100 py-2 border-start border-4 border-warning bg-warning-subtle">
        <div class="card-body">
          <div class="row no-gutters align-items-center">
            <div class="col mr-2">
              <div class="text-xs fw-bold text-warning text-uppercase mb-1">Chờ duyệt</div>
              <div class="h3 mb-0 fw-bold text-dark"><%= @pending_enrollments.count %></div>
            </div>
            <div class="col-auto">
              <i class="bi bi-hourglass-split fs-1 text-warning opacity-50"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4">

    <div class="col-lg-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header py-3 bg-white border-bottom d-flex justify-content-between align-items-center">
          <h6 class="m-0 fw-bold text-primary">Đánh giá mới nhất</h6>
          <%= link_to "Xem tất cả", admin_reviews_path, class: "btn btn-sm btn-outline-primary" %>
        </div>
        <div class="card-body p-0">
          <div class="list-group list-group-flush">
            <% @latest_reviews.each do |review| %>
              <div class="list-group-item px-3 py-3">
                <div class="d-flex w-100 justify-content-between">
                  <div class="d-flex align-items-center">
                    <div class="avatar-wrapper avatar-xs me-2">
                      <% if review.user.avatar_url.present? %>
                        <img
                          src="<%= review.user.avatar_url %>"
                          alt="<%= review.user.name %>"
                          class="avatar-img">
                      <% else %>
                        <div class="avatar-text avatar-xs-text">
                          <%= review.user.name.first.upcase %>
                        </div>
                      <% end %>
                    </div>

                    <span class="fw-bold small"><%= review.user.name %></span>
                  </div>
                  <small class="text-warning">
                    <% review.rating.times do %><i class="bi bi-star-fill"></i><% end %>
                  </small>
                </div>
                <p class="mb-1 small text-muted mt-2 fst-italic">"<%= review.content.truncate(60) %>"</p>
                <small class="text-muted" style="font-size: 0.75rem">Khóa: <%= review.course.title.truncate(30) %></small>
              </div>
            <% end %>
            <% if @latest_reviews.empty? %>
              <div class="text-center py-4 text-muted small">Chưa có đánh giá nào.</div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header py-3 bg-white border-bottom d-flex justify-content-between align-items-center">
          <h6 class="m-0 fw-bold text-success">Thành viên mới gia nhập</h6>
          <%= link_to "Quản lý User", admin_users_path, class: "btn btn-sm btn-outline-success" %>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="bg-light">
                <tr>
                  <th class="ps-3 border-0">Tên</th>
                  <th class="border-0">Email</th>
                  <th class="border-0">Ngày tạo</th>
                </tr>
              </thead>
              <tbody>
                <% @latest_users.each do |user| %>
                  <tr>
                    <td class="ps-3">
                      <div class="d-flex align-items-center">
                        <div class="avatar-wrapper avatar-xs me-2">
                            <% if user.avatar_url.present? %>
                              <img
                                src="<%= user.avatar_url %>"
                                alt="<%= user.name %>"
                                class="avatar-img">
                            <% else %>
                              <div class="avatar-text avatar-xs-text">
                                <%= user.name.first.upcase %>
                              </div>
                            <% end %>
                          </div>

                        <span class="small fw-bold"><%= user.name %></span>
                      </div>
                    </td>
                    <td class="small text-muted"><%= user.email %></td>
                    <td class="small text-muted"><%= user.created_at.strftime("%d/%m") %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
