<%# Admin Dashboard — Bootstrap-free BEM redesign %>

<div class="admin-page-header">
  <div class="admin-page-header__inner">
    <div>
      <div class="admin-page-header__badge"><i class="bi bi-speedometer2"></i> Overview</div>
      <h1 class="admin-page-header__title">System Dashboard</h1>
    </div>
  </div>
</div>

<div class="admin-page-body">

  <%# ── Stats Widget Grid ──────────────────────────────────── %>
  <div class="admin-stats">
    <div class="admin-stats__card admin-stats__card--primary">
      <i class="bi bi-people-fill admin-stats__icon"></i>
      <div class="admin-stats__value"><%= @total_students %></div>
      <div class="admin-stats__label">Students</div>
    </div>

    <div class="admin-stats__card admin-stats__card--success">
      <i class="bi bi-person-video3 admin-stats__icon"></i>
      <div class="admin-stats__value"><%= @total_instructors %></div>
      <div class="admin-stats__label">Instructors</div>
    </div>

    <div class="admin-stats__card admin-stats__card--accent">
      <i class="bi bi-collection-play-fill admin-stats__icon"></i>
      <div class="admin-stats__value"><%= @total_courses %></div>
      <div class="admin-stats__label">Total courses</div>
    </div>

    <div class="admin-stats__card admin-stats__card--warning">
      <i class="bi bi-hourglass-split admin-stats__icon"></i>
      <div class="admin-stats__value"><%= @pending_enrollments.count %></div>
      <div class="admin-stats__label">Pending</div>
    </div>
  </div>

  <%# ── Two-column feed area ───────────────────────────────── %>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">

    <%# Latest Reviews %>
    <div class="admin-card">
      <div class="admin-card__header" style="justify-content:space-between;">
        <h5><i class="bi bi-star" style="color:#f59e0b;"></i> Latest reviews</h5>
        <%= link_to "View all", admin_reviews_path, class: "btn-action btn-action--info", style: "font-size:0.78rem;" %>
      </div>
      <div class="admin-card__body" style="padding:0;">
        <% @latest_reviews.each do |review| %>
          <div style="padding:0.9rem 1.25rem; border-bottom:1px solid #f1f5f9; display:flex; flex-direction:column; gap:0.3rem;">
            <div style="display:flex; align-items:center; justify-content:space-between;">
              <div style="display:flex; align-items:center; gap:0.6rem;">
                <% if review.user.avatar_url.present? %>
                  <img src="<%= review.user.avatar_url %>" style="width:28px; height:28px; border-radius:50%; object-fit:cover; flex-shrink:0;">
                <% else %>
                  <div style="width:28px; height:28px; border-radius:50%; background:#eff6ff; color:#2563eb; font-weight:800; font-size:0.8rem; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <%= review.user.name.first.upcase %>
                  </div>
                <% end %>
                <span style="font-weight:700; font-size:0.85rem; color:#0f172a;"><%= review.user.name %></span>
              </div>
              <span style="color:#f59e0b; font-size:0.8rem;">
                <% review.rating.times do %><i class="bi bi-star-fill"></i><% end %>
              </span>
            </div>
            <p style="font-size:0.8rem; color:#64748b; font-style:italic; margin:0;">"<%= review.content.truncate(60) %>"</p>
            <span style="font-size:0.73rem; color:#94a3b8;">Course: <%= review.course.title.truncate(30) %></span>
          </div>
        <% end %>
        <% if @latest_reviews.empty? %>
          <div style="padding:2rem; text-align:center; color:#94a3b8; font-size:0.85rem;">No reviews yet.</div>
        <% end %>
      </div>
    </div>

    <%# Latest Users %>
    <div class="admin-card">
      <div class="admin-card__header" style="justify-content:space-between;">
        <h5><i class="bi bi-person-plus" style="color:#10b981;"></i> New members</h5>
        <%= link_to "Manage users", admin_users_path, class: "btn-action btn-action--success", style: "font-size:0.78rem;" %>
      </div>
      <div style="overflow:hidden;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Created on</th>
            </tr>
          </thead>
          <tbody>
            <% @latest_users.each do |user| %>
              <tr>
                <td>
                  <div style="display:flex; align-items:center; gap:0.5rem;">
                    <% if user.avatar_url.present? %>
                      <img src="<%= user.avatar_url %>" style="width:28px; height:28px; border-radius:50%; object-fit:cover; flex-shrink:0;">
                    <% else %>
                      <div style="width:28px; height:28px; border-radius:50%; background:#eff6ff; color:#2563eb; font-weight:800; font-size:0.78rem; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <%= user.name.first.upcase %>
                      </div>
                    <% end %>
                    <span style="font-weight:700; font-size:0.85rem;"><%= user.name %></span>
                  </div>
                </td>
                <td class="admin-table__sub"><%= user.email %></td>
                <td class="admin-table__sub"><%= user.created_at.strftime("%d/%m/%Y") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>
