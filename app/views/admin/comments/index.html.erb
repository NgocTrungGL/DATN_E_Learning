<%# Admin Comments Index — Premium BEM Redesign %>

<div class="cm-page">

  <%# ── Page Header ─────────────────────────────────────────── %>
  <header class="cm-page__header">
    <div class="cm-page__header-left">
      <div class="cm-page__breadcrumb">
        <i class="bi bi-chat-dots"></i>
        <span>Interactions</span>
      </div>
      <h1 class="cm-page__title">Q&A Management</h1>
      <p class="cm-page__subtitle">Moderate student questions and instructor responses across lessons.</p>
    </div>
    <div class="cm-page__header-right">
      <div class="cm-page__stat-pill">
        <i class="bi bi-chat-left-text"></i>
        <strong><%= @pagy.count %></strong>
        <span>comments</span>
      </div>
    </div>
  </header>

  <%# ── Table Card ────────────────────────────────────────────── %>
  <div class="cm-table-card">
    <% if @comments.any? %>
      <table class="cm-table">
        <thead>
          <tr>
            <th class="cm-table__th cm-table__th--user">
              <i class="bi bi-person"></i> User
            </th>
            <th class="cm-table__th cm-table__th--type">
              <i class="bi bi-diagram-2"></i> Type
            </th>
            <th class="cm-table__th cm-table__th--location">
              <i class="bi bi-geo-alt"></i> Location
            </th>
            <th class="cm-table__th cm-table__th--content">
              <i class="bi bi-chat-square-text"></i> Content
            </th>
            <th class="cm-table__th cm-table__th--actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @comments.each do |comment| %>
            <tr class="cm-table__row">

              <%# User info %>
              <td class="cm-table__td">
                <div class="cm-table__user-cell">
                  <div class="cm-table__avatar">
                    <% if comment.user.avatar_url.present? %>
                      <img src="<%= comment.user.avatar_url %>" class="cm-table__avatar-img" alt="<%= comment.user.name %>">
                    <% else %>
                      <span class="cm-table__avatar-text"><%= comment.user.name.first.upcase %></span>
                    <% end %>
                  </div>
                  <div>
                    <span class="cm-table__user-name"><%= comment.user.name %></span>
                    <span class="cm-badge cm-badge--neutral"><%= comment.user.role.capitalize %></span>
                  </div>
                </div>
              </td>

              <%# Type %>
              <td class="cm-table__td">
                <% if comment.parent_id.nil? %>
                  <span class="cm-badge cm-badge--info">
                    <i class="bi bi-question-circle"></i> Question
                  </span>
                <% else %>
                  <div class="cm-table__reply">
                    <span class="cm-badge cm-badge--neutral"><i class="bi bi-reply"></i> Reply</span>
                    <span class="cm-table__sub">to #<%= comment.parent_id %></span>
                  </div>
                <% end %>
              </td>

              <%# Location %>
              <td class="cm-table__td">
                <div class="cm-table__location">
                  <span class="cm-table__lesson" title="<%= comment.lesson.title %>">
                    <i class="bi bi-play-circle"></i> <%= comment.lesson.title.truncate(30) %>
                  </span>
                  <span class="cm-table__sub">Course: <%= comment.lesson.course.title.truncate(20) %></span>
                </div>
              </td>

              <%# Content %>
              <td class="cm-table__td">
                <p class="cm-table__body-text"><%= truncate(comment.body, length: 120) %></p>
                <div class="cm-table__sub">
                  <i class="bi bi-clock"></i> <%= time_ago_in_words(comment.created_at) %> ago
                </div>
              </td>

              <%# Actions %>
              <td class="cm-table__td cm-table__td--actions">
                <div class="cm-table__action-group">
                  <%= link_to lesson_path(comment.lesson, anchor: "comment-#{comment.id}"),
                      class: 'cm-btn cm-btn--view', target: '_blank', title: 'View in lesson' do %>
                    <%= image_tag 'view.png', class: 'crs-btn__img', alt: 'View' %>
                  <% end %>
                  <%= link_to admin_comment_path(comment),
                      data: { turbo_method: :delete, turbo_confirm: 'WARNING: Deleting this comment will remove all child replies. Continue?' },
                      class: 'cm-btn cm-btn--delete', title: 'Delete' do %>
                    <%= image_tag 'delete.png', class: 'crs-btn__img', alt: 'Delete' %>
                  <% end %>
                </div>
              </td>

            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="cm-empty">
        <div class="cm-empty__icon"><i class="bi bi-chat-square-dots"></i></div>
        <h3>No discussions yet</h3>
        <p>Comments from students will appear here for management.</p>
      </div>
    <% end %>
  </div>

  <%# ── Pagination ───────────────────────────────────────────── %>
  <% if @pagy.pages > 1 %>
    <div class="cm-pagination">
      <div class="cm-pagination__nav"><%== pagy_nav(@pagy) %></div>
      <p class="cm-pagination__note">
        Showing <strong><%= @pagy.items %></strong> of <strong><%= @pagy.count %></strong> comments
      </p>
    </div>
  <% end %>

</div>
