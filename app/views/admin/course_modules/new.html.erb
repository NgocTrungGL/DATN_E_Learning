<section class="admin-course-modules">
  <div class="admin-course-modules__inner">
    <%= link_to admin_course_path(@course), class: 'admin-course-modules__backlink' do %>
      <i class="bi bi-arrow-left"></i>
      <span><%= t('admin.course_modules.form.back_to_course') %></span>
    <% end %>

    <header class="admin-course-modules__hero">
      <div class="admin-course-modules__hero-copy">
        <p class="admin-course-modules__eyebrow"><%= t('admin.course_modules.new.eyebrow') %></p>
        <h1 class="admin-course-modules__title"><%= t('admin.course_modules.new.title') %></h1>
        <p class="admin-course-modules__subtitle">
          <%= t('admin.course_modules.new.for_course', course_title: @course.title) %>
        </p>
      </div>

      <div class="admin-course-modules__hero-stats">
        <article class="admin-course-modules__stat-card">
          <span class="admin-course-modules__stat-label">Tổng chương</span>
          <strong class="admin-course-modules__stat-value"><%= @modules.size %></strong>
        </article>

        <article class="admin-course-modules__stat-card">
          <span class="admin-course-modules__stat-label">Quiz lớn</span>
          <strong class="admin-course-modules__stat-value"><%= @big_quizzes.size %></strong>
        </article>
      </div>
    </header>

    <div class="admin-course-modules__layout">
      <section class="admin-course-modules__panel admin-course-modules__panel--form">
        <div class="admin-course-modules__panel-head">
          <div>
            <h2 class="admin-course-modules__panel-title"><%= t('admin.course_modules.form.panel_title', default: 'Thêm chương mới') %></h2>
            <p class="admin-course-modules__panel-subtitle"><%= t('admin.course_modules.form.panel_subtitle', default: 'Đặt tên rõ ràng để học viên và admin dễ theo dõi cấu trúc khóa học.') %></p>
          </div>

          <div class="admin-course-modules__panel-badge">
            <i class="bi bi-folder2-open"></i>
            <span><%= @course.title %></span>
          </div>
        </div>

        <%= render 'form', mode: :new, submit_key: 'admin.course_modules.form.submit_new' %>
      </section>

      <aside class="admin-course-modules__panel admin-course-modules__panel--outline">
        <div class="admin-course-modules__outline-head">
          <div>
            <h2><%= t('admin.course_modules.outline.title') %></h2>
            <p class="admin-course-modules__outline-note"><%= t('admin.course_modules.outline.reorder_hint') %></p>
          </div>

          <span class="admin-course-modules__hint">
            <i class="bi bi-arrows-move"></i>
            Kéo để sắp xếp
          </span>
        </div>

        <% if @modules.any? %>
          <div class="admin-course-modules__outline-list"
               data-controller="sortable"
            data-sortable-param-value="course_module"
            data-sortable-handle-value=".admin-course-modules__outline-item"
               data-sortable-url-value="<%= sort_admin_course_modules_path %>">
            <% @modules.each do |mod| %>
              <article class="admin-course-modules__outline-item" data-id="<%= mod.id %>">
                <div class="admin-course-modules__drag-handle drag-handle">
                  <i class="bi bi-grip-vertical"></i>
                </div>

                <div class="admin-course-modules__outline-copy">
                  <h3><%= mod.title %></h3>
                  <p><%= t('admin.course_modules.outline.lesson_count', count: mod.lessons.count) %></p>
                </div>

                <div class="admin-course-modules__outline-actions">
                  <%= link_to edit_admin_course_module_path(mod), class: 'admin-course-modules__action admin-course-modules__action--edit' do %>
                    <i class="bi bi-pencil-square"></i>
                    <span class="admin-course-modules__action-text"><%= t('admin.course_modules.outline.edit', default: 'Sửa') %></span>
                  <% end %>

                  <%= link_to admin_course_module_path(mod),
                              class: 'admin-course-modules__action admin-course-modules__action--delete',
                              data: { turbo_method: :delete, turbo_confirm: t('admin.course_modules.outline.confirm_delete') } do %>
                    <i class="bi bi-trash"></i>
                    <span class="admin-course-modules__action-text"><%= t('admin.course_modules.outline.delete', default: 'Xóa') %></span>
                  <% end %>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <div class="admin-course-modules__empty">
            <i class="bi bi-journal-plus"></i>
            <p><%= t('admin.course_modules.outline.empty') %></p>
          </div>
        <% end %>

        <% if @big_quizzes.any? %>
          <div class="admin-course-modules__quizzes">
            <div class="admin-course-modules__quizzes-head">
              <h3><%= t('admin.course_modules.outline.big_quizzes') %></h3>
              <span class="admin-course-modules__quizzes-chip"><%= @big_quizzes.size %></span>
            </div>
            <div class="admin-course-modules__quiz-list">
              <% @big_quizzes.each do |quiz| %>
                <article class="admin-course-modules__quiz-item">
                  <div>
                    <h4><%= quiz.title %></h4>
                    <p><%= t('admin.course_modules.outline.question_count', count: quiz.total_questions) %></p>
                  </div>
                  <%= link_to t('admin.course_modules.outline.quiz_detail'), admin_quiz_path(quiz), class: 'btn-action btn-action--neutral' %>
                </article>
              <% end %>
            </div>
          </div>
        <% end %>
      </aside>
    </div>
  </div>
</section>
