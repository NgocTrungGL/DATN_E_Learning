<% form_scope = mode == :edit ? [:admin, @course_module] : [:admin, @course, @course_module] %>

<%= form_with(model: form_scope, local: true, class: 'needs-validation') do |form| %>
  <% if @course_module.errors.any? %>
    <div class="admin-course-modules__errors">
      <div class="admin-course-modules__errors-title">
        <%= t('admin.course_modules.form.errors_title', count: @course_module.errors.count) %>
      </div>
      <ul class="admin-course-modules__errors-list">
        <% @course_module.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="admin-course-modules__field-group">
    <div class="admin-course-modules__field">
      <%= form.label :title, t('admin.course_modules.form.title'), class: 'admin-course-modules__label' %>
      <%= form.text_field :title,
                          class: 'form-control form-control-lg admin-course-modules__input',
                          placeholder: t('admin.course_modules.form.title_placeholder'),
                          autofocus: true,
                          required: true %>
    </div>

    <div class="admin-course-modules__field">
      <%= form.label :description, t('admin.course_modules.form.description'), class: 'admin-course-modules__label' %>
      <%= form.text_area :description,
                         rows: 4,
                         class: 'form-control admin-course-modules__textarea',
                         placeholder: t('admin.course_modules.form.description_placeholder') %>
    </div>

    <%= form.hidden_field :order_index %>
  </div>

  <div class="admin-course-modules__form-actions">
    <%= link_to admin_course_path(@course), class: 'btn btn-outline-secondary admin-course-modules__action' do %>
      <%= t('admin.course_modules.form.back_to_course') %>
    <% end %>

    <%= form.submit t(submit_key), class: 'btn btn-primary admin-course-modules__action' %>
  </div>
<% end %>
