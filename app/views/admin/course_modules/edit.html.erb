<section class="admin-course-modules">
  <div class="admin-course-modules__inner">
    <%= link_to admin_course_path(@course), class: 'admin-course-modules__backlink' do %>
      <i class="bi bi-arrow-left"></i>
      <span><%= t('admin.course_modules.form.back_to_course') %></span>
    <% end %>

    <div class="admin-course-modules__layout">
      <section class="admin-course-modules__panel admin-course-modules__panel--form">
        <header class="admin-course-modules__header">
          <p class="admin-course-modules__eyebrow"><%= t('admin.course_modules.edit.eyebrow') %></p>
          <h1 class="admin-course-modules__title"><%= t('admin.course_modules.edit.title') %></h1>
          <p class="admin-course-modules__subtitle">
            <%= t('admin.course_modules.edit.for_course', course_title: @course.title) %>
          </p>
        </header>

        <%= render 'form', mode: :edit, submit_key: 'admin.course_modules.form.submit_edit' %>
      </section>

      <aside class="admin-course-modules__panel admin-course-modules__panel--outline">
        <div class="admin-course-modules__outline-head">
          <h2><%= t('admin.course_modules.outline.current_title') %></h2>
          <span class="admin-course-modules__hint">
            <i class="bi bi-arrows-move"></i>
            <%= t('admin.course_modules.outline.reorder_hint') %>
          </span>
        </div>

        <div class="admin-course-modules__outline-list"
             data-controller="sortable"
             data-sortable-param-value="course_module"
             data-sortable-handle-value=".admin-course-modules__outline-item"
             data-sortable-url-value="<%= sort_admin_course_modules_path %>">
          <% @modules.each do |mod| %>
            <article class="admin-course-modules__outline-item <%= 'admin-course-modules__outline-item--active' if mod == @course_module %>" data-id="<%= mod.id %>">
              <div class="admin-course-modules__drag-handle drag-handle">
                <i class="bi bi-grip-vertical"></i>
              </div>

              <div class="admin-course-modules__outline-copy">
                <h3>
                  <%= mod.title %>
                  <% if mod == @course_module %>
                    <span class="admin-course-modules__active-chip"><%= t('admin.course_modules.outline.editing') %></span>
                  <% end %>
                </h3>
                <p><%= t('admin.course_modules.outline.lesson_count', count: mod.lessons.count) %></p>
              </div>

              <div class="admin-course-modules__outline-actions">
                <% unless mod == @course_module %>
                  <%= link_to edit_admin_course_module_path(mod), class: 'admin-course-modules__action admin-course-modules__action--edit' do %>
                    <i class="bi bi-pencil-square"></i>
                    <span class="admin-course-modules__action-text"><%= t('admin.course_modules.outline.edit', default: 'Sửa') %></span>
                  <% end %>

                  <%= link_to admin_course_module_path(mod),
                              class: 'admin-course-modules__action admin-course-modules__action--delete',
                              data: { turbo_method: :delete, turbo_confirm: t('admin.course_modules.outline.confirm_delete') } do %>
                    <i class="bi bi-trash"></i>
                    <span class="admin-course-modules__action-text"><%= t('admin.course_modules.outline.delete', default: 'Xóa') %></span>
                  <% end %>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      </aside>
    </div>
  </div>
</section>
