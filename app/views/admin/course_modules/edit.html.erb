<div class="row">
  <div class="col-md-5">
    <div class="card shadow-sm sticky-top" style="top: 20px; z-index: 1;">
      <div class="card-header bg-white py-3">
        <h4 class="mb-0 text-warning"><i class="bi bi-pencil-square"></i> Chỉnh sửa Chương</h4>
        <small class="text-muted">Khóa học: <strong><%= @course.title %></strong></small>
      </div>

      <div class="card-body">
        <%= form_with(model: [:admin, @course_module]) do |f| %>

          <% if @course_module.errors.any? %>
            <div class="alert alert-danger small">
              <ul class="mb-0 ps-3">
                <% @course_module.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :title, "Tên chương", class: "form-label fw-bold" %>
            <%= f.text_field :title, class: "form-control", autofocus: true %>
          </div>

          <div class="mb-3">
            <%= f.label :description, "Mô tả ngắn", class: "form-label fw-bold" %>
            <%= f.text_area :description, rows: 3, class: "form-control" %>
          </div>

          <%= f.hidden_field :order_index %>

          <div class="d-grid gap-2 mt-4">
            <%= f.submit "Cập nhật thay đổi", class: "btn btn-warning fw-bold text-dark" %>
            <%= link_to "Hủy & Quay lại tạo mới", new_admin_course_course_module_path(@course), class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-7 mt-4 mt-md-0">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="mb-0 text-secondary">Cấu trúc hiện tại</h5>
      <span class="badge bg-info text-dark"><i class="bi bi-arrows-move"></i> Kéo thả để sắp xếp</span>
    </div>

    <div class="list-group shadow-sm mb-4"
         data-controller="sortable"
         data-sortable-url-value="<%= sort_admin_course_modules_path %>">

      <% @modules.each do |mod| %>
        <div class="list-group-item list-group-item-action d-flex align-items-center p-3 <%= 'list-group-item-warning border-warning' if mod == @course_module %>" data-id="<%= mod.id %>">

          <div class="drag-handle me-3 text-muted" style="cursor: grab;">
            <i class="bi bi-grip-vertical fs-4"></i>
          </div>

          <div class="flex-grow-1">
            <div class="fw-bold text-dark">
              <%= mod.title %>
              <% if mod == @course_module %><span class="badge bg-warning text-dark ms-2">Đang sửa</span><% end %>
            </div>
            <div class="small text-muted"><%= pluralize(mod.lessons.count, "bài học") %></div>
          </div>

          <div class="btn-group">
            <% unless mod == @course_module %>
              <%= link_to edit_admin_course_module_path(mod), class: "btn btn-sm btn-light text-primary" do %>
                <i class="bi bi-pencil-square"></i>
              <% end %>
            <% end %>
            <% unless mod == @course_module %>
              <%= button_to admin_course_module_path(mod), method: :delete, class: "btn btn-sm btn-light text-danger", data: { confirm: "Xóa chương này?" } do %>
                <i class="bi bi-trash"></i>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    </div>
</div>
