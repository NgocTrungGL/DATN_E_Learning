<% form_scope = @lesson.persisted? ? [:admin, @lesson] : [:admin, @course_module, @lesson] %>
<% submit_text = local_assigns[:submit_text] || (@lesson.persisted? ? 'Cập nhật bài học' : 'Lưu & Thêm bài tiếp') %>

<%= form_with(model: form_scope, class: 'admin-lessons__form') do |form| %>
  <% if @lesson.errors.any? %>
    <div class="admin-lessons__errors">
      <ul>
        <% @lesson.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="admin-lessons__field">
    <%= form.label :title, 'Tên bài học', class: 'admin-lessons__label' %>
    <%= form.text_field :title,
                        class: 'admin-input admin-lessons__input',
                        placeholder: 'Ví dụ: Cài đặt môi trường...',
                        autofocus: true,
                        required: true %>
  </div>

  <div class="admin-lessons__field">
    <%= form.label :description, 'Mô tả nội dung', class: 'admin-lessons__label' %>
    <%= form.text_area :description,
                       rows: 4,
                       class: 'admin-textarea admin-lessons__textarea',
                       placeholder: 'Tóm tắt nội dung bài học...' %>
  </div>

  <div class="admin-lessons__field">
    <%= form.label :video_url, 'Link Video (YouTube)', class: 'admin-lessons__label' %>
    <%= form.text_field :video_url,
                        class: 'admin-input admin-lessons__input',
                        placeholder: 'https://youtube.com/...' %>
  </div>

  <div class="admin-lessons__field">
    <%= form.label :attachment_url, 'Link Tài liệu đính kèm', class: 'admin-lessons__label' %>
    <%= form.text_field :attachment_url,
                        class: 'admin-input admin-lessons__input',
                        placeholder: 'Link Google Drive / PDF...' %>
  </div>

  <%= form.hidden_field :order_index %>

  <div class="admin-lessons__actions">
    <%= link_to 'Quay lại khóa học', admin_course_path(@course_module.course), class: 'btn-cancel admin-lessons__action-btn' %>
    <%= form.submit submit_text, class: 'btn-save admin-lessons__action-btn' %>
  </div>
<% end %>
