<section class="admin-lessons">
  <div class="admin-lessons__inner">
    <%= link_to admin_course_path(@course_module.course), class: 'admin-lessons__backlink' do %>
      <i class="bi bi-arrow-left"></i>
      <span>Quay lại khóa học</span>
    <% end %>

    <header class="admin-lessons__hero">
      <div class="admin-lessons__hero-copy">
        <p class="admin-lessons__eyebrow">Quản lý bài học</p>
        <h1 class="admin-lessons__title">Thêm bài học mới</h1>
        <p class="admin-lessons__subtitle">
          Chương: <strong><%= @course_module.title %></strong>
          <span class="admin-lessons__dot">•</span>
          Khóa: <strong><%= @course_module.course.title %></strong>
        </p>
      </div>

      <div class="admin-lessons__hero-stats">
        <article class="admin-lessons__stat-card">
          <span class="admin-lessons__stat-label">Tổng bài học</span>
          <strong class="admin-lessons__stat-value"><%= @lessons.size %></strong>
        </article>
      </div>
    </header>

    <div class="admin-lessons__layout">
      <section class="admin-lessons__panel admin-lessons__panel--form">
        <div class="admin-lessons__panel-head">
          <h2>Thông tin bài học</h2>
          <p>Tạo nhanh bài học với video hoặc tài liệu đính kèm.</p>
        </div>

        <%= render 'form', submit_text: 'Lưu & Thêm bài tiếp' %>
      </section>

      <aside class="admin-lessons__panel admin-lessons__panel--list">
        <div class="admin-lessons__list-head">
          <h2>Danh sách bài học</h2>
          <span class="admin-lessons__hint"><i class="bi bi-arrows-move"></i> Kéo thả để sắp xếp</span>
        </div>

        <% if @lessons.any? %>
          <div class="admin-lessons__list"
               data-controller="sortable"
               data-sortable-param-value="lesson"
               data-sortable-handle-value=".admin-lessons__lesson-item"
               data-sortable-url-value="<%= sort_admin_lessons_path %>">
            <% @lessons.each do |lesson| %>
              <article class="admin-lessons__lesson-item" data-id="<%= lesson.id %>">
                <div class="admin-lessons__drag-handle drag-handle">
                  <i class="bi bi-grip-vertical"></i>
                </div>

                <div class="admin-lessons__lesson-copy">
                  <h3><%= lesson.title %></h3>
                  <% if lesson.quizzes.any? %>
                    <span class="admin-lessons__quiz-chip"><i class="bi bi-lightning-fill"></i> Quiz</span>
                  <% end %>
                </div>

                <div class="admin-lessons__lesson-actions">
                  <%= link_to edit_admin_lesson_path(lesson), class: 'admin-lessons__lesson-action admin-lessons__lesson-action--edit' do %>
                    <i class="bi bi-pencil-square"></i>
                    <span>Sửa</span>
                  <% end %>

                  <%= link_to admin_lesson_path(lesson),
                              class: 'admin-lessons__lesson-action admin-lessons__lesson-action--delete',
                              data: { turbo_method: :delete, turbo_confirm: 'Xóa bài học này?' } do %>
                    <i class="bi bi-trash"></i>
                    <span>Xóa</span>
                  <% end %>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <div class="admin-lessons__empty">
            <i class="bi bi-inbox"></i>
            <p>Chưa có bài học nào trong chương này. Hãy bắt đầu thêm ở panel bên trái.</p>
          </div>
        <% end %>
      </aside>
    </div>
  </div>
</section>
