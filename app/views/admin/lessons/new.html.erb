<div class="row">
  <div class="col-md-6"> <div class="card shadow-sm sticky-top" style="top: 20px; z-index: 1;">
      <div class="card-header bg-white py-3">
        <h4 class="mb-0 text-primary"><i class="bi bi-file-earmark-play"></i> Thêm Bài học Mới</h4>
        <div class="text-muted small mt-1">
          Chương: <strong><%= @course_module.title %></strong>
          <span class="mx-1">•</span>
          Khóa: <strong><%= @course_module.course.title %></strong>
        </div>
      </div>

      <div class="card-body">
        <%= form_with(model: [:admin, @course_module, @lesson]) do |f| %>
          <% if @lesson.errors.any? %>
            <div class="alert alert-danger small">
              <ul class="mb-0 ps-3">
                <% @lesson.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :title, "Tên bài học", class: "form-label fw-bold" %>
            <%= f.text_field :title, class: "form-control", placeholder: "Ví dụ: Cài đặt môi trường...", autofocus: true %>
          </div>

          <div class="mb-3">
            <%= f.label :description, "Mô tả nội dung", class: "form-label fw-bold" %>
            <%= f.text_area :description, rows: 3, class: "form-control", placeholder: "Tóm tắt nội dung bài học..." %>
          </div>

          <div class="mb-3">
            <%= f.label :video_url, "Link Video (YouTube)", class: "form-label fw-bold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-youtube text-danger"></i></span>
              <%= f.text_field :video_url, class: "form-control", placeholder: "https://youtube.com/..." %>
            </div>
          </div>

          <div class="mb-3">
            <%= f.label :attachment_url, "Link Tài liệu đính kèm", class: "form-label fw-bold" %>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-paperclip"></i></span>
              <%= f.text_field :attachment_url, class: "form-control", placeholder: "Link Google Drive / PDF..." %>
            </div>
          </div>

          <%= f.hidden_field :order_index %>

          <div class="d-grid gap-2 mt-4">
            <%= f.submit "Lưu & Thêm bài tiếp", class: "btn btn-primary fw-bold" %>
            <%= link_to "Quay lại Khóa học", admin_course_path(@course_module.course), class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6 mt-4 mt-md-0">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="mb-0 text-secondary">Danh sách bài học</h5>
      <span class="badge bg-info text-dark"><i class="bi bi-arrows-move"></i> Kéo thả</span>
    </div>

    <div class="list-group shadow-sm mb-4"
         data-controller="sortable"
         data-sortable-url-value="<%= sort_admin_lessons_path %>">

      <% @lessons.each do |lesson| %>
        <div class="list-group-item list-group-item-action d-flex align-items-center p-3" data-id="<%= lesson.id %>">

          <div class="drag-handle me-3 text-muted" style="cursor: grab;">
            <i class="bi bi-grip-vertical fs-4"></i>
          </div>

          <div class="me-3 text-center" style="width: 30px;">
            <% if lesson.video_url.present? %>
              <i class="bi bi-play-circle-fill text-danger fs-4" title="Video"></i>
            <% else %>
              <i class="bi bi-file-text-fill text-primary fs-4" title="Văn bản"></i>
            <% end %>
          </div>

          <div class="flex-grow-1">
            <div class="fw-bold text-dark text-truncate" style="max-width: 250px;">
              <%= lesson.title %>
            </div>
            <% if lesson.quizzes.any? %>
              <span class="badge bg-warning text-dark mt-1" style="font-size: 0.7em">
                <i class="bi bi-lightning-fill"></i> Quiz
              </span>
            <% end %>
          </div>

          <div class="btn-group">
            <%= link_to edit_admin_lesson_path(lesson), class: "btn btn-sm btn-light text-primary" do %>
              <i class="bi bi-pencil-square"></i>
            <% end %>
            <%= button_to admin_lesson_path(lesson), method: :delete, class: "btn btn-sm btn-light text-danger", data: { confirm: "Xóa bài học này?" } do %>
              <i class="bi bi-trash"></i>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @lessons.empty? %>
        <div class="text-center p-5 text-muted border rounded bg-light">
          <i class="bi bi-inbox fs-1 d-block mb-3"></i>
          Chưa có bài học nào trong chương này.<br>
          Hãy bắt đầu thêm ở bên trái.
        </div>
      <% end %>
    </div>
  </div>
</div>
