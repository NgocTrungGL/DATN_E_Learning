<%# Admin Enrollments Index — Premium BEM Redesign %>

<div class="en-page">

  <%# ── Page Header ─────────────────────────────────────────── %>
  <header class="en-page__header">
    <div class="en-page__header-left">
      <div class="en-page__breadcrumb">
        <i class="bi bi-wallet2"></i>
        <span>Finance & Sales</span>
      </div>
      <h1 class="en-page__title">Enrollment & Orders</h1>
      <p class="en-page__subtitle">Track course subscriptions, transaction history and payment statuses.</p>
    </div>
    
    <div class="en-page__header-right">
      <div class="en-page__filter-group">
        <%= link_to admin_enrollments_path, 
            class: "en-filter-btn #{'en-filter-btn--active' if params[:status].blank?}" do %>
          <span>All Orders</span>
        <% end %>
        <%= link_to admin_enrollments_path(status: 'active'), 
            class: "en-filter-btn #{'en-filter-btn--active' if params[:status] == 'active'}" do %>
          <i class="bi bi-check-circle"></i> <span>Paid</span>
        <% end %>
        <%= link_to admin_enrollments_path(status: 'pending'), 
            class: "en-filter-btn #{'en-filter-btn--active' if params[:status] == 'pending'}" do %>
          <i class="bi bi-hourglass-split"></i> <span>Pending</span>
        <% end %>
      </div>
    </div>
  </header>

  <%# ── Table Card ────────────────────────────────────────────── %>
  <div class="en-table-card">
    <% if @enrollments.any? %>
      <table class="en-table">
        <thead>
          <tr>
            <th class="en-table__th en-table__th--id">ID</th>
            <th class="en-table__th en-table__th--student">
              <i class="bi bi-person"></i> Student
            </th>
            <th class="en-table__th en-table__th--course">
              <i class="bi bi-book"></i> Course / Instructor
            </th>
            <th class="en-table__th en-table__th--price">
              <i class="bi bi-tag"></i> Price
            </th>
            <th class="en-table__th en-table__th--status">
              <i class="bi bi-shield-check"></i> Status
            </th>
            <th class="en-table__th en-table__th--date">
              <i class="bi bi-clock"></i> Date
            </th>
            <th class="en-table__th en-table__th--actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @enrollments.each do |enrollment| %>
            <tr class="en-table__row">
              
              <%# ID %>
              <td class="en-table__td">
                <span class="en-table__order-id">#<%= enrollment.id %></span>
              </td>

              <%# Student %>
              <td class="en-table__td">
                <div class="en-table__user-cell">
                  <div class="en-table__avatar">
                    <img src="https://ui-avatars.com/api/?name=<%= ERB::Util.url_encode(enrollment.user.name) %>&background=random&size=80&bold=true&format=png"
                         class="en-table__avatar-img" alt="<%= enrollment.user.name %>">
                  </div>
                  <div>
                    <span class="en-table__username"><%= enrollment.user.name %></span>
                    <span class="en-table__sub"><%= enrollment.user.email %></span>
                  </div>
                </div>
              </td>

              <%# Course %>
              <td class="en-table__td">
                <div class="en-table__course">
                  <span class="en-table__course-title" title="<%= enrollment.course.title %>">
                    <%= enrollment.course.title.truncate(35) %>
                  </span>
                  <span class="en-table__sub">Instr: <%= enrollment.course.creator&.name %></span>
                </div>
              </td>

              <%# Price %>
              <td class="en-table__td">
                <div class="en-table__price">
                  <% if enrollment.price.nil? || enrollment.price.to_i == 0 %>
                    <span class="en-price-badge en-price-badge--free">Free</span>
                  <% else %>
                    <span class="en-price-value text-gradient-primary">
                      <%= number_to_currency(enrollment.price, unit: "₫", precision: 0, format: "%n %u") %>
                    </span>
                  <% end %>
                </div>
              </td>

              <%# Status %>
              <td class="en-table__td">
                <div class="en-table__status">
                  <% if enrollment.active? %>
                    <span class="en-status en-status--paid">
                      <i class="bi bi-check-circle-fill"></i> Paid
                    </span>
                  <% elsif enrollment.pending? %>
                    <span class="en-status en-status--pending">
                      <i class="bi bi-hourglass-split"></i> Pending
                    </span>
                  <% else %>
                    <span class="en-status en-status--cancelled">Cancelled</span>
                  <% end %>
                </div>
              </td>

              <%# Date %>
              <td class="en-table__td">
                <div class="en-table__date">
                  <span class="en-table__date-full"><%= enrollment.created_at.strftime("%b %d, %Y") %></span>
                  <span class="en-table__sub"><%= enrollment.created_at.strftime("%H:%M") %></span>
                </div>
              </td>

              <%# Actions %>
              <td class="en-table__td en-table__td--actions">
                <div class="en-table__action-group">
                  <%= link_to admin_enrollment_path(enrollment),
                        data: { turbo_method: :delete, turbo_confirm: "Delete order ##{enrollment.id}?" },
                        class: "en-btn en-btn--delete",
                        title: "Delete order" do %>
                    <%= image_tag 'delete.png', class: 'crs-btn__img', alt: 'Delete' %>
                  <% end %>
                </div>
              </td>

            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="en-empty">
        <div class="en-empty__icon"><i class="bi bi-receipt-cutoff"></i></div>
        <h3>No enrollment data</h3>
        <p>Your sales records and enrollment history will be listed here.</p>
      </div>
    <% end %>
  </div>

  <%# ── Pagination ───────────────────────────────────────────── %>
  <% if @pagy.pages > 1 %>
    <div class="en-pagination">
      <div class="en-pagination__nav"><%== pagy_nav(@pagy) %></div>
    </div>
  <% end %>

</div>
