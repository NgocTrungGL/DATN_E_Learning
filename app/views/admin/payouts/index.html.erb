<%# Admin Payouts Index — Bootstrap-free BEM redesign %>

<div class="admin-page-header">
  <div class="admin-page-header__inner">
    <div>
      <div class="admin-page-header__badge"><i class="bi bi-bank2"></i> Tài chính</div>
      <h1 class="admin-page-header__title">Yêu cầu Rút tiền</h1>
    </div>
  </div>
</div>

<div class="admin-page-body">
  <div class="admin-table-wrapper">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Giảng viên</th>
          <th>Số tiền</th>
          <th>Thông tin ngân hàng</th>
          <th>Trạng thái</th>
          <th style="text-align: right;">Hành động</th>
        </tr>
      </thead>
      <tbody>
        <% @payouts.each do |payout| %>
          <tr>
            <td>
              <div class="admin-table__title"><%= payout.user.name %></div>
              <div class="admin-table__sub">Ví: <%= number_to_currency(payout.user.wallet.balance, unit: "₫", precision: 0) %></div>
            </td>
            <td style="font-weight:800; color:#ef4444; font-size:1.05rem;">
              -<%= number_to_currency(payout.amount, unit: "₫", precision: 0) %>
            </td>
            <td>
              <div class="admin-table__title"><%= payout.bank_name %></div>
              <div style="font-family:monospace; font-size:0.82rem; color:#2563eb; margin:2px 0;"><%= payout.bank_account_num %></div>
              <div class="admin-table__sub" style="text-transform:uppercase;"><%= payout.bank_account_name %></div>
            </td>
            <td>
              <% case payout.status %>
              <% when 'pending' %>
                <span class="admin-badge admin-badge--warning"><i class="bi bi-hourglass"></i> Chờ duyệt</span>
              <% when 'approved' %>
                <span class="admin-badge admin-badge--success"><i class="bi bi-check-circle"></i> Đã chuyển</span>
              <% when 'rejected' %>
                <span class="admin-badge admin-badge--neutral"><i class="bi bi-x-circle"></i> Đã từ chối</span>
              <% end %>
              <div class="admin-table__sub" style="margin-top:4px;"><%= payout.created_at.strftime("%d/%m %H:%M") %></div>
            </td>
            <td>
              <div class="admin-table__actions">
                <% if payout.pending? %>
                  <%= link_to approve_admin_payout_path(payout),
                        data: { turbo_method: :patch, turbo_confirm: "Xác nhận ĐÃ CHUYỂN KHOẢN ngân hàng cho giảng viên này?" },
                        class: "btn-action btn-action--success" do %>
                    <i class="bi bi-check-lg"></i> Duyệt
                  <% end %>
                  <%= link_to reject_admin_payout_path(payout),
                        data: { turbo_method: :patch, turbo_confirm: "Từ chối yêu cầu này?" },
                        class: "btn-action btn-action--danger" do %>
                    <i class="bi bi-x-lg"></i>
                  <% end %>
                <% else %>
                  <span style="font-size:0.8rem; color:#94a3b8;"><i class="bi bi-lock-fill"></i> Đã xử lý</span>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>

        <% if @payouts.empty? %>
          <tr>
            <td colspan="5">
              <div class="admin-table__empty">
                <i class="bi bi-bank2"></i>
                <p>Chưa có yêu cầu rút tiền nào.</p>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
