<div class="container-fluid py-4">
  <h2 class="h3 fw-bold text-gray-800 mb-4 border-start border-4 border-danger ps-3">Yêu cầu Rút tiền</h2>

  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="bg-light">
            <tr>
              <th class="ps-4">Giảng viên</th>
              <th>Số tiền</th>
              <th>Ngân hàng</th>
              <th>Trạng thái</th>
              <th class="text-end pe-4">Hành động</th>
            </tr>
          </thead>
          <tbody>
            <% @payouts.each do |payout| %>
              <tr>
                <td class="ps-4">
                  <div class="fw-bold"><%= payout.user.name %></div>
                  <div class="small text-muted">Ví hiện tại: <%= number_to_currency(payout.user.wallet.balance, unit: "₫", precision: 0) %></div>
                </td>

                <td class="fw-bold text-danger">
                  -<%= number_to_currency(payout.amount, unit: "₫", precision: 0) %>
                </td>

                <td class="small">
                  <div class="fw-bold text-dark"><%= payout.bank_name %></div>
                  <div class="font-monospace text-primary my-1"><%= payout.bank_account_num %></div>
                  <div class="text-uppercase text-muted" style="font-size: 0.85rem;">
                    <%= payout.bank_account_name %>
                  </div>
                </td>

                <td>
                  <% case payout.status %>
                  <% when 'pending' %>
                    <span class="badge bg-warning text-dark">Chờ duyệt</span>
                  <% when 'approved' %>
                    <span class="badge bg-success">Đã chuyển</span>
                  <% when 'rejected' %>
                    <span class="badge bg-secondary">Đã từ chối</span>
                  <% end %>
                  <div class="small text-muted"><%= payout.created_at.strftime("%d/%m %H:%M") %></div>
                </td>

                <td class="text-end pe-4">
                  <% if payout.pending? %>
                    <%= link_to approve_admin_payout_path(payout), data: { turbo_method: :patch, turbo_confirm: "Xác nhận ĐÃ CHUYỂN KHOẢN ngân hàng cho giảng viên này?" }, class: "btn btn-success btn-sm" do %>
                      <i class="bi bi-check-lg"></i> Duyệt
                    <% end %>

                    <%= link_to reject_admin_payout_path(payout), data: { turbo_method: :patch, turbo_confirm: "Từ chối yêu cầu này?" }, class: "btn btn-outline-danger btn-sm" do %>
                      <i class="bi bi-x-lg"></i>
                    <% end %>
                  <% else %>
                    <span class="text-muted small"><i class="bi bi-lock-fill"></i> Đã xử lý</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
