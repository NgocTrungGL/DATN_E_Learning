<%# Admin Reviews Index — Premium BEM Redesign %>

<div class="rv-page">

  <%# ── Page Header ─────────────────────────────────────────── %>
  <header class="rv-page__header">
    <div class="rv-page__header-left">
      <div class="rv-page__breadcrumb">
        <i class="bi bi-star"></i>
        <span>Social Proof</span>
      </div>
      <h1 class="rv-page__title">Review Management</h1>
      <p class="rv-page__subtitle">Monitor and manage course ratings and feedback from students.</p>
    </div>
    <div class="rv-page__header-right">
      <div class="rv-page__stat-pill">
        <i class="bi bi-star-fill"></i>
        <strong><%= @pagy.count %></strong>
        <span>reviews</span>
      </div>
    </div>
  </header>

  <%# ── Table Card ────────────────────────────────────────────── %>
  <div class="rv-table-card">
    <% if @reviews.any? %>
      <table class="rv-table">
        <thead>
          <tr>
            <th class="rv-table__th rv-table__th--student">
              <i class="bi bi-person"></i> Student
            </th>
            <th class="rv-table__th rv-table__th--course">
              <i class="bi bi-book"></i> Course
            </th>
            <th class="rv-table__th rv-table__th--rating">
              <i class="bi bi-stars"></i> Rating
            </th>
            <th class="rv-table__th rv-table__th--feedback">
              <i class="bi bi-chat-quote"></i> Feedback
            </th>
            <th class="rv-table__th rv-table__th--actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @reviews.each do |review| %>
            <tr class="rv-table__row">

              <%# Student info %>
              <td class="rv-table__td">
                <div class="rv-table__user-cell">
                  <div class="rv-table__avatar">
                    <% if review.user.avatar_url.present? %>
                      <img src="<%= review.user.avatar_url %>" class="rv-table__avatar-img" alt="<%= review.user.name %>">
                    <% else %>
                      <span class="rv-table__avatar-text"><%= review.user.name.first.upcase %></span>
                    <% end %>
                  </div>
                  <div>
                    <span class="rv-table__user-name"><%= review.user.name %></span>
                    <span class="rv-table__sub"><%= review.user.email %></span>
                  </div>
                </div>
              </td>

              <%# Course %>
              <td class="rv-table__td">
                <div class="rv-table__course">
                  <span class="rv-table__course-title" title="<%= review.course.title %>">
                    <%= review.course.title.truncate(35) %>
                  </span>
                  <span class="rv-table__sub">ID: #<%= review.course.id %></span>
                </div>
              </td>

              <%# Rating %>
              <td class="rv-table__td">
                <div class="rv-table__rating">
                  <div class="rv-table__stars">
                    <% review.rating.times do %><i class="bi bi-star-fill"></i><% end %>
                    <% (5 - review.rating).times do %><i class="bi bi-star"></i><% end %>
                  </div>
                  <span class="rv-table__rating-text"><%= review.rating %>/5 stars</span>
                </div>
              </td>

              <%# Feedback %>
              <td class="rv-table__td">
                <p class="rv-table__feedback-text">"<%= review.content.truncate(100) %>"</p>
                <div class="rv-table__sub"><i class="bi bi-clock"></i> <%= time_ago_in_words(review.created_at) %> ago</div>
              </td>

              <%# Actions %>
              <td class="rv-table__td rv-table__td--actions">
                <div class="rv-table__action-group">
                  <%= link_to admin_review_path(review),
                      data: { turbo_method: :delete, turbo_confirm: 'Are you sure you want to delete this review?' },
                      class: 'rv-btn rv-btn--delete', title: 'Delete review' do %>
                    <%= image_tag 'delete.png', class: 'crs-btn__img', alt: 'Delete' %>
                  <% end %>
                </div>
              </td>

            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="rv-empty">
        <div class="rv-empty__icon"><i class="bi bi-star"></i></div>
        <h3>No reviews yet</h3>
        <p>Feedback from students will appear here once they complete courses.</p>
      </div>
    <% end %>
  </div>

  <%# ── Pagination ───────────────────────────────────────────── %>
  <% if @pagy.pages > 1 %>
    <div class="rv-pagination">
      <div class="rv-pagination__nav"><%== pagy_nav(@pagy) %></div>
      <p class="rv-pagination__note">
        Showing <strong><%= @pagy.items %></strong> of <strong><%= @pagy.count %></strong> reviews
      </p>
    </div>
  <% end %>

</div>
