<div class="nested-form-wrapper border rounded px-3 py-2 mb-3 bg-white shadow-sm" data-new-record="<%= f.object.new_record? %>">
  <div class="d-flex align-items-center gap-3">

    <div class="form-check m-0">
      <%# Class 'option-selector' dùng để JS tìm và xử lý logic Single/Multiple %>
      <%= f.check_box :is_correct, class: "form-check-input option-selector",
          data: { action: "change->question-form#handleCheck" } %>
    </div>

    <div class="flex-grow-1">
      <%= f.text_field :option_text, class: "form-control", placeholder: "Nhập nội dung đáp án..." %>
    </div>

    <button type="button" class="btn btn-outline-danger btn-sm"
            data-action="question-form#removeAssociation">
      <i class="bi bi-trash"></i>
    </button>

    <%= f.hidden_field :_destroy %>
  </div>
</div>
