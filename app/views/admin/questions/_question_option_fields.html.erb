<%# Question Option Fields — Premium BEM Redesign %>
<%# Preserves: Stimulus data-action="change->question-form#handleCheck" %>
<%# Preserves: Stimulus data-action="question-form#removeAssociation" %>
<%# Preserves: .nested-form-wrapper (used by removeAssociation) %>
<%# Preserves: .option-selector class (used by toggleType to switch radio/checkbox) %>

<div class="qs-option-row nested-form-wrapper" data-new-record="<%= f.object.new_record? %>">

  <%# Checkbox/Radio — class MUST stay "option-selector" for Stimulus toggleType %>
  <%= f.check_box :is_correct,
      class: "option-selector qs-option-row__selector",
      data: { action: "change->question-form#handleCheck" } %>

  <div class="qs-option-row__input-wrap">
    <%= f.text_field :option_text,
        class: "qs-option-row__input",
        placeholder: "Enter answer option text..." %>
  </div>

  <button type="button"
          class="qs-option-row__remove"
          data-action="question-form#removeAssociation"
          title="Remove option">
    <%= image_tag 'delete.png', class: 'crs-btn__img', alt: 'Remove' %>
  </button>

  <%= f.hidden_field :_destroy %>
</div>
