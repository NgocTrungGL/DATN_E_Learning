<%# Admin Question Form — Premium BEM Redesign %>
<%# Preserves: Stimulus data-controller="question-form", data-action, data-*-target %>

<%= form_with(model: [:admin, @question], data: { controller: "question-form" }) do |f| %>

  <%# ── Validation Errors ──────────────────────────────────── %>
  <% if @question.errors.any? %>
    <div class="qs-form__errors">
      <i class="bi bi-exclamation-triangle-fill qs-form__errors-icon"></i>
      <div>
        <strong class="qs-form__errors-title"><%= @question.errors.count %> error(s) need fixing:</strong>
        <ul class="qs-form__errors-list">
          <% @question.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <%# ── Card 1: Question Info ──────────────────────────────── %>
  <div class="qs-form__card">
    <div class="qs-form__card-header">
      <h2 class="qs-form__card-title">Question Information</h2>
      <p class="qs-form__card-subtitle">Enter the question text, type and difficulty level</p>
    </div>
    <div class="qs-form__card-body">

      <div class="qs-form__field qs-form__field--full">
        <label class="qs-form__label qs-form__label--required">
          <i class="bi bi-chat-left-text"></i> Question Text
        </label>
        <%= f.text_area :question_text, rows: 4, class: "qs-form__textarea", required: true,
              placeholder: "Enter the full question text here..." %>
      </div>

      <div class="qs-form__grid">
        <div class="qs-form__field">
          <label class="qs-form__label qs-form__label--required">
            <i class="bi bi-ui-radios"></i> Question Type
          </label>
          <%= f.select :question_type,
                Question.question_types.keys.map { |k| [k.humanize, k] },
                {},
                class: "qs-form__select",
                data: { question_form_target: "typeSelect", action: "change->question-form#toggleType" } %>
        </div>
        <div class="qs-form__field">
          <label class="qs-form__label qs-form__label--required">
            <i class="bi bi-bar-chart"></i> Difficulty
          </label>
          <%= f.select :difficulty, Question.difficulties.keys.map { |k| [k.humanize, k] },
                {}, class: "qs-form__select" %>
        </div>
      </div>

    </div>
  </div>

  <%# ── Card 2: Course Link ───────────────────────────────── %>
  <div class="qs-form__card">
    <div class="qs-form__card-header">
      <h2 class="qs-form__card-title">Course Association</h2>
      <p class="qs-form__card-subtitle">Link this question to a course so it appears in the question bank</p>
    </div>
    <div class="qs-form__card-body">
      <div class="qs-form__field qs-form__field--full">
        <label class="qs-form__label qs-form__label--required">
          <i class="bi bi-book"></i> Course
        </label>
        <%= f.collection_select :course_id, @courses, :id, :title,
              { prompt: "--- Select a course ---" },
              { class: "qs-form__select", required: true } %>
      </div>
    </div>
  </div>

  <%# ── Card 3: Answer Options ────────────────────────────── %>
  <div class="qs-form__card">
    <div class="qs-form__card-header">
      <h2 class="qs-form__card-title">Answer Options</h2>
      <p class="qs-form__card-subtitle">Check the checkbox to mark the correct answer(s)</p>
    </div>
    <div class="qs-form__card-body">

      <div class="qs-options-list" id="question_options"
           data-question-form-target="optionsList">
        <%= f.fields_for :question_options do |option_form| %>
          <%= render "question_option_fields", f: option_form %>
        <% end %>
      </div>

      <div class="qs-form__add-option" data-question-form-target="addButtonContainer">
        <template data-question-form-target="template">
          <%= f.fields_for :question_options, QuestionOption.new, child_index: 'NEW_RECORD' do |option_form| %>
            <%= render "question_option_fields", f: option_form %>
          <% end %>
        </template>

        <button type="button"
                class="qs-form__add-btn"
                data-action="question-form#addAssociation">
          <i class="bi bi-plus-circle"></i> Add another option
        </button>
      </div>

    </div>
  </div>

  <%# ── Actions ─────────────────────────────────────────────── %>
  <div class="qs-form__actions">
    <%= link_to admin_questions_path, class: "qs-form__btn qs-form__btn--cancel" do %>
      Cancel
    <% end %>
    <%= f.submit "Save Question", class: "qs-form__btn qs-form__btn--save" %>
  </div>

<% end %>
