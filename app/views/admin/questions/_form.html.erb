<%= form_with(model: [:admin, @question], data: { controller: "question-form" }) do |f| %>

  <% if @question.errors.any? %>
    <div class="alert alert-danger shadow-sm">
      <ul class="mb-0">
        <% @question.errors.full_messages.each do |message| %><li><%= message %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="card shadow-lg border-0">
    <div class="card-header bg-primary text-white py-3">
      <h4 class="mb-0 fw-semibold">✏️ Tạo / Chỉnh sửa Câu hỏi</h4>
    </div>

    <div class="card-body p-4">
      <h5 class="fw-bold mb-3">📌 Thông tin câu hỏi</h5>

      <div class="mb-4">
        <%= f.label :question_text, "Nội dung câu hỏi", class: "form-label fw-semibold" %>
        <%= f.text_area :question_text, rows: 4, class: "form-control shadow-sm", required: true %>
      </div>

      <div class="row">
        <div class="col-md-6 mb-4">
          <%= f.label :question_type, "Loại câu hỏi", class: "form-label fw-semibold" %>
          <%= f.select :question_type,
                Question.question_types.keys.map { |k| [k.humanize, k] },
                {},
                class: "form-select shadow-sm",
                data: { question_form_target: "typeSelect", action: "change->question-form#toggleType" } %>
        </div>

        <div class="col-md-6 mb-4">
          <%= f.label :difficulty, "Độ khó", class: "form-label fw-semibold" %>
          <%= f.select :difficulty, Question.difficulties.keys.map { |k| [k.humanize, k] }, {}, class: "form-select shadow-sm" %>
        </div>
      </div>

      <hr>

      <h5 class="fw-bold mb-3">📚 Liên kết khóa học</h5>
      <div class="row">
        <div class="col-md-12 mb-4">
          <%= f.label :course_id, "Gắn vào Khóa học (bắt buộc)", class: "form-label fw-semibold" %>
          <%= f.collection_select :course_id, @courses, :id, :title, { prompt: "--- Chọn một khóa học ---" }, { class: "form-select shadow-sm", required: true } %>
        </div>
      </div>

      <hr>

      <h5 class="fw-bold mb-3">📝 Các lựa chọn trả lời</h5>
      <p class="text-muted" data-question-form-target: "instructionText">
        Đánh dấu vào ô để chọn đáp án đúng.
      </p>

      <div id="question_options" data-question-form-target="optionsList" class="bg-light p-3 rounded-3 border">
        <%= f.fields_for :question_options do |option_form| %>
          <%= render "question_option_fields", f: option_form %>
        <% end %>
      </div>

      <div class="mt-3" data-question-form-target="addButtonContainer">
        <template data-question-form-target="template">
          <%= f.fields_for :question_options, QuestionOption.new, child_index: 'NEW_RECORD' do |option_form| %>
            <%= render "question_option_fields", f: option_form %>
          <% end %>
        </template>

        <button type="button" class="btn btn-outline-primary btn-sm dashed-border" data-action="question-form#addAssociation">
          <i class="bi bi-plus-circle me-1"></i> Thêm lựa chọn khác
        </button>
      </div>

    </div>
  </div>

  <div class="mt-4 d-flex gap-2">
    <%= f.submit "💾 Lưu câu hỏi", class: "btn btn-primary px-4 py-2 fw-semibold" %>
    <%= link_to "🔙 Hủy", admin_questions_path, class: "btn btn-secondary px-4 py-2" %>
  </div>

<% end %>
