<div class="container mt-5">
  <div class="card shadow-sm mx-auto" style="max-width: 600px;">
    <div class="card-header bg-white text-center py-4">
      <h3 class="fw-bold mb-0">Application Status</h3>
    </div>

    <div class="card-body text-center p-5">
      <% if @profile.pending? %>
        <i class="bi bi-hourglass-split display-1 text-warning mb-3"></i>
        <h4 class="fw-bold text-warning">Pending review</h4>
        <p class="text-muted mt-3">
          Your application has been submitted successfully.<br>
          Please wait for admin review (typically 24h).
        </p>

      <% elsif @profile.approved? %>
        <i class="bi bi-check-circle-fill display-1 text-success mb-3"></i>
        <h4 class="fw-bold text-success">Approved!</h4>
        <p class="text-muted mt-3">Congratulations, you are now an instructor.</p>
        <div class="mt-4">
          <%= link_to "Go to Instructor Dashboard", instructor_root_path, class: "btn btn-primary fw-bold px-4" %>
        </div>

      <% elsif @profile.rejected? %>
        <i class="bi bi-x-circle-fill display-1 text-danger mb-3"></i>
        <h4 class="fw-bold text-danger">Application rejected</h4>
        <p class="text-muted mt-3">Sorry, your application was not approved.</p>
      <% end %>
    </div>

    <div class="card-footer bg-light text-center py-3">
      <%= link_to "Back to homepage", root_path, class: "text-decoration-none text-muted small" %>
    </div>
  </div>
</div>
