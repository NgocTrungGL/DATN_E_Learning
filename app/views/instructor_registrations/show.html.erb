<div class="container mt-5">
  <div class="card shadow-sm mx-auto" style="max-width: 600px;">
    <div class="card-header bg-white text-center py-4">
      <h3 class="fw-bold mb-0">Trạng thái Hồ sơ</h3>
    </div>

    <div class="card-body text-center p-5">
      <% if @profile.pending? %>
        <i class="bi bi-hourglass-split display-1 text-warning mb-3"></i>
        <h4 class="fw-bold text-warning">Đang chờ duyệt</h4>
        <p class="text-muted mt-3">
          Hồ sơ của bạn đã được gửi thành công.<br>
          Vui lòng đợi Admin xét duyệt (thường mất 24h).
        </p>

      <% elsif @profile.approved? %>
        <i class="bi bi-check-circle-fill display-1 text-success mb-3"></i>
        <h4 class="fw-bold text-success">Đã được duyệt!</h4>
        <p class="text-muted mt-3">Chúc mừng bạn đã trở thành Giảng viên.</p>
        <div class="mt-4">
          <%= link_to "Vào Bảng giảng dạy", instructor_root_path, class: "btn btn-primary fw-bold px-4" %>
        </div>

      <% elsif @profile.rejected? %>
        <i class="bi bi-x-circle-fill display-1 text-danger mb-3"></i>
        <h4 class="fw-bold text-danger">Yêu cầu bị từ chối</h4>
        <p class="text-muted mt-3">Rất tiếc, hồ sơ chưa phù hợp.</p>
      <% end %>
    </div>

    <div class="card-footer bg-light text-center py-3">
      <%= link_to "Quay về trang chủ", root_path, class: "text-decoration-none text-muted small" %>
    </div>
  </div>
</div>
