<div class="container mt-5">
  <div class="card shadow-sm mx-auto" style="max-width: 700px;">
    <div class="card-header bg-primary text-white">
      <h3 class="mb-0">Đăng ký trở thành Giảng viên</h3>
    </div>
    <div class="card-body">
      <%= form_with(model: @profile, url: instructor_registration_path, local: true) do |f| %>

        <div class="mb-3">
          <%= f.label :bio_detailed, "Giới thiệu kinh nghiệm giảng dạy", class: "form-label" %>
          <%= f.text_area :bio_detailed, rows: 5, class: "form-control", required: true %>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :phone, "Số điện thoại", class: "form-label" %>
            <%= f.text_field :phone, class: "form-control", required: true %>
          </div>
          <div class="col-md-6 mb-3">
            <%= f.label :linkedin_url, "LinkedIn Profile", class: "form-label" %>
            <%= f.text_field :linkedin_url, class: "form-control" %>
          </div>
        </div>

        <div class="mb-3">
          <%= f.label :cv_url, "Link CV (Google Drive/Dropbox)", class: "form-label" %>
          <%= f.text_field :cv_url, class: "form-control", required: true, placeholder: "https://..." %>
          <div class="form-text">Hãy chắc chắn link này ở chế độ công khai.</div>
        </div>

        <button type="submit" class="btn btn-success w-100 fw-bold">Gửi đơn đăng ký</button>
      <% end %>
    </div>
  </div>
</div>
